---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  /** Path to a per-page OG image, e.g. "/og/services.png". Defaults to /og-default.png. */
  ogImage?: string;
  /** Optional JSON-LD object(s) to inject — pass as a single object or array. */
  schema?: object | object[];
}

const {
  title = "fwd. — A small web design studio",
  description = "fwd. is a small web design studio crafting clean, considered websites for practices and small businesses. Flat pricing. Honest timelines.",
  ogImage = "/og-default.png",
  schema,
} = Astro.props;

// Build absolute URLs — Astro.site must be set in astro.config.mjs for these
// to resolve correctly. Falls back gracefully in dev.
const siteOrigin = Astro.site?.origin ?? "https://fwd.studio";
const canonical = new URL(Astro.url.pathname, siteOrigin).toString();
const ogImageUrl = new URL(ogImage, siteOrigin).toString();

// Default site-wide JSON-LD: ProfessionalService.
// Per-page schemas (FAQPage, BreadcrumbList) come in via the `schema` prop.
const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "Forward Design Consulting",
  alternateName: "fwd.",
  url: siteOrigin,
  logo: `${siteOrigin}/logo.png`,
  image: ogImageUrl,
  description:
    "A small web design studio crafting clean, flat-priced websites for practices and small businesses.",
  areaServed: "US",
  priceRange: "$800–$1,800",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Irvine",
    addressRegion: "CA",
    addressCountry: "US",
  },
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "Customer Service",
    email: "hello@fwd.studio",
    availableLanguage: ["English"],
  },
};
const allSchemas = schema ? [defaultSchema, ...(Array.isArray(schema) ? schema : [schema])] : [defaultSchema];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0D2F45" />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="fwd." />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Robots -->
    <meta name="robots" content="index, follow, max-image-preview:large" />

    {/* Inline-SVG favicon — same mark as the original, periwinkle dot accent */}
    <link
      rel="icon"
      type="image/svg+xml"
      href={`data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='6' fill='%230D2F45'/><text x='50%25' y='58%25' text-anchor='middle' font-family='Georgia,serif' font-style='italic' font-size='16' fill='white'>n</text><circle cx='22' cy='22' r='2' fill='%238E94B8'/></svg>`}
    />

    {/* Fonts: Fraunces (display serif) + Inter Tight (body) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..700,0..100;1,9..144,300..700,0..100&family=Inter+Tight:ital,wght@0,300..700;1,300..700&display=swap"
      rel="stylesheet"
    />

    {/* Structured data */}
    {allSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    {/* === Analytics ===
        Drop in your privacy-respecting analytics provider here.
        Plausible example (uncomment + set your domain):
        <script defer data-domain="fwd.studio" src="https://plausible.io/js/script.js"></script>
        Fathom example:
        <script src="https://cdn.usefathom.com/script.js" data-site="YOUR_SITE_ID" defer></script>
    */}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <Nav />

    <main id="main">
      <slot />
    </main>

    <Footer />

    {/* Tiny inline scripts — small enough that bundling and shipping a separate
        file would cost more than just inlining. is:inline keeps them out of the
        Astro build pipeline. */}
    <script is:inline>
      // === Mobile nav toggle =================================================
      const toggle = document.getElementById("navToggle");
      const links = document.getElementById("navLinks");
      toggle?.addEventListener("click", () => {
        const open = links.classList.toggle("is-open");
        toggle.setAttribute("aria-expanded", String(open));
      });

      // === Sticky-nav scrolled state =========================================
      const navEl = document.getElementById("nav");
      const setNavScrolled = () => {
        navEl?.classList.toggle("is-scrolled", window.scrollY > 8);
      };
      window.addEventListener("scroll", setNavScrolled, { passive: true });
      setNavScrolled();

      // === Card mouse-spotlight effect =======================================
      // Any element marked [data-tilt] gets two CSS vars (--mx, --my) updated
      // on mousemove, used by the radial-gradient hover sheen on cards.
      document.querySelectorAll("[data-tilt]").forEach((card) => {
        card.addEventListener("mousemove", (e) => {
          const rect = card.getBoundingClientRect();
          card.style.setProperty("--mx", ((e.clientX - rect.left) / rect.width) * 100 + "%");
          card.style.setProperty("--my", ((e.clientY - rect.top) / rect.height) * 100 + "%");
        });
      });

      // === Scroll reveal =====================================================
      // .reveal (staggers direct children) and .r-up (single element) flip to
      // .is-in the first time they enter the viewport. Runs once per element.
      (function initReveal() {
        const targets = document.querySelectorAll(".reveal, .r-up");
        if (!targets.length) return;
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reduce || !("IntersectionObserver" in window)) {
          targets.forEach((el) => el.classList.add("is-in"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-in");
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );
        targets.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
