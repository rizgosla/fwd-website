---
const phrases = [
  "Practices",
  "Small businesses",
  "Studios",
  "Independent founders",
  "Service providers",
  "Local shops",
  "Practitioners",
  "Side projects",
];
---

<div class="marquee" aria-hidden="true">
  <div class="marquee-track">
    <div class="marquee-row">
      {phrases.map((p) => (
        <span class="marquee-item">
          {p}<span class="marquee-dot">●</span>
        </span>
      ))}
    </div>
    <div class="marquee-row" aria-hidden="true">
      {phrases.map((p) => (
        <span class="marquee-item">
          {p}<span class="marquee-dot">●</span>
        </span>
      ))}
    </div>
  </div>
</div>

<style>
  .marquee {
    border-block: 1px solid var(--color-line);
    background: var(--color-paper);
    overflow: hidden;
    padding: 22px 0;
  }
  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee 40s linear infinite;
  }
  .marquee-row {
    display: flex;
    gap: 44px;
    padding-inline: 22px;
    white-space: nowrap;
  }
  .marquee-item {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 350;
    font-size: var(--text-step-3);
    letter-spacing: -0.02em;
    color: var(--color-fg);
    font-variation-settings: "opsz" 144, "SOFT" 70;
    display: inline-flex;
    align-items: center;
    gap: 22px;
  }
  .marquee-dot {
    color: var(--color-periwinkle);
    font-style: normal;
    font-size: 0.5em;
  }
  @keyframes marquee {
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }
</style>
