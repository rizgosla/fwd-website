---
/* ----------------------------------------------------------------------------
   HeroShowcase — the home-page hero's right panel.

   A browser frame that *builds* a real shipped site in front of you
   (blank canvas → grid → wireframe → live), then — if more than one site is
   registered — moves on and builds the next. Seeded from src/data/showcase.ts;
   adding a site is a one-entry change there and everything below scales to it.

   Each preview is rendered on a fixed 1000×620 canvas (.sc-stage) and scaled
   to fit the frame with a single transform, so proportions never break.
   -------------------------------------------------------------------------- */
import { showcase } from "../data/showcase";
import SitePreview from "./showcase/SitePreview.astro";

const total = showcase.length;
const pad = (n: number) => n.toString().padStart(2, "0");
---

<div class="sc-panel" id="heroShowcase" data-total={total}>
  <div class="browser">
    {/* chrome — dots, live URL bar, build/stage pill */}
    <div class="browser-chrome">
      <div class="dots">
        <span style="background:#FF6058"></span><span style="background:#FFBE2E"></span><span style="background:#28C940"></span>
      </div>
      <div class="urlbar">
        <span class="lock" aria-hidden="true">●</span>
        <span class="url" id="scUrl">localhost:4321</span>
      </div>
      <div class="stage-pill" id="scPill">
        <span class="live-dot" aria-hidden="true"></span>
        <span id="scPillText">Blank canvas</span>
      </div>
    </div>

    {/* stacked slides — each builds, then reveals its real site */}
    <div class="browser-body" id="scBody">
      {showcase.map((site, i) => (
        <a
          class="sc-slide"
          href={site.url}
          target="_blank"
          rel="noopener noreferrer"
          data-idx={i}
          data-domain={site.domain}
          data-name={site.name}
          data-industry={site.industry}
          aria-label={`Visit ${site.name} (${site.domain})`}
          aria-hidden={i === 0 ? "false" : "true"}
          tabindex={i === 0 ? 0 : -1}
        >
          <div class="sc-stage">
            {/* build scaffolding — fades out as the real site comes in */}
            <div class="sc-grid"></div>
            <div class="sc-wire">
              <div class="w-nav">
                <span class="w-logo"></span>
                <span class="w-links"><span></span><span></span><span></span></span>
                <span class="w-cta"></span>
              </div>
              <div class="w-hero">
                <div class="w-copy">
                  <span class="w-eyebrow"></span>
                  <span class="w-bar"></span>
                  <span class="w-bar w-bar-2"></span>
                  <span class="w-line"></span>
                  <span class="w-line w-line-2"></span>
                  <span class="w-pill"></span>
                </div>
                <div class="w-media"></div>
              </div>
            </div>
            {/* the real site */}
            <SitePreview site={site} />
          </div>
        </a>
      ))}
    </div>

    {/* footer — project label, build progress track, dot nav */}
    <div class="browser-foot">
      <span class="foot-label" id="scLabel">building…</span>
      <div class="track">
        <div class="fill" id="scFill"></div>
      </div>
      {total > 1 && (
        <div class="sc-dots" role="tablist" aria-label="Choose a project to preview">
          {showcase.map((site, i) => (
            <button
              class="sc-dot"
              data-idx={i}
              role="tab"
              aria-selected={i === 0 ? "true" : "false"}
              aria-label={site.name}
            ></button>
          ))}
        </div>
      )}
      <span class="foot-index" id="scIndex">{pad(1)} / {pad(total)}</span>
    </div>
  </div>
</div>

<style>
  .sc-panel {
    position: relative;
    width: 100%;
    height: 100%;
    background: linear-gradient(160deg, #f6f6f8 0%, #eceef5 100%);
    border-left: 1px solid var(--color-line);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(2rem, 5vh, 4rem) clamp(1rem, 3vw, 3rem);
    overflow: hidden;
    align-self: stretch;
    min-height: clamp(560px, 70vh, 760px);
  }
  .sc-panel::before {
    content: "";
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(13,47,69,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(13,47,69,0.06) 1px, transparent 1px);
    background-size: 38px 38px;
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 80%);
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 80%);
    pointer-events: none;
  }

  .browser {
    width: min(820px, 100%);
    background: #fff;
    border-radius: 14px;
    border: 1px solid var(--color-line);
    box-shadow: 0 60px 120px -40px rgb(7 23 34 / 0.40), 0 16px 36px -14px rgb(7 23 34 / 0.20);
    overflow: hidden;
    position: relative;
    z-index: 1;
  }

  .browser-chrome {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 18px;
    background: #f5f6f8;
    border-bottom: 1px solid var(--color-line);
  }
  .dots { display: flex; gap: 7px; }
  .dots span { width: 12px; height: 12px; border-radius: 50%; }
  .urlbar {
    flex: 1; height: 30px; border-radius: 7px;
    background: #fff; border: 1px solid var(--color-line);
    display: flex; align-items: center; gap: 9px; padding: 0 14px;
    font-family: var(--font-mono); font-size: 12px; color: var(--color-fg-muted);
    overflow: hidden;
  }
  .urlbar .url { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .urlbar .lock { color: var(--color-blue); font-size: 9px; }
  .stage-pill {
    display: inline-flex; align-items: center; gap: 7px;
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-blue);
    background: #fff; border: 1px solid var(--color-line);
    padding: 5px 12px; border-radius: 999px; white-space: nowrap;
  }
  .stage-pill .live-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--color-periwinkle);
    transition: background 400ms var(--ease-soft);
  }
  .stage-pill.is-live .live-dot {
    background: #28C940;
    box-shadow: 0 0 0 0 rgba(40,201,64,0.55);
    animation: scLive 2.4s var(--ease-soft) infinite;
  }
  @keyframes scLive {
    0%, 100% { box-shadow: 0 0 0 0 rgba(40,201,64,0.5); }
    50% { box-shadow: 0 0 0 6px rgba(40,201,64,0); }
  }

  /* Body matches the 1000×620 stage aspect, so a single scale fits exactly. */
  .browser-body {
    position: relative;
    width: 100%;
    aspect-ratio: 1000 / 620;
    background: #fff;
    overflow: hidden;
  }

  .sc-slide {
    position: absolute; inset: 0;
    display: block;
    text-decoration: none;
    opacity: 0;
    transition: opacity 600ms var(--ease-soft);
    pointer-events: none;
  }
  .sc-slide.is-active { opacity: 1; pointer-events: auto; }
  .sc-slide:focus-visible { outline: 3px solid var(--color-blue); outline-offset: -3px; }

  /* Fixed design canvas — JS sets transform: scale() to fit the body. */
  .sc-stage {
    position: absolute;
    top: 0; left: 0;
    width: 1000px;
    height: 620px;
    transform-origin: top left;
  }

  /* ---- build scaffolding ---- */
  .sc-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(13,47,69,0.10) 1px, transparent 1px),
      linear-gradient(90deg, rgba(13,47,69,0.10) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0;
  }
  .sc-wire {
    position: absolute; inset: 0;
    padding: 40px 56px;
    display: flex; flex-direction: column; gap: 40px;
    opacity: 0;
  }
  .w-nav { display: flex; align-items: center; gap: 24px; }
  .w-logo { width: 120px; height: 30px; border-radius: 6px; background: rgba(13,47,69,0.16); }
  .w-links { display: flex; gap: 18px; margin-left: auto; }
  .w-links span { width: 56px; height: 12px; border-radius: 3px; background: rgba(13,47,69,0.12); }
  .w-cta { width: 130px; height: 38px; border-radius: 999px; background: var(--color-periwinkle); opacity: 0.5; }
  .w-hero { flex: 1; display: grid; grid-template-columns: 1.1fr 1fr; gap: 44px; align-items: center; }
  .w-copy { display: flex; flex-direction: column; gap: 18px; }
  .w-eyebrow { width: 180px; height: 14px; border-radius: 3px; background: rgba(13,47,69,0.14); }
  .w-bar { width: 92%; height: 46px; border-radius: 6px; background: rgba(13,47,69,0.18); }
  .w-bar-2 { width: 64%; }
  .w-line { width: 80%; height: 14px; border-radius: 3px; background: rgba(13,47,69,0.12); }
  .w-line-2 { width: 60%; }
  .w-pill { width: 180px; height: 48px; border-radius: 999px; background: var(--color-periwinkle); opacity: 0.55; margin-top: 8px; }
  .w-media {
    height: 100%; min-height: 320px; border-radius: 12px;
    background: repeating-linear-gradient(135deg, rgba(13,47,69,0.10) 0 10px, transparent 10px 20px);
    border: 1px dashed rgba(13,47,69,0.22);
  }
  .sc-wire > *, .w-hero > *, .w-copy > * { transition: opacity 400ms var(--ease-soft), transform 400ms var(--ease-soft); }

  /* The real preview starts hidden; JS reveals it as the final build step. */
  .sc-stage :global(.sp) {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 600ms var(--ease-soft), transform 700ms var(--ease-soft);
  }

  .browser-foot {
    display: flex; align-items: center; gap: 14px;
    padding: 12px 18px;
    background: #fafafb;
    border-top: 1px solid var(--color-line);
  }
  .foot-label {
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-fg-muted);
    white-space: nowrap; min-width: 86px;
  }
  .track { flex: 1; height: 2px; background: rgba(7,23,34,0.08); border-radius: 2px; position: relative; }
  .fill { position: absolute; left: 0; top: 0; height: 100%; background: var(--color-periwinkle); border-radius: 2px; width: 0; }
  .sc-dots { display: flex; gap: 7px; }
  .sc-dot {
    width: 24px; height: 6px; border-radius: 999px;
    background: rgba(7,23,34,0.14); padding: 0;
    transition: background 280ms var(--ease-soft);
  }
  .sc-dot:hover { background: rgba(7,23,34,0.28); }
  .sc-dot[aria-selected="true"] { background: var(--color-blue); }
  .foot-index {
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.08em; color: var(--color-fg-muted); white-space: nowrap;
  }

  @media (max-width: 1000px) {
    .sc-panel {
      border-left: 0;
      border-top: 1px solid var(--color-line);
      min-height: 480px;
      padding-top: 3rem; padding-bottom: 4rem;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .sc-slide { transition: opacity 200ms linear; }
    .sc-stage :global(.sp) { transition: none; transform: none; }
    .stage-pill.is-live .live-dot { animation: none; }
  }
</style>

<script is:inline>
  (() => {
    const root = document.getElementById("heroShowcase");
    if (!root) return;
    const body = document.getElementById("scBody");
    const slides = Array.from(root.querySelectorAll(".sc-slide"));
    const dots = Array.from(root.querySelectorAll(".sc-dot"));
    const total = slides.length;
    if (!body || total === 0) return;

    const urlEl = document.getElementById("scUrl");
    const pill = document.getElementById("scPill");
    const pillText = document.getElementById("scPillText");
    const labelEl = document.getElementById("scLabel");
    const fillEl = document.getElementById("scFill");
    const indexEl = document.getElementById("scIndex");

    const pad = (n) => String(n).padStart(2, "0");
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // --- Keep the fixed 1000×620 canvases scaled to the live frame width. ---
    const fit = () => {
      const w = body.clientWidth;
      const s = w / 1000;
      root.querySelectorAll(".sc-stage").forEach((st) => {
        st.style.transform = `scale(${s})`;
      });
    };
    fit();
    if ("ResizeObserver" in window) new ResizeObserver(fit).observe(body);
    else window.addEventListener("resize", fit, { passive: true });

    // Build phases, by build-progress fraction (0→1).
    const PHASES = [
      { at: 0.0,  label: "Blank canvas" },
      { at: 0.18, label: "Grid system" },
      { at: 0.4,  label: "Wireframe" },
      { at: 0.66, label: "Content" },
    ];
    const BUILD = reduce ? 0 : 3600; // ms to build
    const HOLD = 3000;               // ms live before advancing

    const els = (slide) => ({
      grid: slide.querySelector(".sc-grid"),
      wire: slide.querySelector(".sc-wire"),
      wireKids: slide.querySelectorAll(".sc-wire .w-nav, .sc-wire .w-copy > *, .sc-wire .w-media"),
      sp: slide.querySelector(".sp"),
    });

    const reset = (slide) => {
      const e = els(slide);
      if (e.grid) e.grid.style.opacity = "0";
      if (e.wire) e.wire.style.opacity = "0";
      e.wireKids.forEach((k) => { k.style.opacity = "0"; k.style.transform = "translateY(10px)"; });
      if (e.sp) { e.sp.style.opacity = "0"; e.sp.style.transform = "translateY(14px)"; }
    };

    // Render one frame of the build for the active slide.
    const render = (slide, p, data) => {
      const e = els(slide);
      // grid: in by 0.18, dimmed once content arrives
      const gridIn = Math.min(p / 0.18, 1);
      const gridOut = p > 0.66 ? Math.max(1 - (p - 0.66) / 0.2, 0) : 1;
      if (e.grid) e.grid.style.opacity = String(0.6 * gridIn * gridOut);
      // wireframe: in 0.18→0.4, out 0.66→0.82
      const wireIn = Math.min(Math.max((p - 0.18) / 0.22, 0), 1);
      const wireOut = p > 0.66 ? Math.max(1 - (p - 0.66) / 0.16, 0) : 1;
      if (e.wire) e.wire.style.opacity = String(wireIn * wireOut);
      e.wireKids.forEach((k, i) => {
        const t = Math.min(Math.max((p - 0.2 - i * 0.02) / 0.16, 0), 1);
        k.style.opacity = String(t * wireOut);
        k.style.transform = `translateY(${(1 - t) * 10}px)`;
      });
      // real site: in from 0.66
      const spIn = Math.min(Math.max((p - 0.66) / 0.28, 0), 1);
      if (e.sp) { e.sp.style.opacity = String(spIn); e.sp.style.transform = `translateY(${(1 - spIn) * 14}px)`; }
      // chrome + foot
      let label = PHASES[0].label;
      for (const ph of PHASES) if (p >= ph.at) label = ph.label;
      if (urlEl) urlEl.textContent = p >= 0.66 ? data.domain : "localhost:4321";
      if (pillText) pillText.textContent = p >= 1 ? "Live" : label;
      if (pill) pill.classList.toggle("is-live", p >= 1);
      if (labelEl) labelEl.textContent = p >= 1 ? data.name : "building…";
      if (fillEl) fillEl.style.width = (p * 100) + "%";
    };

    let current = -1;
    let raf = null;
    let holdTimer = null;
    let paused = false;
    let pausedAt = 0;

    const clearTimers = () => {
      if (raf) cancelAnimationFrame(raf);
      if (holdTimer) clearTimeout(holdTimer);
      raf = holdTimer = null;
    };

    const activate = (n) => {
      slides.forEach((s, i) => {
        const active = i === n;
        s.classList.toggle("is-active", active);
        s.setAttribute("aria-hidden", active ? "false" : "true");
        s.setAttribute("tabindex", active ? "0" : "-1");
      });
      dots.forEach((d, i) => d.setAttribute("aria-selected", i === n ? "true" : "false"));
      if (indexEl) indexEl.textContent = `${pad(n + 1)} / ${pad(total)}`;
      current = n;
    };

    const advance = () => build((current + 1) % total);

    function build(n) {
      clearTimers();
      const slide = slides[n];
      const data = slide.dataset;
      activate(n);
      reset(slide);

      if (reduce) { render(slide, 1, data); return; } // no motion: straight to live

      const start = performance.now();
      const step = (ts) => {
        if (paused) { raf = requestAnimationFrame(step); return; }
        const p = Math.min((ts - start) / BUILD, 1);
        render(slide, p, data);
        if (p < 1) raf = requestAnimationFrame(step);
        else if (total > 1) holdTimer = setTimeout(advance, HOLD); // cycle to next site
      };
      // small beat on the blank canvas before building
      raf = requestAnimationFrame(() => { raf = requestAnimationFrame(step); });
    }

    // Dots jump to (and rebuild) a site.
    dots.forEach((d) => d.addEventListener("click", () => build(parseInt(d.dataset.idx, 10) || 0)));

    // Pause while hovered/focused so people can read.
    root.addEventListener("mouseenter", () => { paused = true; });
    root.addEventListener("mouseleave", () => { paused = false; });
    root.addEventListener("focusin", () => { paused = true; });
    root.addEventListener("focusout", () => { paused = false; });

    // Kick off when the panel scrolls into view.
    fit();
    const start = () => build(0);
    if ("IntersectionObserver" in window && !reduce) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { io.disconnect(); start(); } });
      }, { threshold: 0.2 });
      io.observe(root);
    } else {
      start();
    }
  })();
</script>
