---
const year = new Date().getFullYear();

const studioLinks = [
  { href: "/about", label: "About" },
  { href: "/team",  label: "Team" },
  { href: "/work",  label: "Work" },
];
const serviceLinks = [
  { href: "/services", label: "Landing — $800" },
  { href: "/services", label: "Full Site — $1,800" },
  { href: "/contact",  label: "Custom inquiry" },
];
---

<footer class="footer-dark">
  <div class="container-page footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo-link" aria-label="fwd. home">
          <span class="footer-mark">fwd<span class="footer-mark-dot">.</span></span>
        </a>
        <p class="footer-tagline">A small web design studio building clean, considered sites for practices and small businesses.</p>
      </div>

      <div class="footer-col">
        <h5 class="footer-label">Studio</h5>
        <ul>
          {studioLinks.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
        </ul>
      </div>

      <div class="footer-col">
        <h5 class="footer-label">Services</h5>
        <ul>
          {serviceLinks.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
        </ul>
      </div>

      <div class="footer-col">
        <h5 class="footer-label">Contact</h5>
        <ul>
          <li><a href="mailto:hello@fwd.studio">hello@fwd.studio</a></li>
          <li><span class="footer-static">Irvine, CA</span></li>
          <li><a href="/contact">Start a project</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {year} Forward Design Consulting LLC · All rights reserved</span>
      <span class="footer-builtby">Designed &amp; built in-house.</span>
    </div>
  </div>
</footer>

<style>
  .footer-dark {
    margin-top: 6rem;
    background: var(--color-ink, #071722);
    color: rgba(255,255,255,0.78);
    padding: 5rem 0 1.75rem;
    position: relative;
  }
  .footer-dark::before {
    content: "";
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: rgba(255,255,255,0.08);
  }
  .footer-inner { width: 100%; padding-inline: var(--pad-x, clamp(1.5rem, 3.5vw, 3.5rem)); }
  .footer-grid {
    display: grid; gap: 2.5rem;
    grid-template-columns: 1fr;
    margin-bottom: 4rem;
  }
  @media (min-width: 800px) {
    .footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; }
  }

  .footer-brand { display: flex; flex-direction: column; gap: 1.25rem; max-width: 32ch; }
  .footer-logo-link { display: inline-flex; }
  .footer-mark {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 350;
    font-size: clamp(2.6rem, 4vw, 3.5rem);
    line-height: 1;
    color: #fff;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 144, "SOFT" 80;
  }
  .footer-mark-dot { color: var(--color-periwinkle, #8e94b8); font-style: normal; }
  .footer-tagline {
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: var(--text-step-0);
    color: rgba(255,255,255,0.6);
    line-height: 1.5;
    margin: 0;
  }

  .footer-label {
    font-family: var(--font-mono);
    font-size: var(--text-step--2);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    font-weight: 500;
    margin: 0 0 1.25rem;
  }
  .footer-col ul {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.7rem;
  }
  .footer-col a, .footer-static {
    font-family: var(--font-sans);
    font-size: var(--text-step--1);
    color: rgba(255,255,255,0.78);
    transition: color 200ms cubic-bezier(0.2,0.7,0.2,1);
  }
  .footer-col a:hover { color: var(--color-periwinkle, #8e94b8); }

  .footer-bottom {
    display: flex; flex-wrap: wrap; justify-content: space-between;
    align-items: center; gap: 1rem;
    padding-top: 1.75rem;
    border-top: 1px solid rgba(255,255,255,0.10);
    font-family: var(--font-mono);
    font-size: var(--text-step--2);
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.5);
  }
  .footer-builtby {
    font-family: var(--font-display);
    font-style: italic;
    letter-spacing: 0;
    color: rgba(255,255,255,0.6);
    font-size: var(--text-step--1);
    font-variation-settings: "opsz" 60, "SOFT" 100;
  }
</style>
