---
import BrandMark from "./BrandMark.astro";

// Studio links land on real /studio sections — no redirect hops via /about or /team.
const studioLinks = [
  { href: "/studio#values", label: "What we believe" },
  { href: "/studio#people", label: "The team" },
  { href: "/work",          label: "Selected work" },
];
const serviceLinks = [
  { href: "/services", label: "Landing — $800" },
  { href: "/services", label: "Full Site — $1,800" },
  { href: "/contact",  label: "Custom inquiry" },
];
---

<!--
  Slim footer (round-3 feedback): no tagline, no copyright/version row.
  The brand mark grows to fill the brand column. BrandMark resolves
  to `currentColor` so it reads white-on-ink here.
-->
<footer class="footer-dark footer-slim">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo-link" aria-label="fwd. — home">
          <BrandMark class="footer-mark" decorative={true} />
        </a>
      </div>

      <div class="footer-col">
        <h5 class="footer-label">Studio</h5>
        <ul>
          {studioLinks.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
        </ul>
      </div>

      <div class="footer-col">
        <h5 class="footer-label">Services</h5>
        <ul>
          {serviceLinks.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
        </ul>
      </div>

      <div class="footer-col">
        <h5 class="footer-label">Contact</h5>
        <ul>
          <li><a href="mailto:hello@fwd.studio">hello@fwd.studio</a></li>
          <li><span class="footer-static">Irvine, CA</span></li>
          <li><a href="/contact">Start a project</a></li>
        </ul>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-dark {
    background: var(--color-ink, #071722);
    color: rgba(255,255,255,0.78);
    padding: 4rem 0 3rem;
    position: relative;
  }
  .footer-dark::before {
    content: "";
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: rgba(255,255,255,0.08);
  }
  /* G-04 — full bleed, padding via --pad-x only */
  .footer-inner {
    width: 100%;
    padding-inline: var(--pad-x, clamp(1.5rem, 3.5vw, 3.5rem));
  }
  .footer-grid {
    display: grid; gap: 2.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 800px) {
    .footer-grid { grid-template-columns: 1.4fr 1fr 1fr 1fr; gap: clamp(2rem, 4vw, 4rem); align-items: center; }
  }

  .footer-brand {
    display: flex;
    justify-content: center;
  }
  .footer-logo-link {
    display: inline-flex;
    color: var(--color-paper);
    transition: opacity 200ms var(--ease-soft);
    width: fit-content;
  }
  .footer-logo-link:hover { opacity: 0.78; }
  /* Mark grows to fill the freed column space */
  :global(.footer-mark) {
    height: clamp(120px, 14vw, 200px);
    width: auto;
    display: block;
  }

  .footer-label {
    font-family: var(--font-mono);
    font-size: var(--text-step--2);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    font-weight: 500;
    margin: 0 0 1.25rem;
  }
  .footer-col ul {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.7rem;
  }
  .footer-col a, .footer-static {
    font-family: var(--font-sans);
    font-size: var(--text-step--1);
    color: rgba(255,255,255,0.78);
    transition: color 200ms var(--ease-soft);
  }
  .footer-col a:hover { color: var(--color-periwinkle, #8e94b8); }
  .footer-col a:focus-visible {
    outline: 2px solid var(--color-periwinkle, #8e94b8);
    outline-offset: 3px;
    border-radius: 2px;
  }
</style>
