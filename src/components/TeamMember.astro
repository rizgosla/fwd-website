---
// Each member supplies their own portrait SVG via the `portrait` prop.
// Use Astro's set:html to inject the SVG markup.
interface Props {
  name: string;
  role: string;
  bio: string;
  portrait: string; // raw SVG markup
}
const { name, role, bio, portrait } = Astro.props;
---

<div class="member flex flex-col gap-4">
  <div class="member-portrait aspect-[4/5] rounded-[10px] overflow-hidden relative border border-line bg-bg-soft transition-[transform,border-color] duration-[450ms] ease-[var(--ease-soft)]">
    <Fragment set:html={portrait} />
  </div>
  <h3 class="m-0 font-display font-normal text-[length:var(--text-step-2)] tracking-[-0.015em] leading-[1.1]"
      style="font-variation-settings: 'opsz' 144, 'SOFT' 30;">
    {name}
  </h3>
  <p class="m-0 font-mono text-[length:var(--text-step--2)] text-blue tracking-[0.12em] uppercase font-medium">{role}</p>
  <p class="m-0 mt-1 text-fg-soft text-[length:var(--text-step--1)] leading-[1.55]" style="text-wrap: pretty;">{bio}</p>
</div>

<style>
  .member:hover .member-portrait {
    transform: translateY(-3px);
    border-color: var(--color-line-strong);
  }
  .member-portrait :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
