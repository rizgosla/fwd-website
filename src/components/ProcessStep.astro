---
interface Props {
  glyph: string;       // e.g. "i.", "ii."
  step: string;        // e.g. "Step 01"
  title: string;
  body: string;
  meta: string;
  /**
   * Optional visual treatment. If provided, a small graphic renders in
   * the right column of the step. Otherwise the step is text-only.
   *   "call"      — animated calendar with booked slot
   *   "revisions" — redline mark-up
   *   "launch"    — DNS / live indicator
   */
  visual?: "call" | "revisions" | "launch";
}
const { glyph, step, title, body, meta, visual } = Astro.props;
---

<li class={`process-step ${visual ? "has-visual" : ""}`}>
  <span class="ps-step">
    <span class="ps-glyph">{glyph}</span>
    {step}
  </span>

  <div class="ps-text">
    <h3 class="ps-title">{title}</h3>
    <p class="ps-body">
      {body}
      <span class="ps-meta">— {meta}</span>
    </p>
  </div>

  {visual && (
    <div class="ps-visual" aria-hidden="true">
      <div class="ps-visual-frame">
        {visual === "call" && (
          <div class="ps-visual-call">
            <div class="ps-visual-call-h">
              <span class="month">May 2026</span>
              <span>15 min</span>
            </div>
            <div class="ps-visual-call-grid">
              {Array.from({ length: 35 }).map((_, i) => (
                i === 18 ? <span class="slot" /> :
                i === 19 ? <span class="picked" /> :
                i === 25 ? <span class="slot" /> :
                <span />
              ))}
            </div>
          </div>
        )}

        {visual === "revisions" && (
          <div class="ps-visual-revisions">
            <div class="ps-revision-line" style="width:90%" />
            <div class="ps-revision-line with-comment" style="width:75%" />
            <div class="ps-revision-line struck" />
            <div class="ps-revision-line" style="width:85%" />
            <div class="ps-revision-line with-comment" style="width:55%" />
            <div class="ps-revision-line" style="width:70%" />
            <div class="ps-revision-arrow">↵</div>
          </div>
        )}

        {visual === "launch" && (
          <div class="ps-visual-launch">
            <div class="ps-launch-url"><span class="lock" />https://smithdental.com</div>
            <div class="ps-launch-bars">
              <div class="ps-launch-bar" />
              <div class="ps-launch-bar" />
              <div class="ps-launch-bar" />
            </div>
            <div class="ps-launch-status">DNS · cert · live</div>
          </div>
        )}
      </div>
    </div>
  )}
</li>

<style>
  .process-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.5rem;
    padding-block: 2rem;
    border-bottom: 1px solid var(--color-line);
    align-items: start;
    transition: padding-left 450ms var(--ease-soft), background 450ms var(--ease-soft);
  }
  @media (min-width: 800px) {
    .process-step { grid-template-columns: 110px 1.2fr 2fr; gap: 3rem; align-items: center; }
    .process-step.has-visual { grid-template-columns: 110px 1.3fr 1.5fr 1.2fr; gap: clamp(1.5rem, 3vw, 3rem); }
  }
  .process-step:hover { padding-left: 0.75rem; }

  .ps-step {
    font-family: var(--font-mono);
    font-size: var(--text-step--2);
    color: var(--color-blue);
    letter-spacing: 0.1em;
    font-weight: 500;
    text-transform: uppercase;
    display: flex; flex-direction: column; gap: 0.25rem;
  }
  .ps-glyph {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-step-2);
    line-height: 1;
    color: var(--color-blue);
    font-variation-settings: "opsz" 144;
  }
  .ps-text { display: flex; flex-direction: column; gap: 0.5rem; }
  .ps-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-step-2);
    letter-spacing: -0.015em;
    line-height: 1.15;
    font-variation-settings: "opsz" 60;
    color: var(--color-fg);
  }
  .ps-body {
    margin: 0;
    max-width: 55ch;
    color: var(--color-fg-soft);
    font-size: var(--text-step-0);
    line-height: 1.55;
  }
  .ps-meta {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-step--2);
    color: var(--color-fg-muted);
    letter-spacing: 0.05em;
    margin-top: 1rem;
  }

  .ps-visual {
    display: none;
  }
  @media (min-width: 800px) {
    .ps-visual { display: flex; align-items: center; justify-content: flex-end; }
  }
  .ps-visual-frame {
    position: relative;
    width: 100%; max-width: 260px;
    aspect-ratio: 4/3;
    background: var(--color-bg-soft);
    border-radius: 10px;
    border: 1px solid var(--color-line);
    overflow: hidden;
    transition: transform 320ms var(--ease-soft), border-color 320ms var(--ease-soft);
  }
  .process-step:hover .ps-visual-frame { transform: translateY(-3px); border-color: var(--color-line-strong); }
  .ps-visual-frame::before {
    content: ""; position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(13,47,69,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(13,47,69,0.06) 1px, transparent 1px);
    background-size: 18px 18px;
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 30%, transparent 85%);
    mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 30%, transparent 85%);
  }

  /* Call visual — calendar */
  .ps-visual-call {
    position: absolute; inset: 18px;
    display: grid; grid-template-rows: auto 1fr; gap: 6px; z-index: 1;
  }
  .ps-visual-call-h {
    display: flex; justify-content: space-between; align-items: center;
    font-family: var(--font-mono); font-size: 9px;
    color: var(--color-fg-muted); letter-spacing: 0.1em; text-transform: uppercase;
  }
  .ps-visual-call-h .month { color: var(--color-blue); font-weight: 500; }
  .ps-visual-call-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 3px; }
  .ps-visual-call-grid span { background: rgba(13,47,69,0.10); border-radius: 2px; }
  .ps-visual-call-grid .slot { background: var(--color-blue); position: relative; }
  .ps-visual-call-grid .slot::after {
    content: ""; position: absolute; inset: 0;
    border-radius: 2px; background: var(--color-periwinkle);
    animation: mvPulseRing 2.2s var(--ease-soft) infinite;
  }
  .ps-visual-call-grid .picked {
    background: var(--color-periwinkle);
    border: 1px solid var(--color-navy);
  }

  /* Revisions visual */
  .ps-visual-revisions {
    position: absolute; inset: 18px;
    display: flex; flex-direction: column; gap: 8px; z-index: 1; padding: 4px;
  }
  .ps-revision-line {
    position: relative; height: 6px;
    border-radius: 3px; background: rgba(13,47,69,0.18);
  }
  .ps-revision-line.with-comment::after {
    content: ""; position: absolute;
    right: -10px; top: 50%; transform: translateY(-50%);
    width: 14px; height: 14px;
    background: var(--color-periwinkle);
    border: 2px solid var(--color-paper);
    border-radius: 50%;
    box-shadow: 0 4px 10px -2px rgba(7,23,34,0.25);
    animation: mvPulseRing 2.4s var(--ease-soft) infinite;
  }
  .ps-revision-line.struck {
    background: transparent;
    border-top: 1px solid #c2786a;
    height: 0; margin-block: 6px;
    width: 70%;
  }
  .ps-revision-arrow {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-display); font-style: italic;
    color: var(--color-blue);
    font-size: 28px;
    font-variation-settings: "opsz" 96;
    z-index: 2; pointer-events: none;
    opacity: 0;
    animation: mvRevisionPulse 4s ease-in-out infinite;
  }
  @keyframes mvRevisionPulse {
    0%, 40% { opacity: 0; transform: translate(-50%, -50%) scale(0.9); }
    50%, 70% { opacity: 0.8; transform: translate(-50%, -50%) scale(1.05); }
    90%, 100% { opacity: 0; transform: translate(-50%, -50%) scale(0.9); }
  }

  /* Launch visual */
  .ps-visual-launch {
    position: absolute; inset: 18px;
    display: flex; flex-direction: column; justify-content: center;
    gap: 10px; z-index: 1;
  }
  .ps-launch-url {
    display: flex; align-items: center; gap: 8px;
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: 6px;
    padding: 6px 10px;
    font-family: var(--font-mono); font-size: 10px;
    color: var(--color-blue);
    letter-spacing: 0.04em;
    box-shadow: 0 4px 12px -4px rgba(7,23,34,0.10);
  }
  .ps-launch-url .lock {
    width: 6px; height: 6px; border-radius: 50%;
    background: #2bb673;
    box-shadow: 0 0 0 3px rgba(43,182,115,0.2);
    animation: mvPulseRing 2s var(--ease-soft) infinite;
  }
  .ps-launch-status {
    display: flex; align-items: center; gap: 6px;
    font-family: var(--font-mono); font-size: 9px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--color-fg-muted);
  }
  .ps-launch-status::before {
    content: ""; width: 5px; height: 5px; border-radius: 50%;
    background: var(--color-periwinkle);
    animation: mvBlink 1s steps(1) infinite;
  }
  .ps-launch-bars { display: flex; flex-direction: column; gap: 3px; }
  .ps-launch-bar {
    height: 4px; border-radius: 2px;
    background: rgba(13,47,69,0.10);
    position: relative; overflow: hidden;
  }
  .ps-launch-bar::after {
    content: ""; position: absolute; inset: 0;
    background: var(--color-blue);
    transform-origin: left;
    animation: mvLaunchFill 3s ease-out infinite;
  }
  .ps-launch-bar:nth-child(1)::after { animation-delay: 0s; }
  .ps-launch-bar:nth-child(2)::after { animation-delay: 0.4s; background: var(--color-periwinkle); }
  .ps-launch-bar:nth-child(3)::after { animation-delay: 0.8s; }
  @keyframes mvLaunchFill { 0% { transform: scaleX(0); } 40%, 100% { transform: scaleX(1); } }
  @keyframes mvBlink { 0%, 49% { opacity: 1; } 50%, 100% { opacity: 0; } }
</style>
