---
import BrandMark from "./BrandMark.astro";

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const links: { href: string; label: string }[] = [
  { href: "/",        label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/work",    label: "Work" },
  { href: "/team",    label: "Team" },
  { href: "/about",   label: "About" },
];

const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname === href || pathname.startsWith(href + "/");
---

<header
  id="nav"
  class="sticky top-0 z-50 backdrop-blur-xl backdrop-saturate-150 border-b border-transparent
         bg-paper/80 transition-[border-color,background] duration-[450ms] ease-[var(--ease-soft)]"
>
  <div class="container-page flex items-center justify-between gap-6 py-1 relative">
    <a href="/" class="inline-flex items-center gap-2 text-ink hover:opacity-70 transition-opacity duration-200" aria-label="fwd. — home">
      <BrandMark class="h-[78px] w-[140px] text-ink" />
    </a>

    <nav id="navLinks" class="nav-links flex items-center gap-[clamp(1rem,2.5vw,2.25rem)]" aria-label="Primary">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "nav-link relative pb-1 px-0.5 text-[length:var(--text-step--1)] font-medium tracking-[0.01em]",
            "text-fg-soft hover:text-fg transition-colors duration-200",
            isActive(link.href) && "text-fg is-active",
          ]}
        >
          {link.label}
        </a>
      ))}

      <a
        href="/contact"
        class:list={[
          "inline-flex items-center gap-1.5 rounded-full border px-[1.15rem] py-[0.6rem] text-[length:var(--text-step--1)] font-medium",
          "bg-ink border-ink text-paper hover:bg-blue hover:border-blue transition-all duration-200",
          "[&_.arrow]:transition-transform [&_.arrow]:duration-200 hover:[&_.arrow]:translate-x-[3px]",
          isActive("/contact") && "bg-blue border-blue",
        ]}
      >
        Start a project <span class="arrow">→</span>
      </a>
    </nav>

    <button
      id="navToggle"
      class="nav-toggle hidden h-10 w-10 items-center justify-center rounded-lg"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <span class="block h-[1.5px] w-[18px] bg-fg relative
                   before:content-[''] before:absolute before:left-0 before:-top-[6px] before:w-[18px] before:h-[1.5px] before:bg-fg
                   after:content-[''] after:absolute after:left-0 after:top-[6px] after:w-[18px] after:h-[1.5px] after:bg-fg"></span>
    </button>
  </div>
</header>

<style>
  /* Underline indicator on nav links */
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: -2px;
    height: 1px;
    background: var(--color-blue);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 450ms var(--ease-out-expo);
  }
  .nav-link:hover::after,
  .nav-link.is-active::after { transform: scaleX(1); }

  /* Scrolled state — toggled by client script */
  :global(#nav.is-scrolled) {
    border-bottom-color: var(--color-hairline);
    background: color-mix(in oklab, var(--color-paper) 92%, transparent);
  }

  /* Mobile menu */
  @media (max-width: 820px) {
    .nav-links { display: none; }
    .nav-toggle { display: inline-flex; }
    :global(#navLinks.is-open) {
      display: flex;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--color-paper);
      padding: 1rem clamp(1.25rem, 4vw, 3rem);
      border-bottom: 1px solid var(--color-hairline);
    }
    :global(#navLinks.is-open .nav-link) {
      width: 100%;
      padding-block: 0.9rem;
      border-bottom: 1px solid var(--color-hairline);
    }
    :global(#navLinks.is-open) > a:last-child {
      margin-top: 1rem;
      align-self: stretch;
      text-align: center;
      justify-content: center;
    }
  }
</style>
