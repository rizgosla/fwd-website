---
interface Props {
  title: string;
  meta: string;
  href?: string;
  thumb: string; // raw SVG markup
}
const { title, meta, href = "#", thumb } = Astro.props;
---

<a
  href={href}
  class="work-item grid rounded-[10px] overflow-hidden border border-line bg-paper
         transition-[transform,border-color,box-shadow] duration-[450ms] ease-[var(--ease-soft)]
         hover:-translate-y-[3px] hover:border-line-strong hover:shadow-[0_24px_50px_-32px_rgb(7_23_34_/0.25)]"
>
  <div class="work-thumb aspect-[16/11] relative overflow-hidden bg-gradient-to-br from-blue to-navy">
    <Fragment set:html={thumb} />
  </div>
  <div class="flex justify-between items-baseline p-6 gap-4">
    <h4 class="m-0 font-display font-normal text-[length:var(--text-step-2)] tracking-[-0.01em]"
        style="font-variation-settings: 'opsz' 60, 'SOFT' 30;">{title}</h4>
    <span class="text-[length:var(--text-step--2)] text-fg-muted tracking-[0.1em] uppercase font-mono">{meta}</span>
  </div>
</a>

<style>
  .work-thumb :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
