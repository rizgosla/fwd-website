---
interface Props {
  title: string;   // accepts <em> markup
  body: string;
  ctaHref?: string;
  ctaLabel?: string;
}
const { title, body, ctaHref = "/contact", ctaLabel = "Start a project" } = Astro.props;
---

<!--
  Round-3 feedback: no rounded corners, no narrow card. Full-bleed band
  with an animated giant "fwd" repeating in the background. Sized so the
  band feels like it's part of the page, not an island on it.
-->
<section class="cta-band">
  <div class="cta-band-bg" aria-hidden="true">
    <div class="cta-band-bg-track">
      <span>fwd</span><span>fwd</span><span>fwd</span><span>fwd</span><span>fwd</span><span>fwd</span>
      <span>fwd</span><span>fwd</span><span>fwd</span><span>fwd</span><span>fwd</span><span>fwd</span>
    </div>
  </div>

  <div class="cta-band-inner">
    <h3 class="display" set:html={title}></h3>
    <div>
      <p>{body}</p>
      <a href={ctaHref} class="btn btn-primary">
        {ctaLabel} <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .cta-band {
    position: relative;
    background: var(--color-ink);
    color: var(--color-paper);
    padding-block: clamp(4rem, 9vh, 6rem);
    overflow: hidden;
    isolation: isolate;
  }
  .cta-band::before {
    content: "";
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 0%, rgb(142 148 184 / 0.18), transparent 70%),
      radial-gradient(ellipse 60% 60% at 80% 100%, rgb(20 70 103 / 0.55), transparent 70%);
    pointer-events: none; z-index: 0;
  }

  /* Animated repeating fwd mark — slow horizontal drift */
  .cta-band-bg {
    position: absolute; inset: 0;
    display: flex; align-items: center;
    pointer-events: none; z-index: 0;
    overflow: hidden;
  }
  .cta-band-bg-track {
    display: flex; gap: 0.4em;
    width: max-content;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 350;
    font-size: clamp(11rem, 22vw, 22rem);
    letter-spacing: -0.06em;
    line-height: 0.85;
    color: rgba(255,255,255,0.04);
    text-transform: lowercase;
    animation: mvFwdScroll 28s linear infinite;
    font-variation-settings: "opsz" 144;
    white-space: nowrap;
    user-select: none;
  }
  .cta-band-bg-track span { padding-right: 0.5em; }
  .cta-band-bg-track span::after { content: "."; color: rgba(142,148,184,0.18); }
  @keyframes mvFwdScroll { to { transform: translateX(-50%); } }

  .cta-band-inner {
    position: relative; z-index: 2;
    width: 100%;
    padding-inline: var(--pad-x, clamp(1.5rem, 3.5vw, 3.5rem));
    display: grid; gap: 2rem; align-items: end;
    grid-template-columns: 1fr;
  }
  @media (min-width: 900px) {
    .cta-band-inner { grid-template-columns: 1.6fr 1fr; gap: 3rem; }
  }

  .cta-band h3 {
    font-family: var(--font-display);
    font-weight: 350;
    font-size: var(--text-step-5);
    letter-spacing: -0.025em;
    margin: 0;
    font-variation-settings: "opsz" 144;
    line-height: 1;
    text-wrap: balance;
    max-width: 18ch;
  }
  .cta-band h3 :global(em) {
    font-style: italic;
    color: var(--color-periwinkle);
    font-variation-settings: "opsz" 144;
  }
  .cta-band p {
    color: rgb(255 255 255 / 0.7);
    margin: 0 0 1.5rem;
    max-width: 36ch;
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: var(--text-step-1);
    font-variation-settings: "opsz" 60;
    line-height: 1.4;
  }
  /* Invert button against the ink panel */
  .cta-band :global(.btn-primary) {
    background: var(--color-paper);
    color: var(--color-navy);
    border-color: var(--color-paper);
  }
  .cta-band :global(.btn-primary:hover) {
    background: var(--color-periwinkle);
    border-color: var(--color-periwinkle);
    color: var(--color-navy);
  }
</style>
