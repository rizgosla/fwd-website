---
interface Props {
  variant?: "light" | "dark";
  deliverable: string;
  title: string;
  price: string;
  priceNote: string;
  features: string[];
  ctaLabel: string;
}
const { variant = "light", deliverable, title, price, priceNote, features, ctaLabel } = Astro.props;
---

<article class={`tier tier-${variant}`} data-tilt>
  <span class="tier-sheen" aria-hidden="true"></span>
  <div class="tier-top">
    <span class="tier-deliv">{deliverable}</span>
  </div>
  <h3 class="tier-title">{title}</h3>
  <div class="tier-price">
    <span class="dollar">$</span>
    <span class="amount">{price}</span>
    <span class="note">{priceNote}</span>
  </div>
  <ul class="tier-features">
    {features.map((f) => (<li><span class="check">✓</span>{f}</li>))}
  </ul>
  <a href="/contact" class="tier-cta">{ctaLabel} <span class="arrow">→</span></a>
</article>

<style>
  .tier {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    --bg: #fff;
    --sheen: rgb(13 47 69 / 0.10);
    --fg: var(--color-navy);
    --fg-soft: var(--color-fg-soft);
    --fg-muted: var(--color-fg-muted);
    --line: var(--color-line);
    --accent: var(--color-blue);
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: clamp(2rem, 3.5vw, 3rem);
    display: flex; flex-direction: column;
    gap: 1.5rem;
    transition: background 360ms cubic-bezier(0.2,0.7,0.2,1),
                color 360ms cubic-bezier(0.2,0.7,0.2,1),
                border-color 360ms cubic-bezier(0.2,0.7,0.2,1),
                transform 360ms cubic-bezier(0.2,0.7,0.2,1),
                box-shadow 360ms cubic-bezier(0.2,0.7,0.2,1);
    min-height: 560px;
  }
  .tier-dark {
    --bg: var(--color-navy);
    --fg: #ffffff;
    --fg-soft: rgba(255,255,255,0.82);
    --fg-muted: rgba(255,255,255,0.55);
    --line: rgba(255,255,255,0.14);
    --accent: var(--color-periwinkle);
    --sheen: rgb(255 255 255 / 0.14);
  }
  /* Hover: gentle lift only — colors stay put, halo does the talking */
  .tier:hover {
    transform: translateY(-2px);
    box-shadow: 0 30px 60px -28px rgb(7 23 34 / 0.25);
  }

  /* Cursor-following radial sheen (driven by --mx/--my from BaseLayout) */
  .tier-sheen {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 360ms cubic-bezier(0.2,0.7,0.2,1),
                background 360ms cubic-bezier(0.2,0.7,0.2,1);
    background: radial-gradient(
      220px circle at var(--mx, 50%) var(--my, 50%),
      var(--sheen),
      transparent 60%
    );
  }
  .tier:hover .tier-sheen { opacity: 1; }
  .tier > :not(.tier-sheen) { position: relative; z-index: 1; }

  .tier-top { display: flex; align-items: center; justify-content: flex-end; }
  .tier-deliv {
    font-family: var(--font-mono);
    font-size: var(--text-step--2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }
  .tier-title {
    font-family: var(--font-display);
    font-weight: 350;
    font-size: clamp(2.4rem, 3.6vw, 3.6rem);
    line-height: 0.98;
    letter-spacing: -0.025em;
    color: var(--fg);
    margin: 0;
    font-variation-settings: "opsz" 144, "SOFT" 30;
  }
  .tier-price {
    display: flex; align-items: baseline; flex-wrap: wrap; gap: 0.6rem;
    padding-block: 1.2rem;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .tier-price .dollar {
    font-family: var(--font-display);
    font-size: 1.8rem; color: var(--fg-muted);
    font-variation-settings: "opsz" 60, "SOFT" 30;
  }
  .tier-price .amount {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(3rem, 5vw, 4.4rem);
    letter-spacing: -0.03em;
    color: var(--fg);
    line-height: 1;
    font-variation-settings: "opsz" 144, "SOFT" 30;
  }
  .tier-price .note {
    font-family: var(--font-mono);
    font-size: var(--text-step--2);
    color: var(--fg-muted);
    letter-spacing: 0.04em;
    margin-left: auto;
  }
  .tier-features {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.85rem;
    flex: 1;
  }
  .tier-features li {
    display: flex; gap: 0.75rem;
    color: var(--fg-soft);
    font-size: var(--text-step-0);
    line-height: 1.45;
  }
  .tier-features .check {
    color: var(--accent);
    font-weight: 600;
    flex-shrink: 0;
  }
  .tier-cta {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    align-self: stretch;
    padding: 1rem 1.5rem;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: var(--text-step--1);
    font-weight: 500;
    letter-spacing: 0.01em;
    border: 1px solid var(--fg);
    background: transparent;
    color: var(--fg);
    transition: background 280ms cubic-bezier(0.2,0.7,0.2,1),
                color 280ms cubic-bezier(0.2,0.7,0.2,1);
  }
  .tier-cta:hover {
    background: var(--fg);
    color: var(--bg);
  }
  .tier-cta .arrow { transition: transform 320ms cubic-bezier(0.2,0.7,0.2,1); }
  .tier-cta:hover .arrow { transform: translateX(4px); }
</style>
