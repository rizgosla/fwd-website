---
/* ----------------------------------------------------------------------------
   SitePreview — renders ONE shipped site as a faithful mini-hero.

   Sized in FIXED pixels against a 1000×620 design canvas (.sc-stage). The
   parent (HeroShowcase) scales that whole canvas to fit the browser frame with
   a single transform, so proportions are locked at every window size — it
   reads like a real, shrunk-down webpage rather than reflowing type.

   Two layouts:
     • overlay → a full top-of-page render: dark nav (+ optional marquee ribbon)
                 over a full-bleed photo hero. This mirrors restaurants / visual
                 brands like Burnt Crumbs almost exactly — same nav, same
                 marquee, same Oswald/Lora type, same #ScratchMade serif line.
     • split   → editorial text + an optional signature widget (services)
   All colour + type comes in as inline CSS vars so each card carries its own
   palette and fonts — the preview reads like the real, live site.
   -------------------------------------------------------------------------- */
import type { ShowcaseSite } from "../../data/showcase";

interface Props {
  site: ShowcaseSite;
}
const { site } = Astro.props;

const vars = [
  `--sp-bg:${site.bg}`,
  `--sp-fg:${site.fg}`,
  `--sp-muted:${site.muted}`,
  `--sp-accent:${site.accent}`,
  `--sp-on-accent:${site.onAccent ?? "#fff"}`,
  `--sp-display:${site.displayFont ?? 'var(--font-display)'}`,
  `--sp-serif:${site.serifFont ?? 'var(--font-display)'}`,
].join(";");

const emClass = `sp-em-${site.emStyle ?? "caps"}`;
const navLinks = site.navLinks ?? [];
---

<div class={`sp sp-${site.layout} sp-display-${site.display} ${emClass}`} style={vars}>
  {site.layout === "overlay" ? (
    <>
      {/* dark nav — logo + real links + order pill, just like the live site */}
      <div class="sp-bar">
        {site.logo
          ? <img class="sp-logo" src={site.logo} alt={site.name} loading="lazy" />
          : <span class="sp-logo-text">{site.name}</span>}
        {navLinks.length > 0 ? (
          <nav class="sp-bar-nav" aria-hidden="true">
            {navLinks.map((l) => <span>{l}</span>)}
          </nav>
        ) : (
          <span class="sp-nav-links" aria-hidden="true"><span></span><span></span><span></span></span>
        )}
        <span class="sp-bar-cta">Order</span>
      </div>

      {/* tagline ribbon */}
      {site.marquee && site.marquee.length > 0 && (
        <div class="sp-marquee" aria-hidden="true">
          <div class="sp-marquee-track">
            {[0, 1].map(() => (
              <div class="sp-marquee-row">
                {site.marquee!.concat(site.marquee!).map((t) => (
                  <span class="sp-marquee-item">{t}<span class="sp-marquee-dot"></span></span>
                ))}
              </div>
            ))}
          </div>
        </div>
      )}

      {/* photo hero */}
      <div class="sp-hero">
        {site.image && (
          <img class="sp-photo" src={site.image} alt="" loading="lazy" decoding="async" />
        )}
        <div class="sp-scrim" aria-hidden="true"></div>
        <div class="sp-hero-copy">
          <span class="sp-eyebrow"><span class="sp-dot" aria-hidden="true"></span>{site.eyebrow}</span>
          <h3 class="sp-headline" set:html={site.headline}></h3>
          <p class="sp-sub">{site.sub}</p>
          <span class="sp-cta">{site.cta}<span class="sp-arrow" aria-hidden="true">→</span></span>
        </div>
      </div>
    </>
  ) : (
    <>
      <div class="sp-scrim" aria-hidden="true"></div>

      {/* faux nav */}
      <div class="sp-nav">
        {site.logo
          ? <img class="sp-logo" src={site.logo} alt={site.name} loading="lazy" />
          : <span class="sp-logo-text">{site.name}</span>}
        <span class="sp-nav-links" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
        <span class="sp-nav-cta">{site.cta}</span>
      </div>

      <div class="sp-body">
        <div class="sp-copy">
          <span class="sp-eyebrow"><span class="sp-dot" aria-hidden="true"></span>{site.eyebrow}</span>
          <h3 class="sp-headline" set:html={site.headline}></h3>
          <p class="sp-sub">{site.sub}</p>
          <span class="sp-cta">{site.cta}<span class="sp-arrow" aria-hidden="true">→</span></span>
        </div>

        <div class="sp-side" aria-hidden="true">
          {site.widget ? (
            <div class="sp-widget">
              <span class="sp-widget-label">{site.widget.label}</span>
              <ul class="sp-widget-rows">
                {site.widget.rows.map((r) => (
                  <li><span>{r.k}</span><strong>{r.v}</strong></li>
                ))}
              </ul>
              {site.widget.note && <span class="sp-widget-note">{site.widget.note}</span>}
            </div>
          ) : (
            <div class="sp-imgblock"></div>
          )}
        </div>
      </div>
    </>
  )}
</div>

<style>
  /* Everything below is in px against the fixed 1000×620 .sc-stage. */
  .sp {
    position: absolute;
    inset: 0;
    background: var(--sp-bg);
    color: var(--sp-fg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* ============================================================
     OVERLAY — full top-of-page render (Burnt Crumbs et al.)
     ============================================================ */

  /* ---- dark nav bar ---- */
  .sp-bar {
    position: relative;
    z-index: 3;
    flex: none;
    display: flex;
    align-items: center;
    gap: 36px;
    padding: 22px 56px;
    background: var(--sp-bg);
    border-bottom: 1px solid color-mix(in srgb, var(--sp-fg) 10%, transparent);
  }
  .sp-bar .sp-logo { height: 44px; width: auto; }
  .sp-bar-nav {
    display: flex;
    align-items: center;
    gap: 32px;
    margin-left: 12px;
  }
  .sp-bar-nav span {
    font-family: var(--sp-display);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sp-muted);
  }
  .sp-bar-cta {
    margin-left: auto;
    font-family: var(--sp-display);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sp-on-accent);
    background: var(--sp-accent);
    padding: 12px 22px;
    border-radius: 999px;
    box-shadow: 0 4px 16px color-mix(in srgb, var(--sp-accent) 45%, transparent),
      inset 0 1px 0 rgba(255,255,255,0.18);
  }

  /* ---- tagline ribbon ---- */
  .sp-marquee {
    position: relative;
    z-index: 3;
    flex: none;
    overflow: hidden;
    background: var(--sp-bg);
    border-bottom: 1px solid color-mix(in srgb, var(--sp-fg) 10%, transparent);
    padding: 9px 0;
  }
  .sp-marquee-track {
    display: flex;
    width: max-content;
    animation: spMarquee 22s linear infinite;
  }
  .sp-marquee-row { display: flex; flex: none; gap: 28px; padding-right: 28px; }
  .sp-marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-family: var(--sp-display);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sp-muted);
    white-space: nowrap;
  }
  .sp-marquee-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--sp-accent); }
  @keyframes spMarquee { to { transform: translateX(-50%); } }

  /* ---- photo hero ---- */
  .sp-hero {
    position: relative;
    flex: 1;
    overflow: hidden;
  }
  .sp-hero .sp-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 60%;
    transform: scale(1.05);
  }
  /* Left-to-right scrim so the copy stays legible — matches the live site. */
  .sp-hero .sp-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg,
      color-mix(in srgb, var(--sp-bg) 85%, transparent) 0%,
      color-mix(in srgb, var(--sp-bg) 45%, transparent) 45%,
      transparent 75%);
  }
  .sp-hero-copy {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 22px;
    max-width: 600px;
    padding: 0 56px;
  }

  /* ============================================================
     SPLIT — editorial text + side widget (services)
     ============================================================ */
  .sp-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 58%;
  }
  .sp-split .sp-scrim { display: none; }

  .sp-nav {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 28px;
    padding: 40px 56px 0;
  }
  .sp-logo { height: 48px; width: auto; }
  .sp-logo-text {
    font-family: var(--sp-display);
    font-weight: 500;
    font-size: 30px;
    letter-spacing: -0.01em;
    color: var(--sp-fg);
  }
  .sp-nav-links { display: flex; gap: 24px; margin-left: auto; }
  .sp-nav-links span {
    width: 64px; height: 12px; border-radius: 3px;
    background: color-mix(in srgb, var(--sp-fg) 32%, transparent);
  }
  .sp-nav-cta {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sp-on-accent);
    background: var(--sp-accent);
    padding: 14px 26px;
    border-radius: 999px;
  }
  .sp-split .sp-nav-cta { margin-left: auto; box-shadow: 0 14px 30px -12px color-mix(in srgb, var(--sp-accent) 60%, transparent); }

  .sp-body {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    align-items: center;
    gap: 40px;
    padding: 24px 56px 56px;
  }
  .sp-copy { max-width: 660px; display: flex; flex-direction: column; gap: 22px; }
  .sp-display-caps .sp-copy { max-width: 880px; }
  .sp-split .sp-copy { max-width: 520px; }

  /* ============================================================
     SHARED COPY — eyebrow / headline / sub / cta
     ============================================================ */
  .sp-eyebrow {
    display: inline-flex; align-items: center; gap: 14px;
    font-family: var(--sp-display);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sp-muted);
  }
  .sp-dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--sp-accent);
    flex: none;
    box-shadow: 0 0 12px color-mix(in srgb, var(--sp-accent) 90%, transparent);
  }

  .sp-headline {
    margin: 0;
    line-height: 0.9;
    color: var(--sp-fg);
    overflow-wrap: break-word;
  }
  .sp-display-caps .sp-headline {
    font-family: var(--sp-display);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 92px;
    letter-spacing: -0.01em;
    white-space: nowrap; /* keep each line (incl. #ScratchMade) unbroken */
  }
  .sp-display-serif .sp-headline {
    font-family: var(--sp-serif);
    font-weight: 350;
    font-size: 68px;
    letter-spacing: -0.02em;
    line-height: 0.98;
    font-variation-settings: "opsz" 144;
  }
  .sp-headline :global(em) {
    font-style: italic;
    color: var(--sp-accent);
  }
  /* Default caps em: same condensed face, just italic + accent. */
  .sp-em-caps.sp-display-caps .sp-headline :global(em) {
    display: block;
    font-variation-settings: "opsz" 144;
  }
  /* Serif em: editorial serif-italic line under the headline — Burnt's
     "#ScratchMade" treatment. */
  .sp-em-serif .sp-headline :global(em) {
    display: block;
    font-family: var(--sp-serif);
    font-weight: 700;
    font-size: 68px;
    line-height: 0.9;
    letter-spacing: -0.02em;
  }

  .sp-sub {
    margin: 0;
    max-width: 440px;
    font-family: var(--sp-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 26px;
    line-height: 1.4;
    color: var(--sp-muted);
  }

  .sp-cta {
    align-self: flex-start;
    display: inline-flex; align-items: center; gap: 12px;
    margin-top: 6px;
    font-family: var(--sp-display);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sp-on-accent);
    background: var(--sp-accent);
    padding: 17px 32px;
    border-radius: 999px;
    box-shadow: 0 6px 24px color-mix(in srgb, var(--sp-accent) 45%, transparent),
      inset 0 1px 0 rgba(255,255,255,0.18);
  }
  .sp-arrow { font-size: 0.95em; }

  /* ============================================================
     SPLIT side widget
     ============================================================ */
  .sp-side { flex: 1; display: flex; justify-content: flex-end; }
  .sp-widget {
    width: 100%;
    max-width: 360px;
    background: color-mix(in srgb, var(--sp-fg) 4%, #fff);
    border: 1px solid color-mix(in srgb, var(--sp-fg) 12%, transparent);
    border-radius: 22px;
    padding: 28px;
    display: flex; flex-direction: column; gap: 18px;
    box-shadow: 0 40px 80px -40px color-mix(in srgb, var(--sp-fg) 40%, transparent);
  }
  .sp-widget-label {
    font-family: var(--font-sans);
    font-size: 14px; font-weight: 600;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--sp-muted);
  }
  .sp-widget-rows { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 14px; }
  .sp-widget-rows li {
    display: flex; align-items: center; justify-content: space-between;
    padding-bottom: 14px;
    border-bottom: 1px solid color-mix(in srgb, var(--sp-fg) 10%, transparent);
    font-size: 20px;
  }
  .sp-widget-rows li:last-child { border-bottom: 0; padding-bottom: 0; }
  .sp-widget-rows span { color: var(--sp-muted); }
  .sp-widget-rows strong { font-family: var(--sp-serif); font-weight: 500; color: var(--sp-fg); }
  .sp-widget-note {
    font-family: var(--sp-serif); font-style: italic; font-weight: 400;
    font-size: 17px; color: var(--sp-muted); line-height: 1.3;
  }
  .sp-imgblock {
    width: 100%; max-width: 360px; aspect-ratio: 4/5;
    border-radius: 22px;
    background:
      radial-gradient(circle at 30% 30%, color-mix(in srgb, var(--sp-accent) 30%, transparent), transparent 60%),
      color-mix(in srgb, var(--sp-fg) 8%, var(--sp-bg));
  }

  @media (prefers-reduced-motion: reduce) {
    .sp-marquee-track { animation: none; }
  }
</style>
