---
/* ----------------------------------------------------------------------------
   SitePreview — renders ONE shipped site as a faithful mini-hero.
   Driven entirely by a ShowcaseSite entry (src/data/showcase.ts), so adding a
   new site never touches this file. Two layouts:
     • overlay → text over a full-bleed photo (visual brands / restaurants)
     • split   → editorial text + an optional signature widget (services)
   All colour comes in as inline CSS vars so each card carries its own palette.
   -------------------------------------------------------------------------- */
import type { ShowcaseSite } from "../../data/showcase";

interface Props {
  site: ShowcaseSite;
}
const { site } = Astro.props;

const vars = [
  `--sp-bg:${site.bg}`,
  `--sp-fg:${site.fg}`,
  `--sp-muted:${site.muted}`,
  `--sp-accent:${site.accent}`,
  `--sp-on-accent:${site.onAccent ?? "#fff"}`,
].join(";");
---

<div class={`sp sp-${site.layout} sp-display-${site.display}`} style={vars}>
  {site.layout === "overlay" && site.image && (
    <img class="sp-photo" src={site.image} alt="" loading="lazy" decoding="async" />
  )}
  <div class="sp-scrim" aria-hidden="true"></div>

  {/* faux nav */}
  <div class="sp-nav">
    {site.logo
      ? <img class="sp-logo" src={site.logo} alt={site.name} loading="lazy" />
      : <span class="sp-logo-text">{site.name}</span>}
    <span class="sp-nav-links" aria-hidden="true">
      <span></span><span></span><span></span>
    </span>
    <span class="sp-nav-cta">{site.cta}</span>
  </div>

  <div class="sp-body">
    <div class="sp-copy">
      <span class="sp-eyebrow"><span class="sp-dot" aria-hidden="true"></span>{site.eyebrow}</span>
      <h3 class="sp-headline" set:html={site.headline}></h3>
      <p class="sp-sub">{site.sub}</p>
      <span class="sp-cta">{site.cta}<span class="sp-arrow" aria-hidden="true">→</span></span>
    </div>

    {site.layout === "split" && (
      <div class="sp-side" aria-hidden="true">
        {site.widget ? (
          <div class="sp-widget">
            <span class="sp-widget-label">{site.widget.label}</span>
            <ul class="sp-widget-rows">
              {site.widget.rows.map((r) => (
                <li><span>{r.k}</span><strong>{r.v}</strong></li>
              ))}
            </ul>
            {site.widget.note && <span class="sp-widget-note">{site.widget.note}</span>}
          </div>
        ) : (
          <div class="sp-imgblock"></div>
        )}
      </div>
    )}
  </div>
</div>

<style>
  .sp {
    position: absolute;
    inset: 0;
    background: var(--sp-bg);
    color: var(--sp-fg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    container-type: inline-size;
  }

  .sp-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 60%;
    transform: scale(1.05);
  }
  /* Overlay sites get a left-weighted scrim so text stays legible. */
  .sp-overlay .sp-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, color-mix(in srgb, var(--sp-bg) 88%, transparent) 0%,
        color-mix(in srgb, var(--sp-bg) 45%, transparent) 48%,
        transparent 78%),
      linear-gradient(0deg, color-mix(in srgb, var(--sp-bg) 80%, transparent) 0%, transparent 38%);
  }
  .sp-split .sp-scrim { display: none; }

  /* ---- faux nav ---- */
  .sp-nav {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 5cqw;
    padding: 4cqw 5cqw;
  }
  .sp-logo { height: 6.5cqw; width: auto; }
  .sp-logo-text {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 4.2cqw;
    letter-spacing: -0.01em;
    color: var(--sp-fg);
  }
  .sp-nav-links { display: flex; gap: 3cqw; margin-left: auto; }
  .sp-nav-links span {
    width: 7cqw; height: 1.6cqw; border-radius: 2px;
    background: color-mix(in srgb, var(--sp-fg) 38%, transparent);
  }
  .sp-nav-cta {
    font-family: var(--font-sans);
    font-size: 2.7cqw;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sp-on-accent);
    background: var(--sp-accent);
    padding: 1.8cqw 3.4cqw;
    border-radius: 999px;
  }
  .sp-split .sp-nav-cta { box-shadow: 0 4cqw 8cqw -4cqw color-mix(in srgb, var(--sp-accent) 60%, transparent); }

  /* ---- body ---- */
  .sp-body {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    align-items: center;
    gap: 4cqw;
    padding: 2cqw 5cqw 6cqw;
  }
  .sp-overlay .sp-body { align-items: flex-end; }
  .sp-copy { max-width: 62cqw; display: flex; flex-direction: column; gap: 2.4cqw; }
  .sp-split .sp-copy { max-width: 56cqw; }

  .sp-eyebrow {
    display: inline-flex; align-items: center; gap: 2cqw;
    font-family: var(--font-sans);
    font-size: 2.5cqw;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--sp-muted);
  }
  .sp-dot {
    width: 2cqw; height: 2cqw; border-radius: 50%;
    background: var(--sp-accent);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--sp-accent) 55%, transparent);
  }

  .sp-headline {
    margin: 0;
    line-height: 0.92;
    color: var(--sp-fg);
  }
  .sp-display-caps .sp-headline {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 12cqw;
    letter-spacing: -0.01em;
  }
  .sp-display-serif .sp-headline {
    font-family: var(--font-display);
    font-weight: 350;
    font-size: 9.5cqw;
    letter-spacing: -0.02em;
    line-height: 0.98;
    font-variation-settings: "opsz" 144;
  }
  .sp-headline :global(em) {
    font-style: italic;
    color: var(--sp-accent);
    font-variation-settings: "opsz" 144;
  }
  .sp-display-caps .sp-headline :global(em) { display: block; }

  .sp-sub {
    margin: 0;
    max-width: 40cqw;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 3.4cqw;
    line-height: 1.35;
    color: var(--sp-muted);
  }

  .sp-cta {
    align-self: flex-start;
    display: inline-flex; align-items: center; gap: 2cqw;
    margin-top: 1cqw;
    font-family: var(--font-sans);
    font-size: 3cqw;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--sp-on-accent);
    background: var(--sp-accent);
    padding: 2.6cqw 4.6cqw;
    border-radius: 999px;
  }
  .sp-arrow { font-size: 0.9em; }

  /* ---- split side widget ---- */
  .sp-side { flex: 1; display: flex; justify-content: flex-end; }
  .sp-widget {
    width: 100%;
    max-width: 46cqw;
    background: color-mix(in srgb, var(--sp-fg) 4%, #fff);
    border: 1px solid color-mix(in srgb, var(--sp-fg) 12%, transparent);
    border-radius: 4cqw;
    padding: 4cqw;
    display: flex; flex-direction: column; gap: 2.4cqw;
    box-shadow: 0 8cqw 20cqw -8cqw color-mix(in srgb, var(--sp-fg) 30%, transparent);
  }
  .sp-widget-label {
    font-family: var(--font-sans);
    font-size: 2.4cqw; font-weight: 600;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--sp-muted);
  }
  .sp-widget-rows { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1.8cqw; }
  .sp-widget-rows li {
    display: flex; align-items: center; justify-content: space-between;
    padding-bottom: 1.8cqw;
    border-bottom: 1px solid color-mix(in srgb, var(--sp-fg) 10%, transparent);
    font-size: 3cqw;
  }
  .sp-widget-rows li:last-child { border-bottom: 0; padding-bottom: 0; }
  .sp-widget-rows span { color: var(--sp-muted); }
  .sp-widget-rows strong {
    font-family: var(--font-display); font-weight: 500;
    color: var(--sp-fg);
  }
  .sp-widget-note {
    font-family: var(--font-display); font-style: italic; font-weight: 300;
    font-size: 2.6cqw; color: var(--sp-muted); line-height: 1.3;
  }

  .sp-imgblock {
    width: 100%; max-width: 46cqw; aspect-ratio: 4/5;
    border-radius: 4cqw;
    background:
      radial-gradient(circle at 30% 30%, color-mix(in srgb, var(--sp-accent) 30%, transparent), transparent 60%),
      color-mix(in srgb, var(--sp-fg) 8%, var(--sp-bg));
  }
</style>
