---
// Auto-generated from site/studio.html — round 4 design.
// Edit page-level markup here; shared components live in src/components.
import BaseLayout from "../layouts/BaseLayout.astro";
import BrandMark from "../components/BrandMark.astro";
---

<BaseLayout title="The studio — fwd.">
<section class="studio-hero">
    <img src="/assets/fwd-logo.svg" alt="" aria-hidden="true" class="studio-hero-watermark" />
    <div class="full studio-hero-inner">
      <div data-mv-watch class="mv-rise">
        <p class="studio-hero-meta">
          <span class="num">02</span>
          <span class="bar"></span>
          <span class="label">The studio</span>
        </p>
        <h1 class="display studio-hero-title">Three people.<br /><em>One studio.</em><br />No project managers.</h1>
        <p class="lede studio-hero-lede">We started fwd. because we were tired of agency websites that promised the moon and delivered a WordPress theme. We build calmer sites, with fewer people, for fairer prices.</p>
      </div>
    </div>
  </section>

  <section class="section" id="values">
    <div class="full">
      <div class="story-grid">
        <div class="story-body mv-stagger" data-mv-watch>
          <p class="eyebrow story-eyebrow"><span>Why we exist</span></p>
          <p class="manifesto-lede">A good website should make a small business look <em>twice its size</em>, not a third of it.</p>
          <p class="manifesto-p">For two decades the only good options were either custom — done by an agency, billed against retainers, and shipped six months late — or template, done by a freelancer in a weekend, and exactly as forgettable as the next.</p>
          <p class="manifesto-p">We are trying something in between. A small studio, fixed prices, real design work, and a turnaround measured in weeks. Most of what we ship is a single landing page. That is enough. Most businesses do not need more.</p>
          <p class="manifesto-p">We work directly with the people whose names will appear in the footer. There is no account manager, no kickoff deck, no Slack channel called <em>#engagement</em>. Just three of us, and you, and a couple of weeks of careful design.</p>
        </div>
        <aside class="story-stack" aria-hidden="true">
          <img src="/assets/fwd-logo.svg" alt="" class="shs-mark shs-mark-1" />
          <img src="/assets/fwd-logo.svg" alt="" class="shs-mark shs-mark-2" />
          <img src="/assets/fwd-logo.svg" alt="" class="shs-mark shs-mark-3" />
          <img src="/assets/fwd-logo.svg" alt="" class="shs-mark shs-mark-4" />
        </aside>
      </div>
    </div>
  </section>

  <section class="values-band mv-soften" data-mv-watch>
    <div class="full">
      <div class="values-grid mv-stagger" data-mv-watch>
        <div class="value">
          <span class="value-num">01</span>
          <h3 class="value-h">Fewer, slower projects</h3>
          <p class="value-body">Three to four a quarter. We would rather ship one site well than six sites in parallel.</p>
        </div>
        <div class="value">
          <span class="value-num">02</span>
          <h3 class="value-h">Flat fees, on paper</h3>
          <p class="value-body">Two tiers, both posted publicly. No hourlies, no retainers, no scope creep.</p>
        </div>
        <div class="value">
          <span class="value-num">03</span>
          <h3 class="value-h">You own everything</h3>
          <p class="value-body">Your domain, your hosting, your code. We hand it over and you can switch designers tomorrow.</p>
        </div>
        <div class="value">
          <span class="value-num">04</span>
          <h3 class="value-h">Plain language</h3>
          <p class="value-body">No engagements, no deliverables, no ideation sprints. You will know what you are paying for.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="people">
    <div class="full">
      <div class="section-head mv-rise" data-mv-watch>
        <h2 class="display section-title">The whole studio.</h2>
        <p class="section-sub">You will meet all three of us on the first call, and the same three names will be on every email. Photos coming soon — for now, the names will do.</p>
      </div>

      <div class="people-grid mv-stagger" data-mv-watch>
        <article class="person">
          <div class="person-portrait">
            <span class="person-firstname">Riz</span>
            <span class="person-glyph" aria-hidden="true">●</span>
          </div>
          <div class="person-meta">
            <h3 class="person-name">Riz Gosla</h3>
            <span class="person-role">Engineering &amp; design</span>
            <p class="person-bio">Builds every site we ship and designs most of what gets built. Riz makes the technical calls — what stack, where it lives, how it scales — and translates the design into actual working code. If something on your site is moving, blinking, loading, or laying itself out, that is him.</p>
          </div>
        </article>

        <article class="person">
          <div class="person-portrait">
            <span class="person-firstname">Alex</span>
            <span class="person-glyph" aria-hidden="true">●</span>
          </div>
          <div class="person-meta">
            <h3 class="person-name">Alex</h3>
            <span class="person-role">Payment &amp; finances</span>
            <p class="person-bio">Runs the books. Alex handles every invoice, every payment, every contract you will sign. Flat fees, plain receipts, on-time deposits — the parts of working with a studio that usually feel awkward, made boring on purpose.</p>
          </div>
        </article>

        <article class="person">
          <div class="person-portrait">
            <span class="person-firstname">Jaiden</span>
            <span class="person-glyph" aria-hidden="true">●</span>
          </div>
          <div class="person-meta">
            <h3 class="person-name">Jaiden</h3>
            <span class="person-role">Client &amp; growth</span>
            <p class="person-bio">The first voice you will hear from. Jaiden answers the contact form, runs the intro call, scopes the project, and stays on as your point of contact through launch. If you are trying to figure out whether we are the right studio for you, ask Jaiden.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  </section>
  
  <section class="cta-band cta-band-marks mv-soften" data-mv-watch>
    <div class="cta-band-bg" aria-hidden="true">
      <div class="cta-band-bg-marks">
        <BrandMark class="cb-mark" decorative={true} />
        <BrandMark class="cb-mark" decorative={true} />
        <BrandMark class="cb-mark" decorative={true} />
        <BrandMark class="cb-mark" decorative={true} />
        <BrandMark class="cb-mark" decorative={true} />
        <BrandMark class="cb-mark" decorative={true} />
        <BrandMark class="cb-mark" decorative={true} />
        <BrandMark class="cb-mark" decorative={true} />
      </div>
    </div>
    <div class="cta-band-inner">
      <h3 class="display">Sound like the kind of studio you would <em>like to work with</em>?</h3>
      <div>
        <p>The contact form takes about a minute. We reply to every inquiry.</p>
        <a href="/contact" class="btn btn-primary">Start a project <span class="arrow" aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     STUDIO HERO — dark full-bleed band with a giant logo watermark
     bleeding off the left and text content stacked on the right.
     ============================================================ */
  .studio-hero {
    position: relative;
    background: var(--color-ink);
    color: var(--color-paper);
    overflow: hidden;
    padding-block: clamp(5rem, 14vh, 10rem);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .studio-hero::before {
    content: "";
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 20% 30%, rgb(142 148 184 / 0.12), transparent 70%),
      radial-gradient(ellipse 60% 60% at 90% 90%, rgb(20 70 103 / 0.45), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .studio-hero-watermark {
    position: absolute;
    left: -10%;
    top: 50%;
    transform: translateY(-50%) rotate(-8deg);
    height: 140%;
    width: auto;
    max-width: none;
    opacity: 0.07;
    filter: brightness(0) invert(1);
    pointer-events: none;
    z-index: 0;
  }
  .studio-hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    justify-items: end;
  }
  .studio-hero-inner > div { max-width: 38rem; width: 100%; }
  .studio-hero-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0 0 2.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-step--2);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-periwinkle);
  }
  .studio-hero-meta .num { color: var(--color-periwinkle); }
  .studio-hero-meta .bar { width: 28px; height: 1px; background: rgba(255,255,255,0.4); display: inline-block; }
  .studio-hero-meta .label { color: rgba(255,255,255,0.7); }
  .studio-hero-title {
    font-size: var(--text-step-6);
    margin: 0;
    color: var(--color-paper);
    line-height: 0.98;
    letter-spacing: -0.025em;
    font-variation-settings: "opsz" 144;
    max-width: 14ch;
  }
  .studio-hero-title em {
    font-style: italic;
    color: var(--color-periwinkle);
    font-variation-settings: "opsz" 144;
  }
  .studio-hero-lede {
    margin: 2rem 0 0;
    color: rgba(255,255,255,0.72);
    max-width: 50ch;
    font-size: var(--text-step-1);
    font-family: var(--font-display);
    font-weight: 300;
    font-variation-settings: "opsz" 60;
  }
  @media (max-width: 800px) {
    .studio-hero-inner { justify-items: stretch; }
    .studio-hero-watermark { left: -30%; height: 110%; }
  }

  /* ============================================================
     STORY SECTION — manifesto text on the LEFT, a diagonal stack
     of four logo marks (deep blue / periwinkle / paper / navy)
     on the right.
     ============================================================ */
  .story-eyebrow { margin: 0 0 1.5rem; }
  .story-stack {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    max-width: 460px;
    margin-inline: auto;
    align-self: center;
  }
  .shs-mark {
    position: absolute;
    top: 0; left: 0;
    width: 70%;
    height: auto;
    display: block;
  }
  /* Layer 1 (back) — deep blue */
  .shs-mark-1 {
    top: 0; left: 0;
    filter: brightness(0) saturate(100%) invert(20%) sepia(38%) saturate(1400%) hue-rotate(168deg) brightness(95%) contrast(98%);
    opacity: 0.9;
  }
  /* Layer 2 — periwinkle */
  .shs-mark-2 {
    top: 10%; left: 10%;
    filter: brightness(0) saturate(100%) invert(64%) sepia(11%) saturate(700%) hue-rotate(190deg) brightness(95%) contrast(90%);
    opacity: 0.95;
  }
  /* Layer 3 — paper white (with subtle border via drop-shadow so it reads on light bg) */
  .shs-mark-3 {
    top: 20%; left: 20%;
    filter: brightness(0) invert(1) drop-shadow(0 0 1px rgba(13,47,69,0.25));
    opacity: 1;
  }
  /* Layer 4 (front) — navy */
  .shs-mark-4 {
    top: 30%; left: 30%;
    filter: brightness(0) saturate(100%) invert(13%) sepia(45%) saturate(1900%) hue-rotate(180deg) brightness(85%) contrast(95%);
    opacity: 1;
  }
  @media (max-width: 899px) {
    .story-stack { max-width: 280px; }
  }

.story-grid { display: grid; grid-template-columns: 1fr; gap: 2.5rem; align-items: center; }
  @media (min-width: 900px) { .story-grid { grid-template-columns: 1.5fr 1fr; gap: clamp(3rem, 6vw, 6rem); } }
  .story-body { display: flex; flex-direction: column; gap: 1.5rem; }
  .manifesto-lede { font-family: var(--font-display); font-weight: 300; font-size: var(--text-step-3); line-height: 1.2; letter-spacing: -0.015em; color: var(--color-fg); margin: 0; max-width: 26ch; font-variation-settings: "opsz" 96; text-wrap: balance; }
  .manifesto-lede em { font-style: italic; color: var(--color-blue); font-variation-settings: "opsz" 96; }
  .manifesto-p { font-family: var(--font-display); font-weight: 300; font-size: var(--text-step-1); line-height: 1.5; color: var(--color-fg-soft); margin: 0; max-width: 58ch; font-variation-settings: "opsz" 60; text-wrap: pretty; }
  .manifesto-p em { font-style: italic; color: var(--color-blue); }
  .values-band { background: var(--color-ink); color: var(--color-paper); padding-block: clamp(4rem, 9vh, 6rem); margin-block: 4rem; position: relative; overflow: hidden; }
  .values-band::before { content: ""; position: absolute; inset: 0; background: radial-gradient(ellipse 60% 50% at 50% 0%, rgb(142 148 184 / 0.12), transparent 70%); pointer-events: none; }
  .values-grid { display: grid; gap: 2rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); position: relative; z-index: 1; }
  .value { display: flex; flex-direction: column; gap: 0.75rem; }
  .value-num { font-family: var(--font-mono); font-size: var(--text-step--2); letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-periwinkle); }
  .value-h { font-family: var(--font-display); font-weight: 400; font-size: var(--text-step-2); color: var(--color-paper); margin: 0; letter-spacing: -0.015em; font-variation-settings: "opsz" 60; }
  .value-body { margin: 0; color: rgba(255,255,255,0.7); font-size: var(--text-step-0); line-height: 1.5; max-width: 30ch; }
  .section-head { display: grid; gap: 1rem; grid-template-columns: 1fr; align-items: end; margin-bottom: 3rem; }
  @media (min-width: 760px) { .section-head { grid-template-columns: 1fr 1.1fr; gap: 3rem; } }
  .section-title { font-size: var(--text-step-4); max-width: 22ch; margin: 0; }
  .section-sub { color: var(--color-fg-soft); max-width: 50ch; font-size: var(--text-step-1); margin: 0; text-wrap: pretty; }
  .people-grid { display: grid; gap: 2rem; grid-template-columns: 1fr; }
  @media (min-width: 800px) { .people-grid { grid-template-columns: repeat(3, 1fr); } }
  .person { display: flex; flex-direction: column; gap: 1.25rem; border-top: 1px solid var(--color-line); padding-top: 1.5rem; }
  .person-portrait { aspect-ratio: 4/5; background: var(--color-bg-soft); border-radius: 10px; position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; }
  .person-portrait::before { content: ""; position: absolute; inset: 0; background-image: linear-gradient(rgba(13,47,69,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(13,47,69,0.06) 1px, transparent 1px); background-size: 28px 28px; -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 30%, transparent 85%); mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 30%, transparent 85%); }
  .person-firstname { font-family: var(--font-display); font-weight: 350; font-style: italic; font-size: clamp(4rem, 10vw, 7rem); color: var(--color-navy); line-height: 1; letter-spacing: -0.04em; font-variation-settings: "opsz" 144; position: relative; z-index: 1; transition: color 320ms var(--ease-soft); }
  .person:hover .person-firstname { color: var(--color-blue); }
  .person-glyph { position: absolute; bottom: 14px; right: 14px; color: var(--color-periwinkle); font-size: 9px; z-index: 1; animation: mvBlink 1.6s steps(1) infinite; }
  .person-meta { display: flex; flex-direction: column; gap: 0.4rem; }
  .person-name { font-family: var(--font-display); font-weight: 400; font-size: var(--text-step-2); margin: 0; color: var(--color-fg); letter-spacing: -0.015em; font-variation-settings: "opsz" 60; }
  .person-role { font-family: var(--font-mono); font-size: var(--text-step--2); letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-blue); }
  .person-bio { margin: 0.5rem 0 0; color: var(--color-fg-soft); font-size: var(--text-step-0); line-height: 1.5; max-width: 38ch; }
  .section-expect { background: var(--color-bg-soft); }
  .expect-list { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--color-line); }
  .expect-row { display: grid; grid-template-columns: 1fr; gap: 0.5rem; padding-block: 1.75rem; border-bottom: 1px solid var(--color-line); transition: padding-left 280ms var(--ease-soft), background 280ms var(--ease-soft); }
  @media (min-width: 760px) { .expect-row { grid-template-columns: 140px 1fr; gap: 3rem; align-items: baseline; } }
  .expect-row:hover { padding-left: 0.5rem; background: rgb(20 70 103 / 0.025); }
  .expect-when { font-family: var(--font-mono); font-size: var(--text-step--2); letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-blue); font-weight: 500; }
  .expect-text { display: flex; flex-direction: column; gap: 0.4rem; }
  .expect-h { font-family: var(--font-display); font-weight: 400; font-size: var(--text-step-2); color: var(--color-fg); margin: 0; letter-spacing: -0.015em; font-variation-settings: "opsz" 60; }
  .expect-p { margin: 0; color: var(--color-fg-soft); font-size: var(--text-step-0); line-height: 1.5; max-width: 60ch; }
</style>


