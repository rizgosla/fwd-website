---
import BaseLayout from "../layouts/BaseLayout.astro";
import Marquee from "../components/Marquee.astro";
import SectionRule from "../components/SectionRule.astro";
import SectionHead from "../components/SectionHead.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ProcessStep from "../components/ProcessStep.astro";
import CtaStrip from "../components/CtaStrip.astro";
import Reel from "../components/Reel.astro";

const heroMeta = [
  ["Studio size",        "Three partners"],
  ["Typical turnaround", "2–4 weeks"],
  ["Pricing model",      "Flat fee, no retainers"],
  ["Hosting & domain",   "Set up & included"],
];

const HERO_STAGES = [
  { id: "blank",   label: "01 · Blank canvas",  pct: 0.00 },
  { id: "grid",    label: "02 · Grid system",   pct: 0.20 },
  { id: "wires",   label: "03 · Wireframe",     pct: 0.42 },
  { id: "content", label: "04 · Content",       pct: 0.66 },
  { id: "polish",  label: "05 · Live site",     pct: 0.88 },
];

const tiers = [
  { tierNum: "01", tierLabel: "Solo", deliverable: "~1–2 weeks",
    title: "Landing Page", price: "800", priceNote: "flat · one round of revisions",
    features: [
      "One beautifully-designed page built around your brand",
      "Booking / contact form with instant email notifications",
      "Mobile and desktop optimized, basic on-page SEO",
      "Hosting setup and domain connection included",
    ],
    ctaLabel: "Start with Landing" },
  { tierNum: "02", tierLabel: "Full", deliverable: "~2–4 weeks · up to 8 pages",
    title: "Full Site", price: "1,800", priceNote: "flat · two rounds of revisions",
    features: [
      "Everything in Landing Page, scaled up to 8 pages",
      "Home, Services, About, Contact + 4 of your choice",
      "Cohesive type, color, and component system",
      "Handoff doc so you (or anyone) can update content later",
    ],
    ctaLabel: "Start with Full Site" },
];

const steps = [
  { glyph: "i.",   step: "Step 01", title: "A short call",  body: "15 minutes. We learn about your work, who you serve, and what you'd like the site to do for you.", meta: "No prep required" },
  { glyph: "ii.",  step: "Step 02", title: "Design draft",  body: "A first version, built around your brand and content. You see real layouts in your browser, not Figma squiggles.", meta: "Delivered in week one" },
  { glyph: "iii.", step: "Step 03", title: "Revisions",     body: "One or two rounds depending on tier. We adjust until it feels right, then lock it.", meta: "Async, on your time" },
  { glyph: "iv.",  step: "Step 04", title: "Launch",        body: "We connect your domain, set up hosting, and hand over a clean handoff doc you can actually read.", meta: "Live the same day" },
];
---

<BaseLayout>
  <section class="hero-outer" id="heroOuter">
    <div class="hero-pin">
      <div class="hero">
        <div class="hero-left">
          <div class="hero-eyebrow">
            <span class="bar"></span>
            <span class="num">§ 00</span>
            <span>fwd. — small web studio</span>
          </div>
          <h1 class="display hero-title">Websites that <em>earn</em> their place online.</h1>
          <p class="lede hero-lede">
            We build clean, considered sites for practices and small businesses —
            the kind that quietly do their job, look the part, and <em>show up</em>
            when clients search for you.
          </p>
          <div class="hero-actions">
            <a href="/services" class="btn btn-primary">See services <span class="arrow">→</span></a>
            <a href="/contact"  class="btn btn-ghost">Start a project</a>
          </div>
          <div class="hero-meta">
            {heroMeta.map(([k, v]) => (
              <div class="meta-cell">
                <span class="meta-key">{k}</span>
                <strong class="meta-val">{v}</strong>
              </div>
            ))}
          </div>
        </div>

        <div class="hero-right">
          <div class="browser">
            <div class="browser-chrome">
              <div class="dots">
                <span style="background:#FF6058"></span>
                <span style="background:#FFBE2E"></span>
                <span style="background:#28C940"></span>
              </div>
              <div class="urlbar"><span class="lock">●</span><span class="url" id="heroUrl">localhost:4321</span></div>
              <div class="stage-pill" id="heroStagePill">01 · Blank canvas</div>
            </div>
            <div class="browser-body">
              <div class="grid-bg" id="gridBg"></div>

              <div class="wf-row" id="wfRow1"><div class="wf-h1"></div></div>
              <div class="wf-row narrow" id="wfRow2">
                <div class="wf-line" style="width:78%"></div>
                <div class="wf-line" style="width:62%"></div>
              </div>
              <div class="wf-grid" id="wfGrid">
                <div class="wf-block tall"></div>
                <div class="wf-stack">
                  <div class="wf-line" style="width:85%"></div>
                  <div class="wf-line" style="width:70%"></div>
                  <div class="wf-line" style="width:55%"></div>
                  <div class="wf-pill"></div>
                </div>
              </div>

              <div class="content-layer" id="contentLayer">
                <div class="ct-eyebrow">— Family dentistry · Irvine, CA</div>
                <div class="ct-h1">A calmer kind of <em>dental visit</em>.</div>
                <div class="ct-lede">Same-day appointments, gentle care, and a team that actually remembers your name.</div>
              </div>

              <div class="polish-layer" id="polishLayer">
                <div class="pl-image">
                  <div class="pl-image-grad"></div>
                  <div class="pl-image-tag">[ studio photo ]</div>
                </div>
                <div class="pl-cta">Book a visit <span>→</span></div>
                <div class="pl-hours">
                  <div><span>Mon–Thu</span><strong>8a — 6p</strong></div>
                  <div><span>Fri</span><strong>8a — 2p</strong></div>
                  <div><span>Sat–Sun</span><strong>Closed</strong></div>
                </div>
              </div>
            </div>
            <div class="browser-foot">
              <span class="foot-label">scroll to build</span>
              <div class="track">
                <div class="fill" id="heroFill"></div>
                {HERO_STAGES.map((s) => (
                  <div class="tick" data-pct={s.pct} style={`left:${s.pct * 100}%`}></div>
                ))}
              </div>
              <span class="foot-label right" id="heroPct">0%</span>
            </div>
          </div>
          <div class="hero-caption">↑ a site coming together as you scroll</div>
        </div>
      </div>
    </div>
  </section>

  <Marquee />

  <section id="services" class="section">
    <div class="full">
      <SectionRule num="§ 01" label="Services" />
      <SectionHead title="Two ways to <em>get online</em>." />
      <div class="grid gap-6 grid-cols-1 md:grid-cols-2">
        {tiers.map((t) => (<ServiceCard {...t} />))}
      </div>
    </div>
  </section>

  <section class="section section-process">
    <div class="full">
      <SectionRule num="§ 02" label="Process" />
      <SectionHead title="A simple, <em>honest</em> process." />
      <ol class="grid grid-cols-1 list-none p-0 m-0 border-t border-line">
        {steps.map((s) => (<ProcessStep {...s} />))}
      </ol>
    </div>
  </section>

  <Reel />

  <div class="full mt-24" id="contact">
    <CtaStrip
      title="Got a practice, a product, or a <em>side project</em>?"
      body="Tell us about it. We reply to every inquiry — usually within a day."
    />
  </div>
</BaseLayout>

<script is:inline>
  (() => {
    const outer = document.getElementById('heroOuter');
    if (!outer) return;
    const STAGES = [
      { id: "blank",   label: "01 · Blank canvas",  pct: 0.00, url: "localhost:4321" },
      { id: "grid",    label: "02 · Grid system",   pct: 0.20, url: "localhost:4321" },
      { id: "wires",   label: "03 · Wireframe",     pct: 0.42, url: "localhost:4321" },
      { id: "content", label: "04 · Content",       pct: 0.66, url: "localhost:4321" },
      { id: "polish",  label: "05 · Live site",     pct: 0.88, url: "smithdental.com" },
    ];
    const gridBg = document.getElementById('gridBg');
    const wf1 = document.getElementById('wfRow1');
    const wf2 = document.getElementById('wfRow2');
    const wfG = document.getElementById('wfGrid');
    const cl  = document.getElementById('contentLayer');
    const pl  = document.getElementById('polishLayer');
    const url = document.getElementById('heroUrl');
    const pill = document.getElementById('heroStagePill');
    const fill = document.getElementById('heroFill');
    const pctEl = document.getElementById('heroPct');
    const ticks = outer.querySelectorAll('.tick');

    const reach = (id, idx) => idx >= STAGES.findIndex((s) => s.id === id);

    const apply = (progress) => {
      let idx = 0;
      for (let i = 0; i < STAGES.length; i++) if (progress >= STAGES[i].pct) idx = i;
      const stage = STAGES[idx];

      // grid bg visible from "grid" stage, hides at "polish"
      gridBg.style.opacity = reach("grid", idx) ? (reach("polish", idx) ? 0 : 0.5) : 0;

      // wireframe
      const wfOn = reach("wires", idx);
      [wf1, wf2, wfG].forEach((el, i) => {
        el.style.opacity = wfOn ? 1 : 0;
        el.style.transform = wfOn ? 'translateY(0)' : 'translateY(8px)';
        el.style.transitionDelay = (i * 60) + 'ms';
      });

      cl.style.opacity = reach("content", idx) ? 1 : 0;
      pl.style.opacity = reach("polish", idx) ? 1 : 0;

      url.textContent = stage.url;
      pill.textContent = stage.label;
      fill.style.width = (progress * 100) + '%';
      pctEl.textContent = Math.round(progress * 100) + '%';
      ticks.forEach((t) => {
        const p = parseFloat(t.dataset.pct);
        t.style.background = progress >= p - 0.001 ? 'var(--color-periwinkle)' : 'rgba(7,23,34,0.18)';
      });
    };

    const onScroll = () => {
      const rect = outer.getBoundingClientRect();
      const vh = window.innerHeight;
      const total = outer.offsetHeight - vh;
      const scrolled = Math.min(Math.max(-rect.top, 0), total);
      apply(total > 0 ? scrolled / total : 0);
    };

    apply(0);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
  })();
</script>

<style>
  /* ===== HERO — pinned scroll (exact match to prototype) ===== */
  .hero-outer { height: 320vh; position: relative; }
  .hero-pin { position: sticky; top: 0; height: 100vh; overflow: hidden; }
  .hero { display: grid; grid-template-columns: 1.05fr 1fr; height: 100%; width: 100%; align-items: stretch; }
  .hero-left { display: flex; flex-direction: column; gap: 1.75rem; padding: clamp(2rem, 4vh, 3.5rem) clamp(1.5rem, 4vw, 4rem) 2.5rem var(--pad-x, clamp(1.5rem, 3.5vw, 3.5rem)); justify-content: center; }

  .hero-eyebrow { display: inline-flex; align-items: center; gap: 12px; font-family: var(--font-mono); font-size: var(--text-step--2); letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-fg-muted); }
  .hero-eyebrow .bar { width: 24px; height: 1px; background: var(--color-periwinkle); }
  .hero-eyebrow .num { font-family: var(--font-mono); color: var(--color-blue); }

  .hero-title { font-size: var(--text-step-6); margin: 0; max-width: 14ch; }
  .hero-lede { max-width: 38ch; margin: 0; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  .hero-meta { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1.25rem 2rem; border-top: 1px solid var(--color-line); padding-top: 1.25rem; margin-top: 0.5rem; }
  .meta-cell { display: flex; flex-direction: column; gap: 0.3rem; }
  .meta-key { font-family: var(--font-mono); font-size: var(--text-step--2); letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-fg-muted); }
  .meta-val { font-family: var(--font-display); font-weight: 500; font-size: var(--text-step-0); font-variation-settings: "opsz" 60, "SOFT" 30; color: var(--color-fg); }

  .hero-right { position: relative; background: linear-gradient(160deg, #f6f6f8 0%, #eceef5 100%); border-left: 1px solid var(--color-line); display: flex; align-items: center; justify-content: center; padding: clamp(1.5rem, 4vh, 3rem) clamp(1rem, 3vw, 3rem); overflow: hidden; }
  .hero-right::before { content: ""; position: absolute; inset: 0; background-image: linear-gradient(rgba(13,47,69,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(13,47,69,0.06) 1px, transparent 1px); background-size: 32px 32px; -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 80%); mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 80%); pointer-events: none; }

  .browser { width: min(620px, 95%); background: #fff; border-radius: 12px; border: 1px solid var(--color-line); box-shadow: 0 50px 100px -40px rgb(7 23 34 / 0.35), 0 12px 30px -12px rgb(7 23 34 / 0.18); overflow: hidden; position: relative; z-index: 1; }
  .browser-chrome { display: flex; align-items: center; gap: 12px; padding: 12px 16px; background: #f5f6f8; border-bottom: 1px solid var(--color-line); }
  .dots { display: flex; gap: 6px; }
  .dots span { width: 11px; height: 11px; border-radius: 50%; }
  .urlbar { flex: 1; height: 26px; border-radius: 6px; background: #fff; border: 1px solid var(--color-line); display: flex; align-items: center; gap: 8px; padding: 0 12px; font-family: var(--font-mono); font-size: 11px; color: var(--color-fg-muted); }
  .urlbar .lock { color: var(--color-blue); font-size: 8px; }
  .stage-pill { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-blue); background: #fff; border: 1px solid var(--color-line); padding: 4px 10px; border-radius: 999px; white-space: nowrap; }
  .browser-body { position: relative; height: clamp(360px, 48vh, 460px); background: #fff; overflow: hidden; }
  .browser-body > * { transition: opacity 600ms cubic-bezier(0.2,0.7,0.2,1), transform 600ms cubic-bezier(0.2,0.7,0.2,1); }

  .grid-bg { position: absolute; inset: 0; background-image: linear-gradient(rgba(13,47,69,0.12) 1px, transparent 1px), linear-gradient(90deg, rgba(13,47,69,0.12) 1px, transparent 1px); background-size: 24px 24px; opacity: 0; }
  .wf-row, .wf-grid { position: relative; padding: 28px 32px; opacity: 0; }
  .wf-row { padding-bottom: 0; }
  .wf-row.narrow { padding-top: 12px; }
  .wf-h1 { height: 48px; width: 60%; background: rgba(13,47,69,0.18); border-radius: 4px; }
  .wf-line { height: 10px; background: rgba(13,47,69,0.14); border-radius: 3px; margin-bottom: 8px; }
  .wf-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 18px; margin-top: 8px; }
  .wf-block.tall { height: 180px; background: repeating-linear-gradient(135deg, rgba(13,47,69,0.12) 0 8px, transparent 8px 16px); border: 1px dashed rgba(13,47,69,0.25); border-radius: 6px; }
  .wf-stack { display: flex; flex-direction: column; gap: 10px; }
  .wf-pill { width: 110px; height: 30px; border-radius: 999px; background: var(--color-periwinkle); margin-top: 8px; }

  .content-layer { position: absolute; inset: 0; padding: 36px 36px 24px; display: flex; flex-direction: column; gap: 12px; background: rgba(255,255,255,0.6); -webkit-backdrop-filter: blur(2px); backdrop-filter: blur(2px); opacity: 0; }
  .ct-eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; color: var(--color-fg-muted); }
  .ct-h1 { font-family: var(--font-display); font-size: clamp(1.8rem, 2.3vw, 2.4rem); font-weight: 350; line-height: 1.05; letter-spacing: -0.02em; color: var(--color-navy); font-variation-settings: "opsz" 144, "SOFT" 30; margin-top: 4px; }
  .ct-h1 em { font-style: italic; color: var(--color-blue); font-variation-settings: "opsz" 144, "SOFT" 100; }
  .ct-lede { font-family: var(--font-display); font-weight: 300; font-size: var(--text-step-1); color: var(--color-fg-soft); max-width: 36ch; line-height: 1.35; }

  .polish-layer { position: absolute; inset: 0; padding: 28px 32px 20px; display: grid; grid-template-columns: 1.4fr 1fr; grid-template-rows: 1fr auto; gap: 16px; background: #fff; opacity: 0; }
  .pl-image { grid-row: 1 / span 2; position: relative; border-radius: 8px; overflow: hidden; background: linear-gradient(135deg, #e8eef3 0%, #c4d2dc 60%, var(--color-periwinkle) 120%); }
  .pl-image-grad { position: absolute; inset: 0; background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.5), transparent 50%), repeating-linear-gradient(45deg, rgba(13,47,69,0.05) 0 4px, transparent 4px 12px); }
  .pl-image-tag { position: absolute; bottom: 10px; left: 12px; font-family: var(--font-mono); font-size: 10px; color: var(--color-fg-muted); background: rgba(255,255,255,0.85); padding: 3px 8px; border-radius: 4px; letter-spacing: 0.04em; }
  .pl-cta { align-self: start; justify-self: end; background: var(--color-navy); color: #fff; padding: 10px 18px; border-radius: 999px; font-size: 13px; font-weight: 500; display: inline-flex; align-items: center; gap: 6px; }
  .pl-hours { display: flex; flex-direction: column; gap: 6px; font-size: 12px; align-self: end; }
  .pl-hours > div { display: flex; justify-content: space-between; padding: 6px 10px; border-bottom: 1px solid var(--color-line); }
  .pl-hours strong { font-family: var(--font-display); font-weight: 500; font-variation-settings: "opsz" 60, "SOFT" 30; }
  .pl-hours span { color: var(--color-fg-muted); font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; }

  .browser-foot { display: flex; align-items: center; gap: 12px; padding: 10px 16px; background: #fafafb; border-top: 1px solid var(--color-line); }
  .foot-label { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-fg-muted); }
  .foot-label.right { margin-left: auto; }
  .track { flex: 1; height: 2px; background: rgba(7,23,34,0.08); border-radius: 2px; position: relative; }
  .fill { position: absolute; left: 0; top: 0; height: 100%; background: var(--color-periwinkle); border-radius: 2px; transition: width 200ms linear; width: 0; }
  .tick { position: absolute; top: -2px; width: 6px; height: 6px; border-radius: 50%; transform: translateX(-3px); transition: background 280ms cubic-bezier(0.2,0.7,0.2,1); background: rgba(7,23,34,0.18); }

  .hero-caption { position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%); font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-fg-muted); opacity: 0.7; }

  .full { width: 100%; padding-inline: var(--pad-x, clamp(1.5rem, 3.5vw, 3.5rem)); }
  .section { padding-block: clamp(4rem, 9vh, 7rem); position: relative; }

  @media (max-width: 1000px) {
    .hero-outer { height: auto; }
    .hero-pin { position: relative; height: auto; }
    .hero { grid-template-columns: 1fr; height: auto; }
    .hero-right { border-left: 0; border-top: 1px solid var(--color-line); padding-top: 3rem; padding-bottom: 4rem; }
    .hero-title { font-size: clamp(2.6rem, 9vw, 4.5rem); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-outer { height: auto; }
    .hero-pin { position: relative; height: auto; }
  }
</style>
