<script is:inline>
(() => {
    const outer = document.getElementById('heroOuter');
    if (!outer) return;
    const STAGES = [
      { id: "blank", label: "01 · Blank canvas", pct: 0, url: "localhost:4321" },
      { id: "grid", label: "02 · Grid system", pct: 0.2, url: "localhost:4321" },
      { id: "wires", label: "03 · Wireframe", pct: 0.42, url: "localhost:4321" },
      { id: "content", label: "04 · Content", pct: 0.66, url: "localhost:4321" },
      { id: "polish", label: "05 · Live site", pct: 0.88, url: "smithdental.com" },
    ];
    const $ = (id) => document.getElementById(id);
    const gridBg = $('gridBg'), wf1 = $('wfRow1'), wf2 = $('wfRow2'), wfG = $('wfGrid');
    const cl = $('contentLayer'), pl = $('polishLayer'), url = $('heroUrl'), pill = $('heroStagePill');
    const fill = $('heroFill'), pctEl = $('heroPct'), footLabel = $('heroFootLabel'), plCta = $('plCta');
    const plStatNum = $('plStatNum');
    const ticks = outer.querySelectorAll('.tick');
    const reach = (id, idx) => idx >= STAGES.findIndex((s) => s.id === id);
    const apply = (progress) => {
      let idx = 0;
      for (let i = 0; i < STAGES.length; i++) if (progress >= STAGES[i].pct) idx = i;
      const stage = STAGES[idx];
      gridBg.style.opacity = reach('grid', idx) ? (reach('polish', idx) ? 0 : 0.5) : 0;
      const wfOn = reach('wires', idx);
      [wf1, wf2, wfG].forEach((el, i) => {
        el.style.opacity = wfOn ? 1 : 0;
        el.style.transform = wfOn ? 'translateY(0)' : 'translateY(8px)';
        el.style.transitionDelay = (i * 60) + 'ms';
      });
      cl.style.opacity = reach('content', idx) ? 1 : 0;
      pl.style.opacity = reach('polish', idx) ? 1 : 0;
      url.textContent = stage.url;
      pill.textContent = stage.label;
      fill.style.width = (progress * 100) + '%';
      pctEl.textContent = Math.round(progress * 100) + '%';
      ticks.forEach((t) => {
        const p = parseFloat(t.dataset.pct);
        t.style.background = progress >= p - 0.001 ? 'var(--color-periwinkle)' : 'rgba(7,23,34,0.18)';
      });
    };
    apply(0);
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const enterIdle = () => {
      if (plCta) plCta.classList.add('live');
      if (pl) pl.classList.add('is-live');
      if (footLabel) footLabel.textContent = 'live site';
      // Animated stat ticker — counts 0 → 23 over 1.5s
      if (plStatNum) {
        const target = 23;
        const dur = 1500;
        const start = performance.now();
        const step = (ts) => {
          const t = Math.min((ts - start) / dur, 1);
          const eased = 1 - Math.pow(1 - t, 3);
          plStatNum.textContent = Math.round(eased * target);
          if (t < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      }
    };
    if (reduce) { apply(1); enterIdle(); return; }
    const DURATION = 7000;
    let startedAt = null;
    const tick = (ts) => {
      if (startedAt === null) startedAt = ts;
      const t = Math.min((ts - startedAt) / DURATION, 1);
      const eased = 1 - Math.pow(1 - t, 2.2);
      apply(eased);
      if (footLabel) footLabel.textContent = t < 1 ? 'building…' : 'live site';
      if (t < 1) requestAnimationFrame(tick);
      else enterIdle();
    };
    const start = () => requestAnimationFrame(tick);
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { io.disconnect(); start(); } });
      }, { threshold: 0.2 });
      io.observe(outer);
    } else setTimeout(start, 300);
  })();
</script>
