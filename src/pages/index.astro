---
// Auto-generated from site/index.html — round 4 design.
// Edit page-level markup here; shared components live in src/components.
import BaseLayout from "../layouts/BaseLayout.astro";
import Marquee from "../components/Marquee.astro";
import HeroShowcase from "../components/HeroShowcase.astro";
---

<BaseLayout title="fwd. — Websites that earn their place online">
<!-- ============ HERO with idle motion baked in ============ -->
  <section class="hero-outer">
    <div class="hero">
      <div class="hero-left">
        <h1 class="display hero-title">Your website is your new <em>storefront</em>.</h1>
        <p class="lede hero-lede">Give it the <em>respect</em> it deserves.</p>
        <div class="hero-actions">
          <a href="/services" class="btn btn-primary">See services <span class="arrow">→</span></a>
          <a href="/contact" class="btn btn-ghost">Start a project</a>
        </div>
      </div>

      <div class="hero-right">
        <HeroShowcase />
      </div>
    </div>
  </section>

  <!-- ============ MARQUEE (reverted to original phrase Marquee component) ============ -->
  <Marquee />

  <!-- ============ HERO META STRIP ============ -->
  <section class="meta-strip">
    <div class="full">
      <div class="meta-strip-grid mv-stagger" data-mv-watch>
        <div class="meta-cell">
          <span class="meta-key">Studio size</span>
          <strong class="meta-val">Three partners</strong>
        </div>
        <div class="meta-cell">
          <span class="meta-key">Typical turnaround</span>
          <strong class="meta-val">About 4 weeks</strong>
        </div>
        <div class="meta-cell">
          <span class="meta-key">Pricing model</span>
          <strong class="meta-val">Flat fee, no retainers</strong>
        </div>
        <div class="meta-cell">
          <span class="meta-key">Hosting &amp; domain</span>
          <strong class="meta-val">Set up &amp; included</strong>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SERVICES preview — bento spec sheet ============ -->
  <section id="services" class="section section-offer">
    <div class="full">
      <div class="section-head mv-rise" data-mv-watch>
        <h2 class="display section-title">A whole website, <em>one number</em>.</h2>
        <p class="section-sub">No retainers, no scope creep, no hidden hourlies. You bring the brand and the words — we handle every part of designing, building, and shipping it.</p>
      </div>

      <div class="offer-bento mv-stagger" data-mv-watch>
        <!-- Centerpiece: the offer + price + CTA -->
        <article class="bento-card bento-headline" data-tilt>
          <span class="tier-sheen" aria-hidden="true"></span>
          <div class="bh-top">
            <span class="bh-eyebrow"><span class="live-dot" aria-hidden="true"></span>The offer</span>
            <span class="bh-meta">~3–4 weeks · up to 8 pages</span>
          </div>
          <div class="bh-body">
            <h3 class="bh-title">Full <em>Site</em></h3>
            <div class="bh-price">
              <span class="bh-dollar">$</span><span class="bh-amount" id="bhAmount" data-target="4000">4,000</span>
            </div>
            <p class="bh-note">Flat fee. Three rounds of revisions. You own everything when we're done.</p>
          </div>
          <div class="bh-foot">
            <a href="/services" class="bh-cta">
              <span>See the full scope</span>
              <span class="arrow" aria-hidden="true">→</span>
            </a>
            <div class="bh-ticker" aria-hidden="true">
              <div class="bh-ticker-track">
                <span>Flat fee</span><span class="dot">●</span>
                <span>No retainers</span><span class="dot">●</span>
                <span>3 revision rounds</span><span class="dot">●</span>
                <span>You own it all</span><span class="dot">●</span>
                <span>Flat fee</span><span class="dot">●</span>
                <span>No retainers</span><span class="dot">●</span>
                <span>3 revision rounds</span><span class="dot">●</span>
                <span>You own it all</span><span class="dot">●</span>
              </div>
            </div>
          </div>
        </article>

        <!-- Feature tiles — each its own spotlight -->
        <article class="bento-card bento-feature" data-tilt>
          <span class="tier-sheen" aria-hidden="true"></span>
          <span class="bf-num">i.</span>
          <h4 class="bf-title">Up to <em>8 pages</em></h4>
          <p class="bf-body">Designed cohesively around your brand and content.</p>
        </article>

        <article class="bento-card bento-feature" data-tilt>
          <span class="tier-sheen" aria-hidden="true"></span>
          <span class="bf-num">ii.</span>
          <h4 class="bf-title">Design <em>system</em></h4>
          <p class="bf-body">Type, color, and components — built to last past launch.</p>
        </article>

        <article class="bento-card bento-feature" data-tilt>
          <span class="tier-sheen" aria-hidden="true"></span>
          <span class="bf-num">iii.</span>
          <h4 class="bf-title">Lead <em>capture</em></h4>
          <p class="bf-body">Forms wired to your inbox the day the site goes live.</p>
        </article>

        <article class="bento-card bento-feature" data-tilt>
          <span class="tier-sheen" aria-hidden="true"></span>
          <span class="bf-num">iv.</span>
          <h4 class="bf-title">Mobile + <em>SEO</em></h4>
          <p class="bf-body">Optimized at every breakpoint, on-page SEO baked in.</p>
        </article>

        <article class="bento-card bento-feature" data-tilt>
          <span class="tier-sheen" aria-hidden="true"></span>
          <span class="bf-num">v.</span>
          <h4 class="bf-title">Hosting + <em>domain</em></h4>
          <p class="bf-body">Set up, connected, and included from launch day.</p>
        </article>

        <article class="bento-card bento-feature" data-tilt>
          <span class="tier-sheen" aria-hidden="true"></span>
          <span class="bf-num">vi.</span>
          <h4 class="bf-title">Handoff <em>doc</em></h4>
          <p class="bf-body">So anyone on your team can update content later.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ PROCESS — alternating stacked layout, large visuals ============ -->
  <section class="section section-process">
    <div class="full">
      <div class="section-head mv-rise" data-mv-watch>
        <span class="section-eyebrow"><span class="section-eyebrow-bar"></span>The process</span>
        <h2 class="display section-title">A simple, <em>honest</em> process.</h2>
        <p class="section-sub">Four steps. About a month, start to live. No long discovery, no kickoff deck, no signed contract for a chat.</p>
      </div>
    </div>

    <ol class="process-list">
      <!-- Step 01 — short call with calendar -->
      <li class="process-step mv-rise" data-mv-watch>
        <div class="full process-step-inner">
          <div class="ps-text">
            <span class="ps-step">
              <span class="ps-glyph">i.</span>
              Step 01
            </span>
            <div class="ps-text-body">
              <h3 class="ps-title">A short call.</h3>
              <p class="ps-body">15 minutes. We learn about your work, who you serve, and what you'd like the site to do for you.</p>
              <span class="ps-meta">— No prep required</span>
            </div>
          </div>
          <div class="ps-visual" aria-hidden="true">
            <div class="ps-visual-frame ps-frame-call">
              <div class="ps-cal">
                <div class="ps-cal-head">
                  <div class="ps-cal-head-l">
                    <span class="ps-cal-eyebrow">Pick a time that works</span>
                    <h4 class="ps-cal-month">May 2026</h4>
                  </div>
                  <span class="ps-cal-pill">15 MIN · INTRO</span>
                </div>
                <div class="ps-cal-dow"><span>S</span><span>M</span><span>T</span><span>W</span><span>T</span><span>F</span><span>S</span></div>
                <div class="ps-cal-grid">
                  <span class="off">26</span><span class="off">27</span><span class="off">28</span><span class="off">29</span><span class="off">30</span><span>1</span><span>2</span>
                  <span>3</span><span class="avail">4</span><span class="avail">5</span><span>6</span><span class="avail">7</span><span class="avail">8</span><span>9</span>
                  <span>10</span><span class="avail">11</span><span>12</span><span class="avail">13</span><span class="avail picked">14</span><span class="avail">15</span><span>16</span>
                  <span>17</span><span>18</span><span class="avail">19</span><span class="avail">20</span><span class="avail">21</span><span>22</span><span>23</span>
                  <span>24</span><span class="avail">25</span><span class="avail">26</span><span>27</span><span class="avail">28</span><span class="avail">29</span><span>30</span>
                  <span>31</span><span class="off">1</span><span class="off">2</span><span class="off">3</span><span class="off">4</span><span class="off">5</span><span class="off">6</span>
                </div>
                <div class="ps-cal-foot">
                  <div class="ps-cal-slot">
                    <span class="ps-cal-slot-dot"></span>
                    <div class="ps-cal-slot-meta">
                      <span class="ps-cal-slot-day">Thursday, May 14</span>
                      <span class="ps-cal-slot-time">2:00 PM EST</span>
                    </div>
                    <span class="ps-cal-slot-cta">Confirmed →</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </li>

      <!-- Step 02 — design draft (dark) -->
      <li class="process-step process-step-dark mv-rise" data-mv-watch>
        <div class="full process-step-inner">
          <div class="ps-text">
            <span class="ps-step">
              <span class="ps-glyph">ii.</span>
              Step 02
            </span>
            <div class="ps-text-body">
              <h3 class="ps-title">Design draft <em>in your browser</em>.</h3>
              <p class="ps-body">A first version, built around your brand and content. You see real layouts in a real browser — not Figma squiggles, not mockup screenshots.</p>
              <span class="ps-meta">— Delivered in week one</span>
            </div>
          </div>
          <div class="ps-visual" aria-hidden="true">
            <div class="ps-visual-frame ps-frame-draft">
              <div class="ps-draft">
                <div class="ps-draft-chrome">
                  <div class="ps-draft-dots"><span></span><span></span><span></span></div>
                  <div class="ps-draft-url"><span class="ps-draft-lock"></span>draft.fwddesignconsulting.com</div>
                  <span class="ps-draft-tag">DRAFT · V1</span>
                </div>
                <div class="ps-draft-body">
                  <div class="ps-draft-nav">
                    <div class="ps-draft-logo"></div>
                    <div class="ps-draft-links"><span></span><span></span><span></span><span></span></div>
                    <div class="ps-draft-navcta"></div>
                  </div>
                  <div class="ps-draft-hero">
                    <div class="ps-draft-eye"></div>
                    <div class="ps-draft-h1"></div>
                    <div class="ps-draft-h1 w2"></div>
                    <div class="ps-draft-lede"></div>
                    <div class="ps-draft-lede short"></div>
                    <div class="ps-draft-cta mv-sweep"></div>
                  </div>
                  <div class="ps-draft-cards">
                    <div class="ps-draft-card"><span></span><span class="sm"></span></div>
                    <div class="ps-draft-card"><span></span><span class="sm"></span></div>
                    <div class="ps-draft-card"><span></span><span class="sm"></span></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </li>

      <!-- Step 03 — revisions with margin comments -->
      <li class="process-step mv-rise" data-mv-watch>
        <div class="full process-step-inner">
          <div class="ps-text">
            <span class="ps-step">
              <span class="ps-glyph">iii.</span>
              Step 03
            </span>
            <div class="ps-text-body">
              <h3 class="ps-title">A round of <em>revisions</em>.</h3>
              <p class="ps-body">One or two rounds depending on tier. Comments in the margin, edits the same week. We adjust until it feels right, then lock it.</p>
              <span class="ps-meta">— Async, on your time</span>
            </div>
          </div>
          <div class="ps-visual" aria-hidden="true">
            <div class="ps-visual-frame ps-frame-rev">
              <div class="ps-rev">
                <div class="ps-rev-doc">
                  <div class="ps-rev-doc-head">
                    <span class="ps-rev-doc-tab">draft.fwddesignconsulting.com</span>
                    <span class="ps-rev-doc-saved">Saved · 2m ago</span>
                  </div>
                  <div class="ps-rev-doc-body">
                    <div class="ps-rev-eye"></div>
                    <div class="ps-rev-h"></div>
                    <div class="ps-rev-line" style="width:98%"></div>
                    <div class="ps-rev-line edit" style="width:92%"><span class="ps-rev-caret"></span></div>
                    <div class="ps-rev-line struck" style="width:82%"></div>
                    <div class="ps-rev-line added" style="width:95%"></div>
                    <div class="ps-rev-line" style="width:88%"></div>
                    <div class="ps-rev-line" style="width:73%"></div>
                    <div class="ps-rev-h sub" style="width:44%"></div>
                    <div class="ps-rev-line" style="width:96%"></div>
                    <div class="ps-rev-line" style="width:99%"></div>
                    <div class="ps-rev-line" style="width:90%"></div>
                    <div class="ps-rev-line" style="width:97%"></div>
                    <div class="ps-rev-line" style="width:64%"></div>
                  </div>
                </div>
                <div class="ps-rev-comments">
                  <div class="ps-rev-comment">
                    <div class="ps-rev-avatar">J</div>
                    <div class="ps-rev-bubble">
                      <div class="ps-rev-meta"><span class="ps-rev-name">Jess</span><span class="ps-rev-time">2m</span></div>
                      <div class="ps-rev-text">Punchier headline?</div>
                    </div>
                  </div>
                  <div class="ps-rev-comment offset">
                    <div class="ps-rev-avatar alt">F</div>
                    <div class="ps-rev-bubble">
                      <div class="ps-rev-meta"><span class="ps-rev-name">forward</span><span class="ps-rev-time">just now</span></div>
                      <div class="ps-rev-text">Updated ✓</div>
                    </div>
                  </div>
                  <div class="ps-rev-comment">
                    <div class="ps-rev-avatar">J</div>
                    <div class="ps-rev-bubble">
                      <div class="ps-rev-meta"><span class="ps-rev-name">Jess</span><span class="ps-rev-time">now</span></div>
                      <div class="ps-rev-text">Perfect — lock it in.</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </li>

      <!-- Step 04 — launch / live (dark) -->
      <li class="process-step process-step-dark mv-rise" data-mv-watch>
        <div class="full process-step-inner">
          <div class="ps-text">
            <span class="ps-step">
              <span class="ps-glyph">iv.</span>
              Step 04
            </span>
            <div class="ps-text-body">
              <h3 class="ps-title">Launch.</h3>
              <p class="ps-body">We connect your domain, set up hosting, and hand over a clean doc you can actually read. Live the same day.</p>
              <span class="ps-meta">— Up in minutes, not weeks</span>
            </div>
          </div>
          <div class="ps-visual" aria-hidden="true">
            <div class="ps-visual-frame ps-frame-launch">
              <div class="ps-launch">
                <div class="ps-launch-bar-top">
                  <span class="ps-launch-lock"></span>
                  <span class="ps-launch-domain">https://<strong>fwddesignconsulting.com</strong></span>
                  <span class="ps-launch-live"><span class="ps-launch-live-dot"></span>LIVE</span>
                </div>
                <div class="ps-launch-log">
                  <div class="ps-launch-row done"><span class="ps-launch-check">✓</span><span class="ps-launch-step">DNS propagated</span><span class="ps-launch-time">0.4s</span></div>
                  <div class="ps-launch-row done"><span class="ps-launch-check">✓</span><span class="ps-launch-step">SSL certificate issued</span><span class="ps-launch-time">1.2s</span></div>
                  <div class="ps-launch-row done"><span class="ps-launch-check">✓</span><span class="ps-launch-step">CDN edge cache warm</span><span class="ps-launch-time">0.8s</span></div>
                  <div class="ps-launch-row done"><span class="ps-launch-check">✓</span><span class="ps-launch-step">Handoff doc delivered</span><span class="ps-launch-time">—</span></div>
                  <div class="ps-launch-row active"><span class="ps-launch-check pulse"></span><span class="ps-launch-step">Listening for visitors</span><span class="ps-launch-time">live</span></div>
                </div>
                <div class="ps-launch-foot">
                  <div class="ps-launch-stat"><span class="ps-launch-stat-n">99.99%</span><span class="ps-launch-stat-l">uptime · last 30 days</span></div>
                  <div class="ps-launch-stat"><span class="ps-launch-stat-n">A+</span><span class="ps-launch-stat-l">SSL Labs grade</span></div>
                  <div class="ps-launch-stat"><span class="ps-launch-stat-n">98</span><span class="ps-launch-stat-l">Lighthouse score</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </li>
    </ol>
  </section>

  
  <section class="cta-band-light mv-soften" data-mv-watch aria-labelledby="home-cta-title">
    <div class="cta-band-light-bg" aria-hidden="true"></div>
    <div class="cta-band-light-inner">
      <h2 id="home-cta-title" class="display cta-band-light-title">Got a practice, a product, or a <em>side project</em>?</h2>
      <div class="cta-band-light-side">
        <p class="cta-band-light-lede">Tell us about it. We reply to every inquiry — usually within a day.</p>
        <a href="/contact" class="btn btn-primary cta-band-light-btn">
          Start a project <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.hero-outer { position: relative; min-height: calc(100vh - 100px); display: flex; align-items: stretch; }
  .hero { display: grid; grid-template-columns: 1fr 1.15fr; width: 100%; align-items: stretch; gap: clamp(2rem, 4vw, 4rem); }
  /* Padding lives on the text column so the showcase column (with its grid
     background) can run flush to the section's top and bottom edges. */
  .hero-left { display: flex; flex-direction: column; gap: 1.75rem; padding-left: var(--pad-x); padding-block: clamp(2rem, 5vh, 4rem) clamp(3rem, 7vh, 5rem); justify-content: center; }
  .hero-eyebrow { display: inline-flex; align-items: center; gap: 12px; font-family: var(--font-mono); font-size: var(--text-step--2); letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-fg-muted); }
  .hero-eyebrow .bar { width: 24px; height: 1px; background: var(--color-periwinkle); }
  .hero-title { font-size: var(--text-step-6); margin: 0; max-width: 14ch; }
  .hero-lede { margin: 0; font-size: var(--text-step-3); font-family: var(--font-display); font-weight: 300; font-style: italic; color: var(--color-fg-soft); font-variation-settings: "opsz" 96; letter-spacing: -0.015em; line-height: 1.15; }
  .hero-lede em { font-style: italic; color: var(--color-blue); font-variation-settings: "opsz" 96; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* Right column is now the HeroShowcase component, which owns its own
     gridded panel + browser styling. This is just the stretch wrapper. */
  .hero-right { display: flex; align-self: stretch; }

  .marquee { border-block: 1px solid var(--color-line); background: var(--color-paper); overflow: hidden; padding: 22px 0; }
  .marquee-track { display: flex; width: max-content; animation: marquee 60s linear infinite; }
  .marquee:hover .marquee-track { animation-play-state: paused; }
  .marquee-row { display: flex; gap: 44px; padding-inline: 22px; white-space: nowrap; }
  .marquee-item { font-family: var(--font-display); font-style: italic; font-weight: 350; font-size: var(--text-step-3); letter-spacing: -0.02em; color: var(--color-fg); font-variation-settings: "opsz" 144; display: inline-flex; align-items: center; gap: 22px; }
  .marquee-dot { color: var(--color-periwinkle); font-style: normal; font-size: 0.5em; }
  @keyframes marquee { to { transform: translateX(-50%); } }

  .meta-strip { background: var(--color-bg-soft); border-bottom: 1px solid var(--color-line); padding-block: clamp(2rem, 4vh, 3.5rem); }
  .meta-strip-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.25rem 2.5rem; }
  .meta-cell { display: flex; flex-direction: column; gap: 0.35rem; }
  .meta-key { font-family: var(--font-mono); font-size: var(--text-step--2); letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-fg-muted); }
  .meta-val { font-family: var(--font-display); font-weight: 400; font-size: var(--text-step-1); font-variation-settings: "opsz" 60; color: var(--color-fg); letter-spacing: -0.01em; }

  .section-head { display: grid; gap: 1rem; grid-template-columns: 1fr; align-items: end; margin-bottom: 3rem; }
  @media (min-width: 760px) { .section-head { grid-template-columns: 1fr 1.1fr; gap: 3rem; } }
  .section-title { font-size: var(--text-step-4); max-width: 18ch; margin: 0; }
  .section-sub { color: var(--color-fg-soft); max-width: 50ch; font-size: var(--text-step-1); margin: 0; text-wrap: pretty; }

  /* ============================================================
     SERVICES — bento spec sheet. The single offer becomes an
     editorial composition: a dark centerpiece (price + CTA) and
     six annotation tiles, each with its own mouse-spotlight sheen.
     ============================================================ */
  .section-offer { padding-block: clamp(6rem, 11vh, 9rem); }
  .section-offer .section-head { margin-bottom: clamp(2.5rem, 5vh, 4rem); }

  .offer-bento {
    display: grid;
    grid-template-columns: 1fr;
    grid-auto-rows: minmax(0, auto);
    gap: 1rem;
  }
  @media (min-width: 760px) {
    .offer-bento {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }
  @media (min-width: 1000px) {
    .offer-bento {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(3, minmax(180px, 1fr));
      gap: 1.5rem;
    }
  }

  /* Shared card chassis — same sheen mechanic the tier cards use,
     hoisted so each bento tile gets its own spotlight on hover. */
  .bento-card {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    --bg: #fff;
    --fg: var(--color-navy);
    --fg-soft: var(--color-fg-soft);
    --fg-muted: var(--color-fg-muted);
    --line: var(--color-line);
    --accent: var(--color-blue);
    --sheen: rgb(13 47 69 / 0.10);
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--line);
    border-radius: 14px;
    transition: transform 360ms var(--ease-soft), box-shadow 360ms var(--ease-soft), border-color 360ms var(--ease-soft);
  }
  .bento-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 30px 60px -28px rgb(7 23 34 / 0.28);
  }
  .bento-card .tier-sheen {
    position: absolute; inset: 0;
    pointer-events: none; z-index: 0;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 360ms var(--ease-soft);
    background: radial-gradient(260px circle at var(--mx, 50%) var(--my, 50%), var(--sheen), transparent 60%);
  }
  .bento-card:hover .tier-sheen { opacity: 1; }
  .bento-card > :not(.tier-sheen) { position: relative; z-index: 1; }

