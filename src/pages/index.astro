---
// Auto-generated from site/index.html — round 4 design.
// Edit page-level markup here; shared components live in src/components.
import BaseLayout from "../layouts/BaseLayout.astro";
import Marquee from "../components/Marquee.astro";
---

<BaseLayout title="fwd. — Websites that earn their place online">
<!-- ============ HERO with idle motion baked in ============ -->
  <section class="hero-outer" id="heroOuter">
    <div class="hero">
      <div class="hero-left">
        <h1 class="display hero-title">Your website is your new <em>storefront</em>.</h1>
        <p class="lede hero-lede">Give it the <em>respect</em> it deserves.</p>
        <div class="hero-actions">
          <a href="/services" class="btn btn-primary">See services <span class="arrow">→</span></a>
          <a href="/contact" class="btn btn-ghost">Start a project</a>
        </div>
      </div>

      <div class="hero-right" aria-hidden="true">
        <div class="browser">
          <div class="browser-chrome">
            <div class="dots">
              <span style="background:#FF6058"></span><span style="background:#FFBE2E"></span><span style="background:#28C940"></span>
            </div>
            <div class="urlbar"><span class="lock">●</span><span class="url" id="heroUrl">localhost:4321</span></div>
            <div class="stage-pill" id="heroStagePill">01 · Blank canvas</div>
          </div>
          <div class="browser-body">
            <div class="grid-bg" id="gridBg"></div>
            <div class="wf-row" id="wfRow1"><div class="wf-h1"></div></div>
            <div class="wf-row narrow" id="wfRow2">
              <div class="wf-line" style="width:78%"></div>
              <div class="wf-line" style="width:62%"></div>
            </div>
            <div class="wf-grid" id="wfGrid">
              <div class="wf-block tall"></div>
              <div class="wf-stack">
                <div class="wf-line" style="width:85%"></div>
                <div class="wf-line" style="width:70%"></div>
                <div class="wf-line" style="width:55%"></div>
                <div class="wf-pill"></div>
              </div>
            </div>
            <div class="content-layer" id="contentLayer">
              <div class="ct-eyebrow">— Family dentistry · Irvine, CA</div>
              <div class="ct-h1">A calmer kind of <em>dental visit</em>.</div>
              <div class="ct-lede">Same-day appointments, gentle care, and a team that actually remembers your name.</div>
            </div>
            <div class="polish-layer" id="polishLayer">
              <div class="pl-image">
                <div class="pl-image-grad"></div>
                <div class="pl-image-tag">[ studio photo ]</div>
              </div>
              <div class="pl-cta" id="plCta">Book a visit <span aria-hidden="true">→</span></div>
              <div class="pl-hours">
                <div><span><span class="live-dot"></span>Mon–Thu</span><strong>8a — 6p</strong></div>
                <div><span>Fri</span><strong>8a — 2p</strong></div>
                <div><span>Sat–Sun</span><strong>Closed</strong></div>
              </div>
              <div class="pl-stat">
                <strong id="plStatNum">0</strong>
                <span>booked this month</span>
              </div>
            </div>
          </div>
          <div class="browser-foot">
            <span class="foot-label" id="heroFootLabel">building…</span>
            <div class="track">
              <div class="fill" id="heroFill"></div>
              <div class="tick" data-pct="0" style="left:0%"></div>
              <div class="tick" data-pct="0.2" style="left:20%"></div>
              <div class="tick" data-pct="0.42" style="left:42%"></div>
              <div class="tick" data-pct="0.66" style="left:66%"></div>
              <div class="tick" data-pct="0.88" style="left:88%"></div>
            </div>
            <span class="foot-label right" id="heroPct">0%</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ MARQUEE (reverted to original phrase Marquee component) ============ -->
  <Marquee />

  <!-- ============ HERO META STRIP ============ -->
  <section class="meta-strip">
    <div class="full">
      <div class="meta-strip-grid mv-stagger" data-mv-watch>
        <div class="meta-cell">
          <span class="meta-key">Studio size</span>
          <strong class="meta-val">Three partners</strong>
        </div>
        <div class="meta-cell">
          <span class="meta-key">Typical turnaround</span>
          <strong class="meta-val">About 4 weeks</strong>
        </div>
        <div class="meta-cell">
          <span class="meta-key">Pricing model</span>
          <strong class="meta-val">Flat fee, no retainers</strong>
        </div>
        <div class="meta-cell">
          <span class="meta-key">Hosting &amp; domain</span>
          <strong class="meta-val">Set up &amp; included</strong>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SERVICES preview ============ -->
  <section id="services" class="section section-tiers">
    <div class="full">
      <div class="section-head mv-rise" data-mv-watch>
        <h2 class="display section-title">One way to <em>get online</em>.</h2>
        <p class="section-sub">A flat-rate full website. You bring the brand and the words; we handle every part of designing, building, and shipping it.</p>
      </div>
      <div class="tiers-grid tiers-grid-single mv-stagger" data-mv-watch>
        <article class="tier tier-dark" data-tilt>
          <span class="tier-sheen" aria-hidden="true"></span>
          <div class="tier-top"><span class="tier-deliv">~3–4 weeks · up to 8 pages</span></div>
          <h3 class="tier-title">Full Site</h3>
          <div class="tier-price">
            <span class="dollar">$</span>
            <span class="amount">4,000</span>
            <span class="note">flat · three rounds of revisions</span>
          </div>
          <ul class="tier-features">
            <li><span class="check">✓</span>Up to 8 pages, designed cohesively around your brand</li>
            <li><span class="check">✓</span>Cohesive type, color, and component system</li>
            <li><span class="check">✓</span>Lead capture form with instant email notifications</li>
            <li><span class="check">✓</span>Mobile and desktop optimized, basic on-page SEO</li>
            <li><span class="check">✓</span>Hosting setup and domain connection included</li>
            <li><span class="check">✓</span>Handoff doc so you (or anyone) can update content later</li>
          </ul>
          <a href="/services" class="tier-cta">See the full scope <span class="arrow">→</span></a>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ PROCESS — each step has a graphic now ============ -->
  <section class="section section-process">
    <div class="full">
      <div class="section-head mv-rise" data-mv-watch>
        <h2 class="display section-title">A simple, <em>honest</em> process.</h2>
        <p class="section-sub">Four steps. About a month, start to live. No long discovery, no kickoff deck, no signed contract for a chat.</p>
      </div>
    </div>

    <ol class="process-list">
      <!-- Step 01 — short call with animated calendar -->
      <li class="process-step mv-rise" data-mv-watch>
        <div class="full process-step-inner">
          <span class="ps-step">
            <span class="ps-glyph">i.</span>
            Step 01
          </span>
          <div>
            <h3 class="ps-title">A short call</h3>
            <p class="ps-body">15 minutes. We learn about your work, who you serve, and what you'd like the site to do for you.<span class="ps-meta">— No prep required</span></p>
          </div>
          <div class="ps-visual" aria-hidden="true">
            <div class="ps-visual-frame">
              <div class="ps-visual-call">
                <div class="ps-visual-call-h"><span class="month">May 2026</span><span>15 min</span></div>
                <div class="ps-visual-call-grid">
                  <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span class="slot"></span><span class="picked"></span><span></span><span></span><span></span><span></span><span></span><span class="slot"></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </li>

      <!-- Step 02 — design draft (dark, same size as the others) -->
      <li class="process-step process-step-dark mv-rise" data-mv-watch>
        <div class="full process-step-inner">
          <span class="ps-step">
            <span class="ps-glyph">ii.</span>
            Step 02
          </span>
          <div>
            <h3 class="ps-title">Design draft <em>in your browser</em>.</h3>
            <p class="ps-body">A first version, built around your brand and content. You see real layouts in a real browser — not Figma squiggles, not mockup screenshots.<span class="ps-meta">— Delivered in week one</span></p>
          </div>
          <div class="ps-visual" aria-hidden="true">
            <div class="ps-visual-frame">
              <div class="mini-browser ps-mini">
                <div class="mini-chrome">
                  <div class="mini-dots"><span></span><span></span><span></span></div>
                  <div class="mini-url">draft.smithdental.com</div>
                </div>
                <div class="mini-body">
                  <div class="mini-h1"></div>
                  <div class="mini-line w-80"></div>
                  <div class="mini-line w-65"></div>
                  <div class="mini-line w-50"></div>
                  <div class="mini-pill mv-sweep"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </li>

      <!-- Step 03 — revisions with redline markup -->
      <li class="process-step mv-rise" data-mv-watch>
        <div class="full process-step-inner">
          <span class="ps-step">
            <span class="ps-glyph">iii.</span>
            Step 03
          </span>
          <div>
            <h3 class="ps-title">Revisions</h3>
            <p class="ps-body">One or two rounds depending on tier. We adjust until it feels right, then lock it.<span class="ps-meta">— Async, on your time</span></p>
          </div>
          <div class="ps-visual" aria-hidden="true">
            <div class="ps-visual-frame">
              <div class="ps-visual-revisions">
                <div class="ps-revision-line" style="width:90%"></div>
                <div class="ps-revision-line with-comment" style="width:75%"></div>
                <div class="ps-revision-line struck"></div>
                <div class="ps-revision-line" style="width:85%"></div>
                <div class="ps-revision-line with-comment" style="width:55%"></div>
                <div class="ps-revision-line" style="width:70%"></div>
                <div class="ps-revision-arrow">↵</div>
              </div>
            </div>
          </div>
        </div>
      </li>

      <!-- Step 04 — launch / live (dark) -->
      <li class="process-step process-step-dark mv-rise" data-mv-watch>
        <div class="full process-step-inner">
          <span class="ps-step">
            <span class="ps-glyph">iv.</span>
            Step 04
          </span>
          <div>
            <h3 class="ps-title">Launch</h3>
            <p class="ps-body">We connect your domain, set up hosting, and hand over a clean handoff doc you can actually read.<span class="ps-meta">— Live the same day</span></p>
          </div>
          <div class="ps-visual" aria-hidden="true">
            <div class="ps-visual-frame">
              <div class="ps-visual-launch">
                <div class="ps-launch-url"><span class="lock"></span>https://smithdental.com</div>
                <div class="ps-launch-bars">
                  <div class="ps-launch-bar"></div>
                  <div class="ps-launch-bar"></div>
                  <div class="ps-launch-bar"></div>
                </div>
                <div class="ps-launch-status">DNS · cert · live</div>
              </div>
            </div>
          </div>
        </div>
      </li>
    </ol>
  </section>

  
  <section class="cta-band-light mv-soften" data-mv-watch aria-labelledby="home-cta-title">
    <div class="cta-band-light-bg" aria-hidden="true"></div>
    <div class="cta-band-light-inner">
      <h2 id="home-cta-title" class="display cta-band-light-title">Got a practice, a product, or a <em>side project</em>?</h2>
      <div class="cta-band-light-side">
        <p class="cta-band-light-lede">Tell us about it. We reply to every inquiry — usually within a day.</p>
        <a href="/contact" class="btn btn-primary cta-band-light-btn">
          Start a project <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.hero-outer { position: relative; min-height: calc(100vh - 100px); display: flex; align-items: center; padding-block: clamp(2rem, 5vh, 4rem) clamp(3rem, 7vh, 5rem); }
  .hero { display: grid; grid-template-columns: 1fr 1.15fr; width: 100%; align-items: center; gap: clamp(2rem, 4vw, 4rem); }
  .hero-left { display: flex; flex-direction: column; gap: 1.75rem; padding-left: var(--pad-x); justify-content: center; }
  .hero-eyebrow { display: inline-flex; align-items: center; gap: 12px; font-family: var(--font-mono); font-size: var(--text-step--2); letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-fg-muted); }
  .hero-eyebrow .bar { width: 24px; height: 1px; background: var(--color-periwinkle); }
  .hero-title { font-size: var(--text-step-6); margin: 0; max-width: 14ch; }
  .hero-lede { margin: 0; font-size: var(--text-step-3); font-family: var(--font-display); font-weight: 300; font-style: italic; color: var(--color-fg-soft); font-variation-settings: "opsz" 96; letter-spacing: -0.015em; line-height: 1.15; }
  .hero-lede em { font-style: italic; color: var(--color-blue); font-variation-settings: "opsz" 96; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  .hero-right { position: relative; background: linear-gradient(160deg, #f6f6f8 0%, #eceef5 100%); border-left: 1px solid var(--color-line); display: flex; align-items: center; justify-content: center; padding: clamp(2rem, 5vh, 4rem) clamp(1rem, 3vw, 3rem); overflow: hidden; align-self: stretch; min-height: clamp(560px, 70vh, 760px); }
  .hero-right::before { content: ""; position: absolute; inset: 0; background-image: linear-gradient(rgba(13,47,69,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(13,47,69,0.06) 1px, transparent 1px); background-size: 38px 38px; -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 80%); mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 80%); pointer-events: none; }

  .browser { width: min(820px, 100%); background: #fff; border-radius: 14px; border: 1px solid var(--color-line); box-shadow: 0 60px 120px -40px rgb(7 23 34 / 0.40), 0 16px 36px -14px rgb(7 23 34 / 0.20); overflow: hidden; position: relative; z-index: 1; }
  .browser-chrome { display: flex; align-items: center; gap: 14px; padding: 14px 18px; background: #f5f6f8; border-bottom: 1px solid var(--color-line); }
  .dots { display: flex; gap: 7px; }
  .dots span { width: 12px; height: 12px; border-radius: 50%; }
  .urlbar { flex: 1; height: 30px; border-radius: 7px; background: #fff; border: 1px solid var(--color-line); display: flex; align-items: center; gap: 9px; padding: 0 14px; font-family: var(--font-mono); font-size: 12px; color: var(--color-fg-muted); }
  .urlbar .lock { color: var(--color-blue); font-size: 9px; }
  .stage-pill { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-blue); background: #fff; border: 1px solid var(--color-line); padding: 5px 12px; border-radius: 999px; white-space: nowrap; }
  .browser-body { position: relative; height: clamp(440px, 56vh, 560px); background: #fff; overflow: hidden; }
  .browser-body > * { transition: opacity 600ms cubic-bezier(0.2,0.7,0.2,1), transform 600ms cubic-bezier(0.2,0.7,0.2,1); }
  .grid-bg { position: absolute; inset: 0; background-image: linear-gradient(rgba(13,47,69,0.12) 1px, transparent 1px), linear-gradient(90deg, rgba(13,47,69,0.12) 1px, transparent 1px); background-size: 28px 28px; opacity: 0; }
  .wf-row, .wf-grid { position: relative; padding: 32px 40px; opacity: 0; }
  .wf-row { padding-bottom: 0; }
  .wf-row.narrow { padding-top: 14px; }
  .wf-h1 { height: 56px; width: 60%; background: rgba(13,47,69,0.18); border-radius: 5px; }
  .wf-line { height: 11px; background: rgba(13,47,69,0.14); border-radius: 3px; margin-bottom: 9px; }
  .wf-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 22px; margin-top: 10px; }
  .wf-block.tall { height: 220px; background: repeating-linear-gradient(135deg, rgba(13,47,69,0.12) 0 8px, transparent 8px 16px); border: 1px dashed rgba(13,47,69,0.25); border-radius: 7px; }
  .wf-stack { display: flex; flex-direction: column; gap: 11px; }
  .wf-pill { width: 130px; height: 34px; border-radius: 999px; background: var(--color-periwinkle); margin-top: 8px; }
  .content-layer { position: absolute; inset: 0; padding: 44px 44px 28px; display: flex; flex-direction: column; gap: 14px; background: rgba(255,255,255,0.6); -webkit-backdrop-filter: blur(2px); backdrop-filter: blur(2px); opacity: 0; }
  .ct-eyebrow { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.08em; color: var(--color-fg-muted); }
  .ct-h1 { font-family: var(--font-display); font-size: clamp(2rem, 2.8vw, 2.9rem); font-weight: 350; line-height: 1.05; letter-spacing: -0.02em; color: var(--color-navy); font-variation-settings: "opsz" 144; margin-top: 4px; }
  .ct-h1 em { font-style: italic; color: var(--color-blue); font-variation-settings: "opsz" 144; }
  .ct-lede { font-family: var(--font-display); font-weight: 300; font-size: var(--text-step-1); color: var(--color-fg-soft); max-width: 38ch; line-height: 1.35; }
  .polish-layer { position: absolute; inset: 0; padding: 34px 40px 24px; display: grid; grid-template-columns: 1.4fr 1fr; grid-template-rows: 1fr auto; gap: 18px; background: #fff; opacity: 0; }
  .pl-image { grid-row: 1 / span 2; position: relative; border-radius: 10px; overflow: hidden; background: linear-gradient(135deg, #e8eef3 0%, #c4d2dc 60%, var(--color-periwinkle) 120%); }
  .pl-image-grad { position: absolute; inset: 0; background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.5), transparent 50%), repeating-linear-gradient(45deg, rgba(13,47,69,0.05) 0 4px, transparent 4px 12px); }
  .pl-image-tag { position: absolute; bottom: 12px; left: 14px; font-family: var(--font-mono); font-size: 11px; color: var(--color-fg-muted); background: rgba(255,255,255,0.85); padding: 4px 9px; border-radius: 4px; letter-spacing: 0.04em; }
  .pl-cta { position: relative; align-self: start; justify-self: end; background: var(--color-navy); color: #fff; padding: 11px 38px 11px 20px; border-radius: 999px; font-size: 14px; font-weight: 500; display: inline-flex; align-items: center; gap: 7px; overflow: hidden; isolation: isolate; }
  .pl-cta.live::after { content: ""; position: absolute; inset: 0; width: 60%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.20), transparent); animation: mvSweep 3.2s var(--ease-soft) infinite; z-index: 0; pointer-events: none; }
  .pl-cta > span { position: relative; z-index: 1; }
  .pl-hours { display: flex; flex-direction: column; gap: 7px; font-size: 13px; align-self: end; }
  .pl-hours > div { display: flex; justify-content: space-between; padding: 7px 11px; border-bottom: 1px solid var(--color-line); }
  .pl-hours strong { font-family: var(--font-display); font-weight: 500; font-variation-settings: "opsz" 60; }
  .pl-hours span { color: var(--color-fg-muted); font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; display: inline-flex; align-items: center; }
  .browser-foot { display: flex; align-items: center; gap: 14px; padding: 12px 18px; background: #fafafb; border-top: 1px solid var(--color-line); }
  .foot-label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-fg-muted); }
  .foot-label.right { margin-left: auto; }
  .track { flex: 1; height: 2px; background: rgba(7,23,34,0.08); border-radius: 2px; position: relative; }
  .fill { position: absolute; left: 0; top: 0; height: 100%; background: var(--color-periwinkle); border-radius: 2px; transition: width 120ms linear; width: 0; }
  .tick { position: absolute; top: -2px; width: 6px; height: 6px; border-radius: 50%; transform: translateX(-3px); transition: background 280ms cubic-bezier(0.2,0.7,0.2,1); background: rgba(7,23,34,0.18); }

  .marquee { border-block: 1px solid var(--color-line); background: var(--color-paper); overflow: hidden; padding: 22px 0; }
  .marquee-track { display: flex; width: max-content; animation: marquee 60s linear infinite; }
  .marquee:hover .marquee-track { animation-play-state: paused; }
  .marquee-row { display: flex; gap: 44px; padding-inline: 22px; white-space: nowrap; }
  .marquee-item { font-family: var(--font-display); font-style: italic; font-weight: 350; font-size: var(--text-step-3); letter-spacing: -0.02em; color: var(--color-fg); font-variation-settings: "opsz" 144; display: inline-flex; align-items: center; gap: 22px; }
  .marquee-dot { color: var(--color-periwinkle); font-style: normal; font-size: 0.5em; }
  @keyframes marquee { to { transform: translateX(-50%); } }

  .meta-strip { background: var(--color-bg-soft); border-bottom: 1px solid var(--color-line); padding-block: clamp(2rem, 4vh, 3.5rem); }
  .meta-strip-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.25rem 2.5rem; }
  .meta-cell { display: flex; flex-direction: column; gap: 0.35rem; }
  .meta-key { font-family: var(--font-mono); font-size: var(--text-step--2); letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-fg-muted); }
  .meta-val { font-family: var(--font-display); font-weight: 400; font-size: var(--text-step-1); font-variation-settings: "opsz" 60; color: var(--color-fg); letter-spacing: -0.01em; }

  .section-head { display: grid; gap: 1rem; grid-template-columns: 1fr; align-items: end; margin-bottom: 3rem; }
  @media (min-width: 760px) { .section-head { grid-template-columns: 1fr 1.1fr; gap: 3rem; } }
  .section-title { font-size: var(--text-step-4); max-width: 18ch; margin: 0; }
  .section-sub { color: var(--color-fg-soft); max-width: 50ch; font-size: var(--text-step-1); margin: 0; text-wrap: pretty; }

  /* Pricing section — give it more vertical room so it doesn't feel crowded
     against the marquee above. */
  .section-tiers { padding-block: clamp(6rem, 11vh, 9rem); }
  .section-tiers .section-head { margin-bottom: clamp(3rem, 6vh, 5rem); }

  .tiers-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  .tiers-grid-single { max-width: 720px; margin-inline: auto; }
  @media (min-width: 900px) { .tiers-grid:not(.tiers-grid-single) { grid-template-columns: 1fr 1fr; gap: 2.5rem; } }
