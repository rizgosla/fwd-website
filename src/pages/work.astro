---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const all = await getCollection("work");
const live = all
  .filter((e) => e.data.status === "live")
  .sort((a, b) => a.data.order - b.data.order);
const upcoming = all
  .filter((e) => e.data.status !== "live")
  .sort((a, b) => a.data.order - b.data.order);

const statusLabel = {
  build: "In build",
  design: "In design",
  discovery: "Kickoff",
};
---

<BaseLayout title="Selected work — fwd.">
  <section class="work-hero">
    <img src="/assets/fwd-logo.svg" alt="" aria-hidden="true" class="work-hero-stamp" />
    <div class="full work-hero-inner">
      <div data-mv-watch class="mv-rise work-hero-text">
        <p class="work-hero-eyebrow">
          <span class="num">— 03</span>
          <span>Selected work</span>
        </p>
        <h1 class="display work-hero-title">A small studio. <em>Real projects</em>.</h1>
        <p class="lede work-hero-lede">Every site we ship gets a short write-up — what we built, why, and how it performed once it went live. New entries land as projects launch.</p>
      </div>
      <ul class="work-hero-stats">
        <li><strong>{live.length.toString().padStart(2, "0")}</strong><span>Launched</span></li>
        <li><strong>{upcoming.length.toString().padStart(2, "0")}</strong><span>In production</span></li>
        <li><strong>100%</strong><span>Flat-fee</span></li>
        <li><strong>2026</strong><span>Studio year</span></li>
      </ul>
    </div>
  </section>

  {live.length > 0 && (
    <section class="section section-work-grid">
      <div class="full">
        <div class="section-head mv-rise" data-mv-watch>
          <h2 class="display section-title">Launched <em>projects</em>.</h2>
          <p class="section-sub">Tap any card to read the full case study — brief, approach, results, and a process recap.</p>
        </div>

        <ul class="work-grid mv-stagger" data-mv-watch>
          {live.map((entry) => (
            <li class="work-card">
              <a href={`/work/${entry.id}`} class="work-card-link">
                <span class="work-card-stripe" aria-hidden="true"></span>
                <div class="work-card-body">
                  <div class="work-card-meta">
                    {entry.data.industry && <span>{entry.data.industry}</span>}
                    {entry.data.location && <span class="sep" aria-hidden="true">·</span>}
                    {entry.data.location && <span>{entry.data.location}</span>}
                  </div>
                  <h3 class="work-card-title">{entry.data.title}</h3>
                  <p class="work-card-summary">{entry.data.summary}</p>
                  {entry.data.results.length > 0 && (
                    <dl class="work-card-results">
                      {entry.data.results.slice(0, 2).map((r) => (
                        <div>
                          <dt>{r.label}</dt>
                          <dd>{r.value}</dd>
                        </div>
                      ))}
                    </dl>
                  )}
                </div>
                <div class="work-card-foot">
                  <span class="work-card-scope">{entry.data.scope} · ${entry.data.price.toLocaleString()}</span>
                  <span class="work-card-cta">Read case study <span class="arrow" aria-hidden="true">→</span></span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {upcoming.length > 0 && (
    <section class="section section-upcoming" id="next">
      <div class="full">
        <div class="section-head mv-rise" data-mv-watch>
          <h2 class="display section-title">In <em>production</em>.</h2>
          <p class="section-sub">We keep the studio small on purpose — three to four projects a quarter, fully shipped, then written up like the ones above.</p>
        </div>

        <ul class="pipeline-grid mv-stagger" data-mv-watch>
          {upcoming.map((entry) => (
            <li class="pipeline-card">
              <div class="pipeline-header">
                <span class="pipeline-status">
                  <span class={`pipeline-dot pipeline-dot-${entry.data.status}`} aria-hidden="true"></span>
                  {statusLabel[entry.data.status as "build" | "design" | "discovery"]}
                </span>
                {entry.data.launchesIn && <span class="pipeline-eta">Launches {entry.data.launchesIn}</span>}
              </div>
              <h3 class="pipeline-title">{entry.data.title}</h3>
              <p class="pipeline-desc">{entry.data.summary}</p>
              <span class="pipeline-meta">{entry.data.scope} · ${entry.data.price.toLocaleString()}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="section section-note">
    <div class="full">
      <div class="container-prose note-inner mv-stagger" data-mv-watch>
        <p class="eyebrow"><span>A note on this page</span></p>
        <h2 class="display note-h">Real projects, written up <em>as they ship</em>.</h2>
        <p class="note-body">When we started fwd. we agreed we would never show work that was not ours, and we would never dress up a placeholder to look like a case study. So this page fills up slowly — one careful project at a time.</p>
        <p class="note-body">If you would like the next slot, the <a class="link-arrow" href="/services">services page<span class="arrow">→</span></a> has the scope and the price, and the <a class="link-arrow" href="/contact">contact form<span class="arrow">→</span></a> takes a minute.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .work-hero {
    position: relative;
    background: var(--color-paper);
    padding-block: clamp(4rem, 11vh, 8rem) clamp(3rem, 7vh, 5rem);
    border-bottom: 1px solid var(--color-line);
    overflow: hidden;
  }
  .work-hero::before {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-line-strong), transparent);
  }
  .work-hero-stamp {
    position: absolute;
    top: clamp(2rem, 5vh, 4rem);
    right: var(--pad-x);
    height: clamp(60px, 8vw, 110px);
    width: auto;
    opacity: 0.25;
    pointer-events: none;
  }
  .work-hero-inner {
    position: relative; z-index: 1;
    display: flex; flex-direction: column;
    gap: clamp(3rem, 7vh, 5rem);
  }
  .work-hero-text { text-align: center; max-width: 60ch; margin-inline: auto; }
  .work-hero-eyebrow {
    display: inline-flex; align-items: center; gap: 0.75rem;
    margin: 0 0 2rem;
    font-family: var(--font-mono); font-size: var(--text-step--2);
    letter-spacing: 0.22em; text-transform: uppercase; color: var(--color-fg-muted);
  }
  .work-hero-eyebrow .num { color: var(--color-blue); font-weight: 500; }
  .work-hero-title {
    font-size: var(--text-step-5); margin: 0; line-height: 1;
    letter-spacing: -0.03em; color: var(--color-navy);
    max-width: 18ch; margin-inline: auto; text-wrap: balance;
  }
  .work-hero-title em { font-style: italic; color: var(--color-blue); }
  .work-hero-lede {
    margin: 1.75rem auto 0; color: var(--color-fg-soft);
    max-width: 50ch; font-size: var(--text-step-1);
  }
  .work-hero-stats {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(2, 1fr);
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }
  @media (min-width: 720px) {
    .work-hero-stats { grid-template-columns: repeat(4, 1fr); }
  }
  .work-hero-stats li {
    display: flex; flex-direction: column; gap: 0.35rem;
    padding: 1.5rem clamp(1rem, 2.5vw, 2rem);
    border-right: 1px solid var(--color-line);
  }
  .work-hero-stats li:last-child { border-right: 0; }
  @media (max-width: 719px) {
    .work-hero-stats li:nth-child(2) { border-right: 0; }
    .work-hero-stats li:nth-child(-n+2) { border-bottom: 1px solid var(--color-line); }
  }
  .work-hero-stats strong {
    font-family: var(--font-display); font-weight: 400;
    font-size: var(--text-step-4); letter-spacing: -0.025em;
    color: var(--color-navy); line-height: 1;
    font-variation-settings: "opsz" 144;
  }
  .work-hero-stats span {
    font-family: var(--font-mono); font-size: var(--text-step--2);
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--color-fg-muted);
  }

  .section-head { display: grid; gap: 1rem; grid-template-columns: 1fr; align-items: end; margin-bottom: 2.25rem; }
  @media (min-width: 760px) { .section-head { grid-template-columns: 1fr 1.1fr; gap: 3rem; } }
  .section-title { font-size: var(--text-step-4); max-width: 18ch; margin: 0; }
  .section-sub { color: var(--color-fg-soft); max-width: 50ch; font-size: var(--text-step-1); margin: 0; text-wrap: pretty; }

  /* ---------- launched grid ---------- */
  .work-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 360px), 1fr));
  }
  .work-card { display: flex; }
  .work-card-link {
    flex: 1;
    display: flex; flex-direction: column;
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 280ms var(--ease-soft), transform 280ms var(--ease-soft), box-shadow 280ms var(--ease-soft);
  }
  .work-card-link:hover,
  .work-card-link:focus-visible {
    border-color: var(--color-navy);
    transform: translateY(-2px);
    box-shadow: 0 24px 50px -28px rgb(7 23 34 / 0.30);
  }
  .work-card-link:focus-visible { outline: 2px solid var(--color-blue); outline-offset: 3px; }
  .work-card-stripe {
    height: 6px;
    background: linear-gradient(90deg, var(--color-blue), var(--color-periwinkle));
  }
  .work-card-body {
    padding: 1.75rem 1.75rem 1.5rem;
    display: flex; flex-direction: column;
    gap: 1rem;
    flex: 1;
  }
  .work-card-meta {
    display: flex; flex-wrap: wrap; gap: 0.5rem;
    font-family: var(--font-mono); font-size: var(--text-step--2);
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--color-fg-muted);
  }
  .work-card-meta .sep { color: var(--color-line-strong); }
  .work-card-title {
    font-family: var(--font-display); font-weight: 400;
    font-size: var(--text-step-3); margin: 0;
    letter-spacing: -0.02em; color: var(--color-navy);
    font-variation-settings: "opsz" 144;
    line-height: 1.05;
  }
  .work-card-summary {
    margin: 0; color: var(--color-fg-soft);
    font-size: var(--text-step-0); line-height: 1.5;
  }
  .work-card-results {
    margin: auto 0 0;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-line);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .work-card-results div { display: flex; flex-direction: column; gap: 0.25rem; }
  .work-card-results dt {
    font-family: var(--font-mono); font-size: var(--text-step--2);
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--color-fg-muted);
  }
  .work-card-results dd {
    margin: 0;
    font-family: var(--font-display); font-weight: 400;
    font-size: var(--text-step-2); color: var(--color-navy);
    letter-spacing: -0.015em;
    font-variation-settings: "opsz" 60;
  }
  .work-card-foot {
    padding: 1rem 1.75rem;
    border-top: 1px solid var(--color-line);
    background: var(--color-bg-soft);
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; flex-wrap: wrap;
  }
  .work-card-scope {
    font-family: var(--font-mono); font-size: var(--text-step--2);
    letter-spacing: 0.06em; color: var(--color-fg-muted);
  }
  .work-card-cta {
    font-family: var(--font-sans); font-size: var(--text-step--1);
    font-weight: 500; color: var(--color-blue);
    display: inline-flex; align-items: center; gap: 0.4rem;
  }
  .work-card-cta .arrow { transition: transform 280ms var(--ease-soft); }
  .work-card-link:hover .work-card-cta .arrow,
  .work-card-link:focus-visible .work-card-cta .arrow { transform: translateX(4px); }

  /* ---------- upcoming pipeline ---------- */
  .pipeline-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }
  .pipeline-card { padding: 1.75rem; border: 1px solid var(--color-line); border-radius: 14px; background: var(--color-paper); display: flex; flex-direction: column; gap: 1rem; }
  .pipeline-header { display: flex; justify-content: space-between; align-items: center; font-family: var(--font-mono); font-size: var(--text-step--2); letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-fg-muted); gap: 0.75rem; flex-wrap: wrap; }
  .pipeline-status { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--color-blue); }
  .pipeline-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--color-periwinkle); }
  .pipeline-dot-build { background: #2bb673; }
  .pipeline-dot-design { background: var(--color-blue); }
  .pipeline-dot-discovery { background: var(--color-periwinkle); }
  .pipeline-eta { color: var(--color-fg-muted); }
  .pipeline-title { font-family: var(--font-display); font-weight: 400; font-size: var(--text-step-2); margin: 0; letter-spacing: -0.015em; color: var(--color-navy); font-variation-settings: "opsz" 60; }
  .pipeline-desc { margin: 0; color: var(--color-fg-soft); font-size: var(--text-step--1); line-height: 1.5; }
  .pipeline-meta { font-family: var(--font-mono); font-size: var(--text-step--2); color: var(--color-fg-muted); letter-spacing: 0.06em; padding-top: 0.5rem; border-top: 1px solid var(--color-line); }

  .section-note { background: var(--color-bg-soft); border-block: 1px solid var(--color-line); }
  .note-inner { display: flex; flex-direction: column; gap: 1.25rem; padding-block: 1rem; }
  .note-h { font-size: var(--text-step-3); max-width: 26ch; margin: 0.5rem 0 0; }
  .note-body { font-family: var(--font-display); font-weight: 300; font-size: var(--text-step-1); color: var(--color-fg-soft); line-height: 1.5; margin: 0; max-width: 58ch; font-variation-settings: "opsz" 60; }
</style>
