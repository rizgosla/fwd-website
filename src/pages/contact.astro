---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const contactInfo = [
  { heading: "Email",         body: '<a href="mailto:hello@fwd.studio">hello@fwd.studio</a>' },
  { heading: "Response time", body: "Within 24 hours, weekdays." },
  { heading: "Based in",      body: "California — working with clients anywhere." },
  { heading: "Prefer a call?", body: "Send a message first. If it sounds like a fit, we'll schedule 15 minutes." },
];
---

<BaseLayout
  title="Start a project — fwd."
  description="Tell us about your project. We read every message and reply within a day — usually with a real timeline and a yes/no on whether we're the right fit."
  schema={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://fwd.studio/" },
      { "@type": "ListItem", position: 2, name: "Contact", item: "https://fwd.studio/contact" },
    ],
  }}
>
  <PageHero
    eyebrow="Start a project"
    title="Tell us about <em>your project</em>."
    lede="A few questions below. We read every message and reply within a day or so — usually with a real timeline and a yes/no on whether we're the right fit."
  />

  <section class="pb-24">
    <div class="container-page">
      <div class="contact-grid grid gap-12 grid-cols-1 lg:grid-cols-[0.9fr_1.1fr] lg:gap-20 reveal">
        <aside class="contact-aside grid gap-8 content-start">
          {contactInfo.map((i) => (
            <div class="item">
              <h3>{i.heading}</h3>
              {i.body.startsWith("<") ? (
                <Fragment set:html={i.body} />
              ) : (
                <p>{i.body}</p>
              )}
            </div>
          ))}
        </aside>

        <form
          class="form"
          id="contactForm"
          novalidate
          method="POST"
          action="https://formspree.io/f/YOUR_FORM_ID"
        >
          {/* Honeypot — hidden from humans, bots fill it and we silently drop the submit. */}
          <input
            type="text"
            name="company_url"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
            style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;"
          />

          <div class="field-row">
            <div class="field">
              <label for="name">Name</label>
              <input id="name" name="name" type="text" required autocomplete="name" aria-describedby="name-error" />
              <span id="name-error" class="field-error" aria-live="polite"></span>
            </div>
            <div class="field">
              <label for="email">Email</label>
              <input id="email" name="email" type="email" required autocomplete="email" aria-describedby="email-error" />
              <span id="email-error" class="field-error" aria-live="polite"></span>
            </div>
          </div>

          <div class="field-row">
            <div class="field">
              <label for="company">Business / Practice</label>
              <input id="company" name="company" type="text" autocomplete="organization" />
            </div>
            <div class="field">
              <label for="tier">Service</label>
              <select id="tier" name="tier">
                <option value="">Not sure yet</option>
                <option value="landing">Landing Page — $800</option>
                <option value="full">Full Site — $1,800</option>
                <option value="other">Something else</option>
              </select>
            </div>
          </div>

          <div class="field">
            <label for="message">Tell us about your project</label>
            <textarea
              id="message"
              name="message"
              required
              aria-describedby="message-error"
              placeholder="What you do, who you serve, what you're hoping the site will do for you, and a rough timeline."
            ></textarea>
            <span id="message-error" class="field-error" aria-live="polite"></span>
          </div>

          <div class="flex items-center justify-between gap-6 flex-wrap mt-4">
            <p class="text-fg-muted text-[length:var(--text-step--2)] m-0 max-w-[34ch] font-mono tracking-[0.04em]">
              Your details are only used to respond to your inquiry. No mailing list. No resale. Ever.
            </p>
            <button id="submitBtn" type="submit" class="btn btn-primary">
              <span class="btn-label">Send message</span>
              <span class="arrow">→</span>
            </button>
          </div>

          <p id="formStatus" role="status" aria-live="polite" class="m-0 min-h-[1.4em] text-blue"></p>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
    // === Contact-form handler ==============================================
    // Sends to the Formspree endpoint in the form's action attribute via fetch
    // so we get a stay-on-page success state instead of a redirect.
    // Replace YOUR_FORM_ID in the <form action> with your real Formspree ID
    // (formspree.io → New Form → copy the endpoint). Same flow works for
    // Web3Forms, Basin, or any service that accepts JSON.
    (() => {
      const form = document.getElementById("contactForm");
      if (!form) return;
      const status = document.getElementById("formStatus");
      const submitBtn = document.getElementById("submitBtn");
      const btnLabel = submitBtn?.querySelector(".btn-label");

      const fields = ["name", "email", "message"];
      const setError = (name, msg) => {
        const el = document.getElementById(name + "-error");
        if (el) el.textContent = msg || "";
        const input = form.elements[name];
        if (input) input.setAttribute("aria-invalid", msg ? "true" : "false");
      };
      const clearErrors = () => fields.forEach((n) => setError(n, ""));

      // Clear an error as the user starts fixing it.
      fields.forEach((name) => {
        form.elements[name]?.addEventListener("input", () => setError(name, ""));
      });

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        clearErrors();
        status.textContent = "";
        status.style.color = "";

        // Honeypot — if a bot filled it, silently succeed.
        if (form.company_url?.value) {
          status.textContent = "Thanks — we'll be in touch within a day or so.";
          status.style.color = "var(--color-blue)";
          form.reset();
          return;
        }

        const name = form.name.value.trim();
        const email = form.email.value.trim();
        const message = form.message.value.trim();

        let hasError = false;
        if (!name) { setError("name", "Please add your name."); hasError = true; }
        if (!email) { setError("email", "We need an email to reply."); hasError = true; }
        else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { setError("email", "That email doesn't look right."); hasError = true; }
        if (!message) { setError("message", "Tell us a little about the project."); hasError = true; }
        if (hasError) {
          status.textContent = "Please fix the highlighted fields above.";
          status.style.color = "#c25b5b";
          return;
        }

        // Loading state.
        submitBtn.disabled = true;
        if (btnLabel) btnLabel.textContent = "Sending…";
        status.textContent = "";

        try {
          const action = form.getAttribute("action") || "";
          // If the form hasn't been wired up to a real backend yet, fall back
          // to a friendly local success state so dev/preview still feels real.
          if (action.includes("YOUR_FORM_ID") || !action) {
            await new Promise((r) => setTimeout(r, 700));
            status.textContent = "Thanks — we'll be in touch within a day or so. (Note: form backend not yet wired up.)";
            status.style.color = "var(--color-blue)";
            form.reset();
            return;
          }
          const res = await fetch(action, {
            method: "POST",
            headers: { Accept: "application/json" },
            body: new FormData(form),
          });
          if (!res.ok) throw new Error("Bad response");
          status.textContent = "Thanks — we'll be in touch within a day or so.";
          status.style.color = "var(--color-blue)";
          form.reset();
        } catch (err) {
          status.textContent = "Something went wrong sending the form. Email us directly at hello@fwd.studio?";
          status.style.color = "#c25b5b";
        } finally {
          submitBtn.disabled = false;
          if (btnLabel) btnLabel.textContent = "Send message";
        }
      });
    })();
  </script>
</BaseLayout>

<style>
  .contact-aside .item h3 {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: var(--text-step--2);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin: 0 0 0.4rem;
  }
  .contact-aside .item p,
  .contact-aside .item a {
    font-family: var(--font-display);
    font-size: var(--text-step-1);
    color: var(--color-fg);
    line-height: 1.35;
    font-variation-settings: "opsz" 60, "SOFT" 30;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .contact-aside .item a {
    border-bottom: 1px solid var(--color-line);
    padding-bottom: 1px;
    transition: color 200ms, border-color 200ms;
  }
  .contact-aside .item a:hover {
    color: var(--color-blue);
    border-bottom-color: var(--color-blue);
  }

  .form {
    display: grid;
    gap: 1.5rem;
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: 18px;
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }
  .field {
    display: grid;
    gap: 0.4rem;
  }
  .field label {
    font-size: var(--text-step--2);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    font-weight: 500;
    font-family: var(--font-mono);
  }
  .field input,
  .field textarea,
  .field select {
    width: 100%;
    padding: 0.85rem 1rem;
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: 4px;
    color: var(--color-fg);
    font: inherit;
    transition: border-color 200ms var(--ease-soft), background 200ms var(--ease-soft);
  }
  .field input:focus,
  .field textarea:focus,
  .field select:focus {
    outline: none;
    border-color: var(--color-blue);
    background: var(--color-paper);
    box-shadow: 0 0 0 3px rgb(20 70 103 / 0.08);
  }
  .field textarea {
    min-height: 140px;
    resize: vertical;
  }
  .field-row {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 600px) {
    .field-row { grid-template-columns: 1fr 1fr; }
  }

  /* Inline error text under a field */
  .field-error {
    color: #c25b5b;
    font-size: var(--text-step--2);
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    min-height: 1.1em;
    margin-top: 0.25rem;
  }
  .field input[aria-invalid="true"],
  .field textarea[aria-invalid="true"],
  .field select[aria-invalid="true"] {
    border-color: #c25b5b;
    background: rgba(194, 91, 91, 0.04);
  }

  /* Submit-button disabled / loading state */
  .form .btn[disabled] {
    opacity: 0.6;
    cursor: progress;
    pointer-events: none;
  }
</style>
