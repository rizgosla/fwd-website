---
import BurntLayout from "../layouts/BurntLayout.astro";

const M = "/burntmockup/media";

const arrow = `<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7h10m0 0L8 3m4 4l-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

const dishes = [
  { img: "p-spag-stack.jpg", name: ["Spaghetti", "Grilled Cheese"], sub: "pressed spaghetti, mozzarella, marinara", price: "$15", badge: "Signature" },
  { img: "p-pancake-pink.jpg", name: ["Chilaquiles"], sub: "shredded beef, queso fresco, avocado, fried egg", price: "$20", badge: "House" },
  { img: "p-club.jpg", name: ["Mango Fluffy", "Soufflé Pancakes"], sub: "2 jiggly pancakes, ice cream", price: "$15", badge: "Seasonal Special" },
  { img: "chicken%20sandwhich.jpg", name: ["Fried Chicken", "Sandwich"], sub: "buttermilk fried chicken, sriracha honey, garlic aioli", price: "$15", badge: "Hot" },
  { img: "p-chilaquiles-bowl.jpg", name: ["Breakfast", "Burrito"], sub: "eggs, potatoes, grilled onions, cilantro crema", price: "$16", badge: "A.M." },
  { img: "p-cubano.jpg", name: ["Shredded", "Beef"], sub: "avocado spread, pickled onions, provolone, salsa verde", price: "$16", badge: "Fan Fav" },
  { img: "nashville.jpg", name: ["Nashville Hot", "Chicken"], sub: "fried thigh, brioche, pickles, hot honey", price: "$15", badge: "Hot" },
  { img: "asada-fries.jpg", name: ["Carne Asada", "Fries"], sub: "carne asada, lime crema, pickled onion, queso fresco", price: "$12.50", badge: "Sides" },
];

const stages = [
  { folder: "burrito", count: 9, bg: "bg-butter", scene: "Scene 01", chip: "Burrito", eyebrow: "Breakfast Burrito", title: "Sauce. <em>By the ounce.</em>", sub: "Pico, potato, melt — and the house red that everyone reorders." },
  { folder: "chicken", count: 10, bg: "bg-sky", scene: "Scene 02", chip: "Hot Chicken", eyebrow: "Southern Fried Chicken", title: "A little <em>heat,</em><br/>a lot of biscuit.", sub: "Buttermilk-brined, fried golden, glazed in our hot oil." },
  { folder: "pancake", count: 13, bg: "bg-blush", scene: "Scene 03", chip: "Pancakes", eyebrow: "Soufflé Pancakes", title: "Pancakes that<br/><em>move.</em>", sub: "2 fluffy stacks, ice cream, fresh fruit. The most photographed plate on the menu." },
  { folder: "salad", count: 9, bg: "bg-lavender", scene: "Scene 04", chip: "Greens", eyebrow: "Carne Asada Salad", title: "Salads that<br/><em>show off.</em>", sub: "Crisp romaine, carne asada, cotija, tortilla strips, lime-crema dressing." },
];

const cats = [
  { img: "p-breakfast-burrito.jpg", count: "14 items", name: "Breakfast" },
  { img: "hero-spag-melt.jpg", count: "11 items", name: "Sandwiches" },
  { img: "p-pancake-mango.jpg", count: "06 items", name: "Pancakes" },
  { img: "p-table-pink.jpg", count: "09 items", name: "Brunch Plates" },
  { img: "hero-fries.jpg", count: "07 items", name: "Sides & Sauces", pos: "object-[center_75%]" },
];

const hot = [
  { img: "hero-pancake.jpg", tags: ["New", "Limited"], title: 'The Spaghetti <em class="font-serif italic font-normal">Melt</em>', desc: "Garlic sourdough, hand-pulled marinara, three cheeses, finished on the flat-top.", price: "$15" },
  { img: "hero-table.jpg", pos: "object-[center_85%]", tags: ["Hot"], title: "Nashville Hot Chicken", desc: "Fried thigh, brioche, pickles, hot honey. Order with fries and the green crema.", price: "$15" },
  { img: "p-pancake-mango.jpg", tags: ["Insta-bait"], title: "Original Soufflé Stack", desc: "Three fluffy layers, fresh whip, fruit of the week. Pretty enough to film, gone in five.", price: "$15" },
];

const reviews = [
  { src: "Yelp · Christine C.", quote: 'The <em class="italic text-ember">spaghetti grilled cheese</em> alone is worth the drive. We came back the next morning for the pancakes.', by: "Mission Viejo", avatar: "C" },
  { src: "Google · Jess B.", quote: 'Fluffy <em class="italic text-ember">cloud</em> pancakes. The hot chicken biscuit is criminally good. Bring friends to share.', by: "Irvine", avatar: "J" },
  { src: "Yelp · Jayson P.", quote: 'Catered our office. Fifty hungry engineers. <em class="italic text-ember">Zero</em> leftovers. They want it again next Friday.', by: "Newport", avatar: "J" },
  { src: "Google · Kevin K.", quote: 'The breakfast burrito with house red sauce on the side. <em class="italic text-ember">Pour it on.</em> Best decision I made all week.', by: "Tustin", avatar: "K" },
];

const navLinks = ["Menu", "Story", "Catering", "Find Us"];
---

<BurntLayout>
  <!-- ── Nav ───────────────────────────────────────────────────────── -->
  <header
    id="burnt-nav"
    class="sticky top-0 z-[70] bg-ink text-paper transition-shadow"
  >
    <div class="mx-auto flex max-w-screen-xl items-center justify-between px-4 py-3 md:px-8 md:py-4">
      <img src={`${M}/logo.png`} alt="Burnt Crumbs" class="h-9 w-auto drop-shadow md:h-11" />

      <nav class="hidden items-center gap-8 md:flex">
        {navLinks.map((l) => (
          <a href="#" class="font-display text-[13px] font-medium uppercase tracking-[0.14em] text-paperdim transition-colors hover:text-paper">{l}</a>
        ))}
      </nav>

      <div class="flex items-center gap-2">
        <a
          href="#"
          class="inline-flex items-center gap-1.5 rounded-full bg-ember px-4 py-2.5 font-display text-[13px] font-semibold uppercase tracking-[0.1em] text-paper shadow-[0_4px_16px_rgba(197,69,58,0.45),inset_0_1px_0_rgba(255,255,255,0.18)]"
          >Order</a
        >
        <button
          id="burnt-menu-btn"
          aria-label="Menu"
          aria-expanded="false"
          class="grid h-[42px] w-[42px] place-items-center rounded-full border border-paper/20 bg-paper/[0.18] backdrop-blur md:hidden"
        >
          <div>
            <span class="my-[3px] block h-[1.6px] w-[18px] rounded bg-paper"></span>
            <span class="my-[3px] block h-[1.6px] w-[18px] rounded bg-paper"></span>
            <span class="my-[3px] block h-[1.6px] w-[18px] rounded bg-paper"></span>
          </div>
        </button>
      </div>
    </div>

    <!-- mobile dropdown -->
    <div id="burnt-mobile-menu" class="hidden border-t border-paper/10 bg-ink px-4 pb-4 md:hidden">
      <nav class="flex flex-col">
        {navLinks.map((l) => (
          <a href="#" class="border-b border-paper/10 py-3 font-display text-sm font-medium uppercase tracking-[0.14em] text-paperdim last:border-0">{l}</a>
        ))}
      </nav>
    </div>
  </header>

  <!-- ── Marquee ───────────────────────────────────────────────────── -->
  <div class="overflow-hidden border-y border-paper/10 bg-ink py-[7px] text-paperdim">
    <div class="burnt-marquee-track flex gap-7 whitespace-nowrap font-display text-[11px] font-medium uppercase tracking-[0.2em]">
      {Array.from({ length: 2 }).map(() =>
        ["Burnt on purpose", "Scratch made daily", "Sauce by the ounce", "Spaghetti grilled cheese", "Pancakes that move"].map((t) => (
          <span class="inline-flex items-center gap-3.5">{t}<span class="h-[5px] w-[5px] rounded-full bg-ember"></span></span>
        ))
      )}
    </div>
  </div>

  <!-- ── Hero ──────────────────────────────────────────────────────── -->
  <section id="burnt-hero" class="relative overflow-hidden text-paper">
    <div class="absolute inset-0 bg-char">
      <img src={`${M}/hero-spag-melt.jpg`} alt="Spaghetti grilled cheese" class="h-full w-full scale-105 object-cover object-[50%_60%]" />
    </div>
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(26,20,16,0.6)_0%,rgba(26,20,16,0)_25%,rgba(26,20,16,0)_55%,rgba(26,20,16,0.9)_100%)] md:bg-[linear-gradient(90deg,rgba(26,20,16,0.85)_0%,rgba(26,20,16,0.45)_45%,rgba(26,20,16,0)_75%)]"></div>

    <div class="absolute right-5 top-[120px] hidden [writing-mode:vertical-rl] sm:flex sm:items-center sm:gap-2 font-display text-[10px] uppercase tracking-[0.24em] text-paper/70">
      <span>Scroll</span>
      <span class="burnt-drop-line block h-9 w-px bg-paper/70"></span>
    </div>

    <div class="relative mx-auto flex min-h-[760px] max-w-screen-xl flex-col justify-end px-5 pb-10 md:min-h-[88vh] md:justify-center md:px-8 md:pb-0 lg:px-12">
      <div class="md:max-w-[60%] lg:max-w-[52%]">
        <div class="inline-flex items-center gap-2 font-display text-[11px] uppercase tracking-[0.2em] text-paperdim/90">
          <span class="h-1.5 w-1.5 rounded-full bg-ember shadow-[0_0_12px_var(--color-emberlit)]"></span>
          Irvine, CA &nbsp;·&nbsp; Est. 2010 &nbsp;·&nbsp; #scratchmade
        </div>
        <h1 class="mt-2.5 font-display text-[88px] font-bold uppercase leading-[0.9] tracking-[-0.01em] md:text-[110px] lg:text-[140px]">
          Burnt<br />
          <em class="block font-serif text-[74px] italic font-bold leading-[0.9] tracking-[-0.02em] text-ember md:text-[92px] lg:text-[118px]">on purpose.</em>
        </h1>
        <p class="mt-4 max-w-[28ch] font-serif text-[17px] italic leading-[1.4] text-paperdim md:text-xl">
          Scratch-made comfort bites and the spaghetti grilled cheese that started it all.
        </p>
        <div class="mt-6 flex items-center gap-2.5">
          <a href="#" class="inline-flex flex-1 items-center justify-center gap-2 rounded-full bg-ember px-5 py-4 font-display text-sm font-semibold uppercase tracking-[0.1em] text-paper shadow-[0_6px_24px_rgba(197,69,58,0.45),inset_0_1px_0_rgba(255,255,255,0.18)] md:flex-none md:px-8">
            Order Online <Fragment set:html={arrow} />
          </a>
          <a href="#" aria-label="View menu" class="grid h-[54px] w-[54px] place-items-center rounded-full border border-paper/50 bg-paper/[0.06] text-paper backdrop-blur">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 5h10M5 10h10M5 15h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Story ─────────────────────────────────────────────────────── -->
  <section class="bg-paper px-5 py-16 md:px-8 md:py-24 lg:px-12">
    <div class="mx-auto grid max-w-screen-xl items-center gap-10 md:grid-cols-2 md:gap-16">
      <div>
        <div class="font-display text-[11px] font-medium uppercase tracking-[0.2em] text-char/55">
          <span class="mr-2 inline-block h-1.5 w-1.5 rounded-full bg-ember align-middle"></span>The burnt story
        </div>
        <h2 class="my-3 font-display text-[56px] font-bold uppercase leading-[0.94] tracking-[-0.01em] text-char text-balance md:text-[64px]">
          A nickname<br />that <em class="font-serif italic font-bold text-ember">stuck.</em>
        </h2>
        <p class="burnt-dropcap my-4 font-serif text-base leading-[1.6] text-char/[0.78] md:text-[17px]">
          In college, Chef Paul Cao fried his spaghetti to crisp the bottom. His roommates called it <em class="italic">burnt spaghetti</em>. The name caught on. The food truck followed in 2010. Today the truck is a kitchen on Irvine Center Drive — same crispy edges, same scratch-made sauces, same chef.
        </p>
        <a href="#" class="inline-flex items-center gap-2 border-b-[1.5px] border-char pb-0.5 font-display text-[13px] font-semibold uppercase tracking-[0.1em] text-char">
          Read the full story <Fragment set:html={arrow} />
        </a>
      </div>
      <div class="relative aspect-[4/5] overflow-hidden rounded-[22px] bg-char">
        <img src={`${M}/hero-spag-melt.jpg`} alt="Spaghetti grilled cheese" class="h-full w-full object-cover" />
        <span class="absolute left-3.5 top-3.5 rounded-full bg-char px-2.5 py-1.5 font-display text-[10px] font-semibold uppercase tracking-[0.2em] text-paper">The Original</span>
      </div>
    </div>
  </section>

  <!-- ── Curved Carousel ───────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-char px-5 py-16 text-paper md:px-8 md:py-24 lg:px-12">
    <div class="mx-auto max-w-screen-xl">
      <div class="font-display text-[11px] font-medium uppercase tracking-[0.2em] text-paper/55">
        <span class="mr-2 inline-block h-1.5 w-1.5 rounded-full bg-ember align-middle"></span>The hall of fame
      </div>
      <h2 class="my-3 font-display text-[56px] font-bold uppercase leading-[0.94] tracking-[-0.01em] text-balance md:text-[64px]">
        The <em class="font-serif italic font-bold text-ember">classics</em><br />you came for.
      </h2>

      <div class="flex items-center justify-between gap-5 pb-1.5 pt-5 text-paperdim">
        <div class="font-serif text-3xl italic leading-none"><span id="ci-num">01</span> <span class="opacity-50">/ 08</span></div>
        <div class="text-right">
          <div id="ci-name" class="font-display text-base font-bold uppercase tracking-[0.02em] text-paper">Spaghetti Grilled Cheese</div>
          <div id="ci-price" class="mt-0.5 font-serif text-[17px] font-medium text-amber">$15</div>
        </div>
      </div>
    </div>

    <div class="relative mt-7 h-[540px]">
      <div id="carousel" class="burnt-no-scrollbar absolute inset-0 flex snap-x snap-mandatory gap-[18px] overflow-x-auto px-[35%] [perspective:1200px] md:px-[40%]">
        {dishes.map((d) => (
          <div
            class="burnt-card relative h-[360px] flex-[0_0_220px] origin-bottom snap-center overflow-hidden rounded-[18px] bg-[#2a1d15] shadow-[0_30px_60px_rgba(0,0,0,0.4)] [will-change:transform,opacity]"
            data-name={d.name.join(" ")}
            data-price={d.price}
          >
            <img src={`${M}/${d.img}`} alt={d.name.join(" ")} class="block h-full w-full object-cover" />
            <span class="absolute left-3 top-3 rounded bg-ember px-[7px] py-1 font-display text-[9.5px] font-semibold uppercase tracking-[0.18em] text-paper">{d.badge}</span>
            <span class="absolute right-3 top-3 rounded-full bg-paper px-[9px] py-1 font-display text-xs font-bold text-char">{d.price}</span>
            <div class="absolute inset-x-0 bottom-0 bg-[linear-gradient(180deg,rgba(0,0,0,0)_0%,rgba(0,0,0,0.75)_100%)] p-3.5 pt-10">
              <div class="font-display text-xl font-bold uppercase leading-[1.05]" set:html={d.name.join("<br/>")}></div>
              <div class="mt-1 font-serif text-xs italic text-paper/70">{d.sub}</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="mx-auto mt-[18px] flex max-w-screen-xl items-center justify-between">
      <div id="carousel-dots" class="flex gap-1.5"></div>
      <a href="#" class="inline-flex items-center gap-2 border-b-[1.5px] border-paper pb-0.5 font-display text-[13px] font-semibold uppercase tracking-[0.1em] text-paper">
        See full menu <Fragment set:html={arrow} />
      </a>
    </div>
  </section>

  <!-- ── Stop-motion ───────────────────────────────────────────────── -->
  <div class="bg-paper px-5 pb-6 pt-[70px] md:px-8 lg:px-12">
    <div class="mx-auto max-w-screen-xl">
      <div class="font-display text-[11px] font-medium uppercase tracking-[0.2em] text-char/55">
        <span class="mr-2 inline-block h-1.5 w-1.5 rounded-full bg-ember align-middle"></span>Sauce, by the ounce
      </div>
      <h2 class="my-3 font-display text-[56px] font-bold uppercase leading-[0.94] tracking-[-0.01em] text-char md:text-[64px]">
        The <em class="font-serif italic font-bold text-ember">best</em><br />part.
      </h2>
      <p class="mt-2.5 font-serif text-[17px] italic text-char/65">Watch each dish hit. Then come hungry.</p>
    </div>
  </div>

  <div class="bg-paper">
    {stages.map((s) => (
      <div class={`burnt-stage ${s.bg}`} data-folder={s.folder} data-count={s.count}>
        <div class="mx-auto flex max-w-screen-xl flex-col px-4 pb-5 pt-12 md:grid md:grid-cols-2 md:items-center md:gap-12 md:px-8 md:py-20 lg:px-12">
          <div class="order-2 text-char md:order-1">
            <div class="inline-flex items-center gap-2 self-end font-display text-[10.5px] font-semibold uppercase tracking-[0.2em] text-char md:mb-4">
              <span>{s.scene}</span>
              <span class="rounded-md bg-char px-2 py-1 font-serif text-[13px] font-medium italic text-paper">{s.chip}</span>
            </div>
            <div class="pt-4 md:pt-0">
              <div class="font-display text-[11px] font-medium uppercase tracking-[0.2em] text-char/70">{s.eyebrow}</div>
              <h3 class="mt-1.5 font-display text-[58px] font-bold uppercase leading-[0.9] tracking-[-0.01em] text-char md:text-[68px] [&_em]:font-serif [&_em]:italic [&_em]:font-bold [&_em]:text-ember" set:html={s.title}></h3>
              <p class="mt-2 max-w-[24ch] font-serif text-[15px] italic leading-[1.4] md:text-base">{s.sub}</p>
            </div>
          </div>
          <div class="burnt-frames order-1 relative aspect-square w-full shrink-0 overflow-hidden rounded-[18px] shadow-[0_24px_60px_rgba(0,0,0,0.28)] md:order-2"></div>
        </div>
      </div>
    ))}
  </div>

  <!-- ── Menu Categories ───────────────────────────────────────────── -->
  <section class="bg-paper px-5 py-14 md:px-8 md:py-20 lg:px-12">
    <div class="mx-auto max-w-screen-xl">
      <div class="font-display text-[11px] font-medium uppercase tracking-[0.2em] text-char/55">
        <span class="mr-2 inline-block h-1.5 w-1.5 rounded-full bg-ember align-middle"></span>The menu
      </div>
      <h2 class="my-3 font-display text-[56px] font-bold uppercase leading-[0.94] tracking-[-0.01em] text-char md:text-[64px]">
        Pick your <em class="font-serif italic font-bold text-ember">lane.</em>
      </h2>
      <div class="mt-6 grid grid-cols-1 gap-3.5 sm:grid-cols-2 lg:grid-cols-3">
        {cats.map((c) => (
          <a href="#" class="relative isolate flex h-[132px] items-end overflow-hidden rounded-[18px] p-4 text-paper md:h-[180px]">
            <img src={`${M}/${c.img}`} alt="" class={`absolute inset-0 -z-20 h-full w-full object-cover ${c.pos ?? ""}`} />
            <span class="absolute inset-0 -z-10 bg-[linear-gradient(180deg,rgba(0,0,0,0.05),rgba(0,0,0,0.5)_70%,rgba(0,0,0,0.78)_100%)]"></span>
            <span class="absolute right-3.5 top-3.5 rounded-full bg-paper/90 px-2 py-1 font-display text-[10px] font-semibold uppercase tracking-[0.14em] text-char">{c.count}</span>
            <div class="font-display text-4xl font-bold uppercase leading-[0.9] tracking-[0.01em]">{c.name}</div>
            <span class="absolute bottom-3.5 right-3.5 grid h-9 w-9 place-items-center rounded-full bg-paper text-char"><Fragment set:html={arrow} /></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Hot List ──────────────────────────────────────────────────── -->
  <section class="bg-char px-5 py-16 text-paper md:px-8 md:py-24 lg:px-12">
    <div class="mx-auto max-w-screen-xl">
      <div class="font-display text-[11px] font-medium uppercase tracking-[0.2em] text-paper/55">
        <span class="mr-2 inline-block h-1.5 w-1.5 rounded-full bg-ember align-middle"></span>The hot list
      </div>
      <h2 class="my-3 font-display text-[56px] font-bold uppercase leading-[0.94] tracking-[-0.01em] md:text-[64px]">
        What's <em class="font-serif italic font-bold text-ember">hot</em><br />this week.
      </h2>
      <div class="mt-7 grid gap-7 md:grid-cols-3">
        {hot.map((h) => (
          <div class="flex flex-col gap-3 border-b border-paper/10 pb-6 md:border-b-0 md:pb-0">
            <div class="relative aspect-[5/3] overflow-hidden rounded-[14px] bg-[#222]">
              <img src={`${M}/${h.img}`} alt="" class={`h-full w-full object-cover ${h.pos ?? ""}`} />
              <div class="absolute left-2.5 top-2.5 flex gap-1.5">
                {h.tags.map((t) => (
                  <span class="rounded-full bg-char/70 px-2 py-1 font-display text-[10px] font-semibold uppercase tracking-[0.14em] text-paper backdrop-blur">{t}</span>
                ))}
              </div>
            </div>
            <div class="flex items-start justify-between gap-4">
              <div>
                <h4 class="font-display text-[22px] font-bold uppercase leading-[1.05] tracking-[0.01em]" set:html={h.title}></h4>
                <p class="mt-1 max-w-[32ch] font-serif text-sm italic leading-[1.4] text-paper/65">{h.desc}</p>
              </div>
              <div class="whitespace-nowrap pt-1 font-display text-[15px] font-bold text-amber">{h.price}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Reviews ───────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-amber px-5 py-14 text-char md:px-8 md:py-20 lg:px-12">
    <div class="mx-auto max-w-screen-xl">
      <div class="font-display text-[11px] font-medium uppercase tracking-[0.2em] text-char/55">
        <span class="mr-2 inline-block h-1.5 w-1.5 rounded-full bg-ember align-middle"></span>Reviewed by Orange County
      </div>
      <div class="md:flex md:items-end md:justify-between md:gap-10">
        <h2 class="mt-2.5 font-display text-[52px] font-bold uppercase leading-[0.92] tracking-[-0.01em] md:text-[64px]">
          Cleared the<br />plate. <em class="font-serif italic font-bold">Twice.</em>
        </h2>
        <div class="mt-2.5 flex items-baseline gap-3.5 font-serif italic">
          <div class="text-6xl leading-none">4.8</div>
          <div>
            <div class="flex gap-0.5 text-char" aria-label="4.8 out of 5">
              {Array.from({ length: 5 }).map(() => (
                <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M7 0l2.1 4.3 4.8.7-3.5 3.3.8 4.7L7 10.8 2.8 13l.8-4.7L.1 5l4.8-.7z" /></svg>
              ))}
            </div>
            <div class="mt-1 font-display text-[11px] font-medium uppercase not-italic tracking-[0.18em]">2,400+ reviews · yelp + google</div>
          </div>
        </div>
      </div>
    </div>

    <div class="burnt-no-scrollbar -mx-5 mt-6 flex snap-x snap-mandatory gap-3.5 overflow-x-auto px-5 pb-2 md:mx-auto md:max-w-screen-xl md:grid md:grid-cols-4 md:gap-5 md:overflow-visible md:px-0">
      {reviews.map((r) => (
        <div class="flex flex-[0_0_270px] snap-start flex-col gap-2.5 rounded-2xl bg-paper p-[18px] text-char shadow-[0_18px_40px_rgba(0,0,0,0.12)] md:flex-auto">
          <div class="font-display text-[10px] font-medium uppercase tracking-[0.18em] text-char/50">{r.src}</div>
          <p class="font-serif text-[15px] leading-[1.45]" set:html={`"${r.quote}"`}></p>
          <div class="mt-auto flex items-center gap-2 font-display text-xs font-semibold uppercase tracking-[0.1em]">
            <span class="grid h-7 w-7 place-items-center rounded-full bg-ember text-xs text-paper">{r.avatar}</span>{r.by}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Catering ──────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-char px-5 py-16 text-paper md:px-8 md:py-24 lg:px-12">
    <div class="mx-auto grid max-w-screen-xl items-center gap-10 md:grid-cols-2 md:gap-16">
      <div>
        <div class="font-display text-[11px] font-medium uppercase tracking-[0.2em] text-paper/55">
          <span class="mr-2 inline-block h-1.5 w-1.5 rounded-full bg-ember align-middle"></span>Catering
        </div>
        <h2 class="my-3 font-display text-[56px] font-bold uppercase leading-[0.94] tracking-[-0.01em] md:text-[64px]">
          Feed the<br /><em class="font-serif italic font-bold text-ember">whole office.</em>
        </h2>
        <p class="font-serif text-[17px] italic text-paper/60">From a 10-person breakfast meeting to a 200-guest rehearsal dinner — we'll show up packed, hot, and on time.</p>
        <div class="my-6 grid grid-cols-2 gap-3.5">
          {[
            ["Built for groups", "Boxed lunches, family-style trays, full set-ups."],
            ["48-hr lead time", "Order online or by phone. We confirm same-day."],
            ["Hot drop-offs", "Delivered ready-to-serve in OC + neighboring counties."],
            ["Custom menus", "Brunch, lunch, or pancake bar. Yes, really."],
          ].map(([t, d]) => (
            <div class="font-serif text-sm italic leading-[1.4] text-paper/70">
              <strong class="mb-0.5 block font-display text-[22px] not-italic font-bold tracking-[0.01em] text-paper">{t}</strong>{d}
            </div>
          ))}
        </div>
      </div>
      <div class="relative aspect-[16/11] overflow-hidden rounded-[18px]">
        <img src={`${M}/p-table-yellow.jpg`} alt="Spread of dishes" class="h-full w-full object-cover" />
        <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(26,20,16,0.1)_30%,rgba(26,20,16,0.85))]"></div>
        <div class="absolute inset-x-4 bottom-4 text-paper">
          <h3 class="font-display text-4xl font-bold uppercase leading-[0.94] tracking-[0.01em]">Get a catering quote →</h3>
          <p class="mt-1.5 font-serif text-sm italic opacity-85">Hit reply within 12 hours. Promise.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Location ──────────────────────────────────────────────────── -->
  <section class="bg-paper px-5 py-16 text-char md:px-8 md:py-24 lg:px-12">
    <div class="mx-auto max-w-screen-xl">
      <div class="font-display text-[11px] font-medium uppercase tracking-[0.2em] text-char/55">
        <span class="mr-2 inline-block h-1.5 w-1.5 rounded-full bg-ember align-middle"></span>Find us
      </div>
      <h2 class="my-3 font-display text-[56px] font-bold uppercase leading-[0.94] tracking-[-0.01em] md:text-[64px]">
        Irvine. <em class="font-serif italic font-bold text-ember">One spot.</em>
      </h2>
      <div class="mt-6 overflow-hidden rounded-[20px] border border-char/10 bg-paper md:grid md:grid-cols-2">
        <div class="burnt-map relative h-[200px] overflow-hidden md:h-full md:min-h-[320px]">
          <div class="absolute -inset-x-[10%] top-[38%] h-2 -rotate-[8deg] border-y-[1.5px] border-char bg-paper"></div>
          <div class="absolute -inset-x-[10%] top-[60%] h-3.5 rotate-[-6deg] border-y-[1.5px] border-char bg-paper"></div>
          <div class="absolute left-1/2 top-[52%] h-[52px] w-10 -translate-x-1/2 -translate-y-full">
            <div class="grid h-10 w-10 -rotate-45 place-items-center rounded-[999px_999px_999px_4px] bg-ember shadow-[0_12px_24px_rgba(0,0,0,0.25)]">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="#f5ede0" class="rotate-45"><circle cx="7" cy="7" r="3" /></svg>
            </div>
          </div>
        </div>
        <div>
          <div class="px-[18px] pb-2 pt-[18px]">
            <div class="font-display text-[11px] font-medium uppercase tracking-[0.2em] text-char/50">Irvine, CA</div>
            <div class="mt-1 font-display text-[22px] font-bold uppercase leading-[1.15] tracking-[0.01em]">8549 Irvine Center Dr.<br /><em class="font-serif italic font-normal text-ember">Irvine, CA 92618</em></div>
          </div>
          <div class="mt-2.5 border-t border-dashed border-char/20 px-[18px] py-3.5">
            <div class="flex items-baseline justify-between py-[5px] font-body text-sm font-medium">
              <span class="font-bold text-char">Mon – Sun</span>
              <span class="before:mr-1.5 before:inline-block before:h-[7px] before:w-[7px] before:rounded-full before:bg-[#2a9d4a] before:align-middle before:shadow-[0_0_0_4px_rgba(42,157,74,0.18)] before:content-['']">8:30 AM – 3:00 PM</span>
            </div>
          </div>
          <div class="grid grid-cols-2 border-t border-char/10">
            <a href="tel:9495025998" class="flex items-center justify-center gap-1.5 p-4 text-center font-display text-[13px] font-semibold uppercase tracking-[0.1em] text-char">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 2l2 3-1 1c1 2 2 3 4 4l1-1 3 2-1 2c-5 0-10-5-10-10l2-1z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" /></svg>Call
            </a>
            <a href="#" class="flex items-center justify-center gap-1.5 border-l border-char/10 p-4 text-center font-display text-[13px] font-semibold uppercase tracking-[0.1em] text-char">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1c-3 0-5 2-5 5 0 4 5 7 5 7s5-3 5-7c0-3-2-5-5-5zm0 7a2 2 0 100-4 2 2 0 000 4z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" /></svg>Directions
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Footer ────────────────────────────────────────────────────── -->
  <footer class="bg-char px-5 pb-28 pt-12 text-paperdim md:px-8 md:pb-12 md:pt-20 lg:px-12">
    <div class="mx-auto max-w-screen-xl md:grid md:grid-cols-2 md:gap-12">
      <div>
        <div class="font-display text-[78px] font-bold uppercase leading-[0.88] tracking-[-0.01em] text-paper md:text-[96px]">
          Burnt<br />on<br /><em class="font-serif italic font-bold text-ember">purpose.</em>
        </div>
        <p class="mt-[18px] max-w-[30ch] font-serif text-[15px] italic leading-[1.4] text-paper/55">Scratch-made since 2010. Started as The Burnt Truck. Still chef-run, still family.</p>
      </div>
      <div class="mt-8 md:mt-0">
        <div class="grid grid-cols-2 gap-[18px_14px]">
          {["Order Online", "Catering", "Full Menu", "Merch", "Our Story", "Contact"].map((l) => (
            <a href="#" class="font-display text-[13px] font-medium uppercase tracking-[0.06em] text-paper">{l} <span class="ml-1 text-ember">↗</span></a>
          ))}
        </div>
        <div class="mt-7 flex gap-2.5">
          {[
            '<rect x="2" y="2" width="14" height="14" rx="4" stroke="currentColor" stroke-width="1.4"/><circle cx="9" cy="9" r="3" stroke="currentColor" stroke-width="1.4"/><circle cx="13.5" cy="4.5" r="0.8" fill="currentColor"/>',
            '<path d="M11 6V4.5c0-0.6.4-1 1-1h1V1h-2c-1.7 0-3 1.3-3 3v2H6v2h2v7h3V8h2l.5-2H11z" fill="currentColor"/>',
            '<path d="M9 1.5v7l3-1.5-3-5.5zm-2 8L2 8v3l5-1.5zm0 1.5l-4 3 2.5 2L9 13l-2-2zm4-1L13 10l3 2-1.5 2.5L11 12z" fill="currentColor"/>',
            '<path d="M11 1v8.5a2 2 0 11-2-2V6a4.5 4.5 0 104.5 4.5V4.5a3.5 3.5 0 003 1V3a3 3 0 01-3-2H11z" fill="currentColor"/>',
          ].map((svg) => (
            <a href="#" class="grid h-11 w-11 place-items-center rounded-full border border-paper/20 text-paperdim"><svg width="18" height="18" viewBox="0 0 18 18" fill="none" set:html={svg}></svg></a>
          ))}
        </div>
      </div>
    </div>
    <div class="mx-auto mt-[18px] flex max-w-screen-xl justify-between border-t border-paper/10 pt-[18px] font-body text-[11px] text-paper/40">
      <span>© 2026 Burnt Crumbs</span>
      <span class="flex gap-2.5"><a href="#">Privacy</a><a href="#">Terms</a></span>
    </div>
  </footer>

  <!-- ── Sticky Order Bar ──────────────────────────────────────────── -->
  <div
    id="burnt-sticky"
    class="pointer-events-none fixed bottom-7 left-1/2 z-[100] flex w-[calc(100%-40px)] max-w-[420px] -translate-x-1/2 translate-y-6 items-center justify-between gap-2 rounded-full bg-ink py-2 pl-5 pr-2 text-paper opacity-0 shadow-[0_20px_50px_rgba(0,0,0,0.55),0_0_0_1px_rgba(245,237,224,0.05)] transition-[opacity,transform] duration-300"
  >
    <div class="font-display text-[13px] font-medium uppercase tracking-[0.06em]">Open now · <em class="font-serif italic font-normal text-amber">til 3pm</em></div>
    <a href="#" class="inline-flex h-10 items-center gap-1.5 rounded-full bg-ember px-4 font-display text-xs font-semibold uppercase tracking-[0.1em] text-paper">
      Order
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6h8m0 0L7 3m3 3l-3 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
    </a>
  </div>
</BurntLayout>
