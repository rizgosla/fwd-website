---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const updated = "May 2026";
---

<BaseLayout
  title="Privacy — fwd."
  description="A short, plain-language privacy policy. We don't sell data and we don't track you across the web."
>
  <PageHero
    eyebrow={`Last updated · ${updated}`}
    title="A short, <em>plain-language</em> privacy policy."
    lede="We don't sell your data. We don't run cross-site tracking. Here's the short version of what we do and don't collect."
  />

  <section class="pb-24">
    <div class="container-page prose-page reveal">
      <h2>What we collect</h2>
      <p>
        When you submit the contact form, we collect the name, email, business
        name, service interest, and message you provide. That's it. We don't
        collect this information through any other means on this site.
      </p>

      <h2>How we use it</h2>
      <p>
        We use what you send us to reply to your inquiry. We do not add you to
        a mailing list, do not share your information with third parties, and
        do not sell it to anyone. Ever.
      </p>

      <h2>Analytics</h2>
      <p>
        If you see metrics on this page, they come from a privacy-respecting
        analytics provider that does not use cookies, does not fingerprint
        visitors, and is GDPR-compliant by default. We use it to know roughly
        how many people are visiting and which pages are useful.
      </p>

      <h2>Cookies</h2>
      <p>
        This site does not set tracking cookies. Your browser may store small
        amounts of data to make the site work (for example, remembering your
        place in an animated section), but nothing that identifies you.
      </p>

      <h2>Your data</h2>
      <p>
        Want a copy of the information we have about you, or want us to delete
        it? Email
        <a href="mailto:hello@fwd.studio">hello@fwd.studio</a>
        and we'll take care of it within 30 days.
      </p>

      <h2>Changes to this policy</h2>
      <p>
        If we update this policy, we'll bump the “Last updated” date at the
        top. Material changes will also be mentioned in our next reply to you.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .prose-page {
    max-width: 65ch;
    margin-inline: auto;
    color: var(--color-fg-soft);
    font-size: var(--text-step-0);
    line-height: 1.7;
  }
  .prose-page h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-step-2);
    color: var(--color-fg);
    letter-spacing: -0.015em;
    margin: 2.5rem 0 0.75rem;
    font-variation-settings: "opsz" 80, "SOFT" 30;
  }
  .prose-page p {
    margin: 0 0 1rem;
    text-wrap: pretty;
  }
  .prose-page a {
    color: var(--color-blue);
    border-bottom: 1px solid var(--color-line);
  }
  .prose-page a:hover { border-bottom-color: var(--color-blue); }
</style>
